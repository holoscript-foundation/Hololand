{
  "name": "hololand",
  "version": "1.1.0",
  "description": "HoloScript: VR/AI Inspired Programming Language - The first programming language designed for Virtual Reality environments",
  "packageManager": "pnpm@10.28.2",
  "private": true,
  "workspaces": [
    "packages/*"
  ],
  "scripts": {
    "build": "pnpm -r build",
    "test": "pnpm -r --workspace-concurrency=1 test",
    "lint": "pnpm -r lint",
    "clean": "pnpm -r clean",
    "audit": "pnpm audit --prod",
    "audit:fix": "pnpm audit --fix",
    "audit:hardware": "node scripts/hardware-audit.mjs",
    "typecheck": "pnpm -r typecheck",
    "typecheck:holoscript": "echo 'HoloScript type checking (.holo files)'",
    "typecheck:holoscript:watch": "echo 'HoloScript type checking with watch mode'",
    "audit:zero-typescript": "node scripts/check-zero-typescript.mjs",
    "check:zero-typescript": "node scripts/check-zero-typescript.mjs --strict",
    "check:holoscript-source-contract": "node scripts/check-holoscript-source-contract.mjs",
    "check:generated-output": "node scripts/check-generated-output-clean.mjs",
    "check:native-proof": "node scripts/check-native-holoscript-proof.mjs",
    "check:hololand-mcp-manifest": "node scripts/check-hololand-mcp-manifest.mjs",
    "format": "pnpm -r format",
    "brittney": "npx tsx scripts/start-brittney.ts",
    "playground": "pnpm --filter @hololand/playground dev",
    "dev": "npm-run-all --parallel brittney playground",
    "start": "npm run dev",
    "compile:zone": "echo 'Compile .holo zone file to target platforms - Usage: pnpm compile:zone <file.holo> <target>'",
    "compile:unity": "echo 'Compile .holo files to Unity C# - requires @holoscript/cli'",
    "compile:unreal": "echo 'Compile .holo files to Unreal C++ - requires @holoscript/cli'",
    "compile:godot": "echo 'Compile .holo files to Godot GDScript - requires @holoscript/cli'",
    "compile:babylon": "echo 'Compile .holo files to Babylon.js TypeScript - requires @holoscript/cli'",
    "compile:webgpu": "echo 'Compile .holo files to WebGPU shaders - requires @holoscript/cli'",
    "compile:all": "echo 'Compile .holo files to all targets - requires @holoscript/cli'",
    "compile:examples": "echo 'See examples/compiled-outputs/ for demonstration cross-compilation outputs'"
  },
  "keywords": [
    "holoscript",
    "vr",
    "virtual-reality",
    "spatial-programming",
    "ai",
    "programming-language",
    "webxr",
    "oculus",
    "voice-commands",
    "gesture-control"
  ],
  "author": "brianonbased-dev",
  "license": "Elastic-2.0",
  "repository": {
    "type": "git",
    "url": "https://github.com/brianonbased-dev/Hololand.git"
  },
  "engines": {
    "node": ">=20",
    "pnpm": ">=9.0.0"
  },
  "devDependencies": {
    "@eslint/js": "^9.39.2",
    "@types/node": "^20.10.0",
    "@types/webxr": "^0.5.24",
    "@typescript-eslint/eslint-plugin": "^8.0.0",
    "@typescript-eslint/parser": "^8.0.0",
    "@vitest/coverage-v8": "^4.1.5",
    "eslint": "^9.39.1",
    "eslint-config-prettier": "^9.1.0",
    "eslint-plugin-prettier": "^5.0.1",
    "glob": "^13.0.6",
    "npm-run-all": "^4.1.5",
    "prettier": "^3.1.1",
    "typescript": "^5.9.3",
    "vitest": "^4.1.5"
  },
  "dependencies": {
    "@holoscript/agent-protocol": "file:../HoloScript/packages/agent-protocol",
    "@holoscript/core": "file:../HoloScript/packages/core",
    "ethers": "^6.16.0"
  },
  "pnpm": {
    "overrides": {
      "@holoscript/core": "file:../HoloScript/packages/core",
      "@holoscript/crdt": "file:../HoloScript/packages/crdt",
      "@holoscript/mvc-schema": "file:../HoloScript/packages/mvc-schema",
      "@holoscript/runtime": "file:../HoloScript/packages/runtime",
      "@holoscript/agent-protocol": "file:../HoloScript/packages/agent-protocol",
      "@holoscript/r3f-renderer": "file:../HoloScript/packages/r3f-renderer"
    }
  }
}
