  "repository": {
    "type": "git",
    "url": "https://github.com/brianonbased-dev/Hololand.git"
  },
  "engines": {
    "node": ">=18.0.0",
    "pnpm": ">=8.0.0"
  },
  "devDependencies": {
    "@types/node": "^20.10.0",
    "typescript": "^5.3.3",
    "vitest": "^1.0.4"
  },
  "dependencies": {
    "ethers": "^6.16.0"
  }
