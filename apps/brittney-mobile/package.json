{
  "name": "@hololand/brittney-mobile",
  "version": "1.0.0-alpha.1",
  "description": "Brittney AI Mobile - Local-first HoloScript assistant for iOS and Android",
  "author": "Hololand Team",
  "license": "MIT",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "tsc && vite build",
    "preview": "vite preview",
    "cap:init": "cap init 'Brittney AI' com.hololand.brittney --web-dir dist",
    "cap:add:ios": "cap add ios",
    "cap:add:android": "cap add android",
    "cap:sync": "cap sync",
    "cap:open:ios": "cap open ios",
    "cap:open:android": "cap open android",
    "cap:run:ios": "cap run ios",
    "cap:run:android": "cap run android",
    "mobile:ios": "pnpm build && cap sync ios && cap open ios",
    "mobile:android": "pnpm build && cap sync android && cap open android"
  },
  "dependencies": {
    "@hololand/brittney-toolkit": "workspace:*",
    "@capacitor/app": "^6.0.0",
    "@capacitor/core": "^6.0.0",
    "@capacitor/filesystem": "^6.0.0",
    "@capacitor/haptics": "^6.0.0",
    "@capacitor/keyboard": "^6.0.0",
    "@capacitor/preferences": "^6.0.0"
  },
  "optionalDependencies": {
    "@nicolo-ribaudo/llama-cpp-wasm": "^0.1.0"
  },
  "devDependencies": {
    "@capacitor/cli": "^6.0.0",
    "typescript": "^5.3.0",
    "vite": "^5.0.0"
  },
  "engines": {
    "node": ">=18.0.0"
  }
}
