  "promotion": {
    "status": "adapter_contract_ready",
    "requires": [
      "mcp__holoscript.validate_holoscript pass",
      "HoloScript visual projection manifest validation pass",
      "Hololand visual sandwich gate receipt pass",
      "browser or hardware interaction receipt pass before deployment"
    ],
    "blocksOn": [
      "local rewrite of source projection semantics",
