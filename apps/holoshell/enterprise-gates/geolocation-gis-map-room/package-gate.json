        "state",
        "emit"
      ]
    },
    {
      "name": "@holoscript/agent-protocol",
      "gates": [
        "agent_action",
        "handoff_context",
        "interaction_receipt"
      ]
    }
  ],
  "benchmarkGates": [
    {
      "id": "holoscript_visual_projection_geolocation_gis",
      "description": "HoloScript can provide a base visual projection manifest and Hololand can consume it as an enterprise visual room without rewriting source semantics.",
      "mustProve": [
        "holoscript_projection_contract_named",
        "hololand_visual_adapter_declared",
        "source_semantics_not_rewritten",
        "enterprise_interactions_preserved",
        "render_and_interaction_receipts_required"
      ]
    }
  ],
  "requiredReceipts": [
    "source",
    "visual_projection_source",
    "validation",
    "hololand_visual_adapter",
    "runtime",
    "render",
    "interaction",
    "enterprise_receipt"
