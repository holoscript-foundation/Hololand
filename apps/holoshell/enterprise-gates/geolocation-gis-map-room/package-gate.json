    "promotionSurface": "Hololand deployable room",
    "localRewriteAllowed": false
  },
  "runtimeAdapter": {
    "status": "implemented",
    "script": "scripts/hololand-visual-projection-sandwich-gate.mjs",
    "browserReceiptScript": "scripts/hololand-visual-projection-sandwich-browser-receipt.mjs",
    "consumesSourceProjectionManifest": true,
    "adapterReceiptField": "visualRuntimeAdapter",
    "sourceSemanticsRewritten": false,
    "localRewriteAllowed": false
  },
  "holoscriptPackages": [
    {
      "name": "@holoscript/plugin-geolocation-gis",
