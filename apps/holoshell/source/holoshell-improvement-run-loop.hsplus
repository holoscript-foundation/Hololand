// HoloShell Improvement Run Loop
//
// Source contract for queueing repeated Brittney-led codebase-fix shakedowns
// from the desktop HoloShell app. Vision understanding is distinct from Fara:
// vision models read screens/images, while Fara plans guarded desktop automation.
// HoloTune traces are deliberately deferred until actual fixes pass review.

composition "HoloShell Improvement Run Loop" {
  config {
    title: "HoloShell Improvement Run Loop"
    product: "HoloShell"
    sourceLayer: "HoloScript"
    serverModule: "packages/holoshell/serve.mjs"
    queueEndpoint: "POST /api/improvement-runs"
    historyEndpoint: "GET /api/improvement-runs"
    detailEndpoint: "GET /api/improvement-runs/:runId"
    executeEndpoint: "POST /api/improvement-runs/:runId/execute"
    desktopBridgeEndpoint: "GET /api/desktop-control/bridge"
    surfaceSource: "packages/holoshell/scenes/operate-room.holo"
    desktopControlSource: "apps/holoshell/source/holoshell-desktop-control-bridge.hsplus"
    liveStatusSource: "apps/holoshell/source/holoshell-live-status-brief.hsplus"
    modelLibrarySource: ".ai-ecosystem/model-library/library.json"
    holoClawSkillSource: "HoloScript/compositions/skills"
    holotuneTraceSource: "deferred until codebase-fix shakedown validation"
    maxBatchRunCount: 128
    defaultShakedownRunCount: 10
    receiptRequired: true
    destructiveActionsTakenByQueue: false
    destructiveActionsTakenByShakedown: false
    executionMode: "codebase_fix_shakedown"
  }

  state {
    lastRunId: ""
    lastExecutionId: ""
    queuedRunCount: 0
    executedRunCount: 0
    remainingRunCount: 0
    requestedRunCount: 0
    visionModelCount: 0
    desktopAutomationModelCount: 0
    holoClawSkillCount: 0
    lastStatus: "idle"
  }

  channel "holoshell:improvement:queue" {
    type: "append_only"
    priority: "high"
    description: "Receipt-backed improvement batches queued from the HoloShell desktop surface"
  }

  channel "holoshell:improvement:routing" {
    type: "append_only"
    priority: "high"
    description: "Native model and skill routing selected for each improvement batch"
  }

  channel "holoshell:improvement:execution" {
    type: "append_only"
    priority: "high"
    description: "Codebase-fix shakedowns that count only after patch and validation evidence is attached"
  }

  channel "holoshell:improvement:holotune_trace" {
    type: "append_only"
    priority: "medium"
    description: "Deferred per-identity HoloTune trace emission after real codebase fixes pass review"
  }

  channel "holoshell:improvement:desktop_bridge" {
    type: "snapshot"
    priority: "medium"
    description: "Laptop desktop-control bridge readiness, separate from Fara planning"
  }

  template "ImprovementRunReceipt" {
    type: "improvement_run_receipt"
    schemaVersion: "hololand.holoshell.improvement-run.v0.1.0"
    runId: ""
    status: "queued"
    objective: ""
    requestedRunCount: 0
    queuedRunCount: 0
    routing: {}
    loop: []
    receiptRequired: true
    destructiveActionsTaken: false
  }

  template "ImprovementExecutionReceipt" {
    type: "improvement_execution_receipt"
    schemaVersion: "hololand.holoshell.improvement-execution.v0.1.0"
    executionId: ""
    sourceRunId: ""
    status: "completed_codebase_fix_shakedown"
    executionMode: "codebase_fix_shakedown"
    plannedFixCount: 0
    executedRunCount: 0
    remainingRunCount: 0
    fixEvidenceRequired: true
    gpuBalancePlan: {}
    desktopBridge: {}
    runResults: []
    lessons: []
    receiptRequired: true
    destructiveActionsTaken: false
    desktopAutomationExecuted: false
  }

  template "HoloTuneTraceEmission" {
    type: "holotune_trace_emission"
    schemaVersion: "hololand.holoshell.holotune-trace-emission.v0.1.0"
    status: "deferred"
    reason: "actual_codebase_fixes_before_tuning"
    agentId: "agent_brittney"
    emittedRows: 0
    traceFiles: []
    errors: []
  }

  policy "VisionIsNotFara" {
    appliesTo: ["screen_understanding", "image_understanding", "desktop_automation"]
    visionUnderstandingLane: "vision_language"
    desktopAutomationLane: "fara_gui_grounding"
    visionModelsReadOnly: true
    faraPlansDesktopActions: true
    faraRequiresApprovalBeforeMutation: true
    receiptRequired: true
  }

  policy "DesktopBridgeIsNotDesktopMutation" {
    appliesTo: ["desktop_bridge_status", "desktop_automation"]
    bridgeReportsReadOnly: true
    faraPlansDesktopActions: true
    laptopBridgeExecutesOnlyAfterConsent: true
    desktopAutomationExecutedByShakedown: false
    receiptRequired: true
  }

  policy "NativeRoutingBeforeFallback" {
    appliesTo: ["improvement_batch", "model_routing", "skill_routing"]
    preferModelLibrary: true
    preferHoloClawSkills: true
    requiredLanes: ["brittney_operator", "vision_language", "fara_gui_grounding", "holo_sdf_geometry", "semantic_embeddings", "holoclaw_skills", "codebase_fix", "receipt_gate"]
    receiptRequired: true
  }

  policy "ExponentialImprovementLoop" {
    appliesTo: ["improvement_batch"]
    loopSteps: ["capture_live_state", "select_codebase_fix_candidate", "plan_patch", "apply_codebase_fix", "run_targeted_validation", "record_fix_receipt", "defer_holotune_until_fix_corpus_review", "feed_lesson_to_brittney"]
    requireMeasurementEveryRun: true
    requireReceiptEveryRun: true
    requireCodebaseFixEvidenceEveryCountedRun: true
    requireHoloTuneTraceRowEveryRun: false
    holotuneTraceMode: "deferred_until_codebase_fix_review"
    destructiveActionsTakenByQueue: false
    shakedownRunCount: 10
    requireGpuBalanceSnapshot: true
    requireDesktopBridgeStatus: true
  }

  action queue_improvement_run(receipt) {
    state.lastRunId = receipt.runId
    state.queuedRunCount = receipt.queuedRunCount
    state.requestedRunCount = receipt.requestedRunCount
    state.visionModelCount = receipt.routing.visionUnderstanding.models.length
    state.desktopAutomationModelCount = receipt.routing.desktopAutomation.models.length
    state.holoClawSkillCount = receipt.routing.holoClawSkills.count
    state.lastStatus = receipt.status
    emit("holoshell:improvement:queue", {
      action: "improvement_run_queued",
      run_id: state.lastRunId,
      status: state.lastStatus,
      requested_run_count: state.requestedRunCount,
      queued_run_count: state.queuedRunCount,
      receipt_required: true,
      destructive_actions_taken: false
    })
  }

  action route_improvement_run(receipt) {
    emit("holoshell:improvement:routing", {
      action: "improvement_run_routed",
      run_id: receipt.runId,
      operator_model: receipt.routing.operator.model,
      vision_models: receipt.routing.visionUnderstanding.models,
      desktop_automation_models: receipt.routing.desktopAutomation.models,
      geometry_model: receipt.routing.geometry.model,
      embeddings_model: receipt.routing.embeddings.model,
      holoclaw_skill_count: receipt.routing.holoClawSkills.count,
      fara_role: "desktop_automation",
      vision_role: "screen_image_understanding",
      receipt_required: true
    })
  }

  action execute_codebase_fix_shakedown(receipt) {
    state.lastExecutionId = receipt.executionId
    state.executedRunCount = receipt.totalExecutedRunCount
    state.remainingRunCount = receipt.remainingRunCount
    state.lastStatus = receipt.status
    emit("holoshell:improvement:execution", {
      action: "codebase_fix_shakedown_evidence_recorded",
      run_id: receipt.sourceRunId,
      execution_id: state.lastExecutionId,
      executed_run_count: receipt.executedRunCount,
      total_executed_run_count: receipt.totalExecutedRunCount,
      remaining_run_count: receipt.remainingRunCount,
      fix_evidence_required: true,
      planned_fix_count: receipt.plannedFixCount,
      destructive_actions_taken: false,
      desktop_automation_executed: false,
      receipt_required: true
    })
  }

  action emit_holotune_trace(receipt) {
    emit("holoshell:improvement:holotune_trace", {
      action: "holotune_trace_deferred",
      run_id: receipt.sourceRunId,
      execution_id: receipt.executionId,
      agent_id: receipt.holotuneTrace.agentId,
      emitted_rows: receipt.holotuneTrace.emittedRows,
      status: receipt.holotuneTrace.status,
      reason: receipt.holotuneTrace.reason,
      receipt_required: true,
      destructive_actions_taken: false
    })
  }

  action report_desktop_bridge_status(receipt) {
    emit("holoshell:improvement:desktop_bridge", {
      action: "desktop_bridge_status_reported",
      status: receipt.desktopBridge.status,
      bridge_url: receipt.desktopBridge.url,
      approval_required_for_desktop_automation: true,
      destructive_actions_taken: false
    })
  }
}
