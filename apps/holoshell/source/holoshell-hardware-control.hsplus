// HoloShell Hardware Program Control
//
// Canonical HoloScript contract for turning the local computer into an
// intent-addressable HoloShell surface. Host scripts may enumerate windows,
// focus programs, launch paths, send hotkeys, or click controls only through
// the permission envelopes and receipts defined here.

composition "HoloShell Hardware Program Control" {
  config {
    title: "HoloShell Hardware Program Control"
    product: "HoloShell"
    sourceLayer: "HoloScript"
    operatingModel: "hardware_native_shell"
    programRegistryScript: "scripts/holoshell-program-registry.mjs"
    executorScript: "scripts/holoshell-action-executor.mjs"
    approvalBundleScript: "scripts/holoshell-approval-bundle.mjs"
    workflowApprovalBundleScript: "scripts/holoshell-workflow-approval-bundle.mjs"
    brainIntentGateScript: "scripts/holoshell-brain-intent-gate.mjs"
    controlDaemonScript: "scripts/holoshell-control-daemon.mjs"
    roomMarathonWorkflowScript: "scripts/holoshell-room-marathon-workflow.mjs"
    claudeChatWorkflowScript: "scripts/holoshell-claude-chat-workflow.mjs"
    ollamaCloudAgentWorkflowScript: "scripts/holoshell-ollama-cloud-agent-workflow.mjs"
    grokBuildWorkflowScript: "scripts/holoshell-grok-build-workflow.mjs"
    grokHeartbeatScript: "scripts/holoshell-grok-heartbeat.mjs"
    agentDispatchScript: "scripts/holoshell-agent-dispatch.mjs"
    founderCommandScript: "scripts/holoshell-founder-command.mjs"
    controlDaemonUrl: "http://127.0.0.1:4747"
    osUiCaptureSource: "apps/holoshell/source/holoshell-os-ui-capture.hsplus"
    grokBuildWorkflowSource: "apps/holoshell/source/holoshell-grok-build-workflow.hsplus"
    grokHeartbeatSource: "apps/holoshell/source/holoshell-grok-heartbeat.hsplus"
    trustedAutonomySource: "apps/holoshell/source/holoshell-trusted-autonomy.hsplus"
    founderCommandPipelineSource: "apps/holoshell/source/holoshell-founder-command-pipeline.hs"
    founderIntentPolicySource: "apps/holoshell/source/holoshell-founder-intent-policy.hsplus"
    trustedAutonomyLedgerScript: "scripts/holoshell-trust-ledger.mjs"
    homeSource: "apps/holoshell/source/holoshell-home.hsplus"
    brittneyRuntimeBridgeSource: "apps/holoshell/source/holoshell-brittney-runtime-bridge.hsplus"
    latestActionReceipt: ".tmp/holoshell/action-latest.json"
    latestActionWriteMode: "locked_atomic_same_directory_rename"
    latestProgramRegistry: ".tmp/holoshell/program-registry.json"
    latestApprovalBundle: ".tmp/holoshell/approval-latest.json"
    latestApprovalWriteMode: "locked_atomic_same_directory_rename"
    latestWorkflowReceipt: ".tmp/holoshell/workflow-latest.json"
    latestWorkflowApprovalBundle: ".tmp/holoshell/workflow-approval-latest.json"
    latestWorkflowIntentGate: ".tmp/holoshell/brain-intent-gate-latest.json"
    latestAgentDispatchReceipt: ".tmp/holoshell/agent-dispatch-latest.json"
    latestGrokBuildSetup: ".tmp/holoshell/grok-build-setup.json"
    latestGrokHeartbeat: ".tmp/holoshell/grok-heartbeat.json"
    latestTrustLedger: ".tmp/holoshell/trust-ledger.json"
    latestFounderCommandReceipt: ".tmp/holoshell/founder-command-latest.json"
    actionReceiptDir: ".tmp/holoshell/action-receipts"
    approvalBundleDir: ".tmp/holoshell/approval-bundles"
    workflowApprovalBundleDir: ".tmp/holoshell/workflow-approval-bundles"
    agentDispatchReceiptDir: ".tmp/holoshell/agent-dispatches"
    browserBootstrap: ".tmp/holoshell/action-latest.js"
    programRegistryBootstrap: ".tmp/holoshell/program-registry.js"
    approvalBundleBootstrap: ".tmp/holoshell/approval-latest.js"
    workflowApprovalBundleBootstrap: ".tmp/holoshell/workflow-approval-latest.js"
    agentDispatchBootstrap: ".tmp/holoshell/agent-dispatch-latest.js"
    grokBuildSetupBootstrap: ".tmp/holoshell/grok-build-setup.js"
    trustLedgerBootstrap: ".tmp/holoshell/trust-ledger.js"
  }

  state {
    hardwareControlStatus: "unknown"
    platform: "unknown"
    installedProgramCount: 0
    launchableProgramCount: 0
    startMenuProgramCount: 0
    appPathProgramCount: 0
    programWindowCount: 0
    programControlCount: 0
    programRegistryHash: ""
    lastActionId: ""
    lastActionKind: ""
    lastActionStatus: "unknown"
    lastPermissionEnvelope: "unknown"
    lastTargetProgramName: ""
    lastTargetWindowId: ""
    lastTargetWindowTitle: ""
    lastTargetProcessName: ""
    actionReceiptCount: 0
    readOnlyActionCount: 0
    guardedActionCount: 0
    breakGlassBlockedCount: 0
    pendingHardwareApprovalCount: 0
    latestApprovalId: ""
    latestApprovalStatus: "unknown"
    latestApprovalTarget: ""
    latestApprovalExpiresAt: ""
    latestBrowserBoundaryStatus: "none"
    latestBrowserProfileBoundary: ""
    latestBrowserCookiePolicy: ""
    latestBrowserScreenshotPolicy: ""
    controlDaemonStatus: "offline"
    controlDaemonExecuteEnabled: false
    latestAgentDispatchId: ""
    latestAgentDispatchStatus: "unknown"
    latestAgentDispatchCapabilityId: ""
    latestAgentDispatchCapabilityLabel: ""
    latestAgentDispatchKind: ""
    latestAgentDispatchRoute: ""
    latestAgentDispatchConfidence: 0
    latestAgentDispatchApprovalRequired: false
    grokBuildSetupStatus: "unknown"
    grokBuildCliStatus: "unknown"
    grokBuildCliVersion: "unknown"
    grokBuildAuthStatus: "unknown"
    grokBuildAuthRuntimeStatus: "unknown"
    grokBuildAuthProvider: ""
    grokBuildOperatorStatus: "unknown"
    grokBuildAutonomyStatus: "unknown"
    grokBuildModelStatus: "unknown"
    grokBuildProjectTrusted: false
    grokBuildProjectTrustStatus: "unknown"
    grokBuildWarningCount: 0
    grokBuildHeavyAccessStatus: "unknown"
    grokBuildReadyForHeavyRecheck: false
    grokBuildReadyForGrokBuild: false
    grokBuildObservationStatus: "none"
    grokBuildPrimaryFinding: ""
    trustLedgerStatus: "unknown"
    trustLedgerRecordCount: 0
    trustLedgerReadOnlyCount: 0
    trustLedgerGuardedCount: 0
    trustLedgerTrustedCount: 0
    trustLedgerBreakGlassCount: 0
    trustedAutonomyLatestLevel: "unknown"
    trustedAutonomyLatestActionKind: ""
    trustedAutonomyLatestTarget: ""
    trustedAutonomyEligible: false
    trustedAutonomySuccessesUntilTrusted: 3
    activeWorkflowId: ""
    activeWorkflowKind: ""
    activeWorkflowStatus: "unknown"
    activeWorkflowTitle: ""
    activeWorkflowTargetSurface: ""
    activeWorkflowAgent: ""
    activeWorkflowPendingApprovalCount: 0
    activeWorkflowStepCount: 0
    activeWorkflowModelRoute: ""
    activeWorkflowMutationExecuted: false
    activeWorkflowApprovalId: ""
    activeWorkflowApprovalStatus: "unknown"
    activeWorkflowApprovalExpiresAt: ""
    activeWorkflowApprovalExecutionAllowed: false
    activeWorkflowIntentGateStatus: "unknown"
    activeWorkflowIntentGateExecutionAllowed: false
    activeWorkflowIntentGateRuntimeBlocking: false
    activeWorkflowIntentGateCaseId: ""
    activeWorkflowIntentGateFailedCheckCount: 0
    founderCommandIntent: "Brittney, open Claude, start a room marathon using Ollama Kimi Cloud, open a browser, and play lofi music on YouTube"
    founderCommandPipelineShape: "intent_plan_approval_trust_launcher_receipt"
    founderCommandConfidence: 0
    founderCommandTrustLevel: "guarded"
    founderCommandExecutionDefault: "staged_not_run"
    founderCommandReceiptStatus: "unknown"
    founderCommandApprovalCount: 0
    founderCommandExecutionAllowed: false
    founderCommandMutationExecuted: false
    mutatingActionExecuted: false
    approvalRequired: false
    approvedByUser: false
  }

  channel "holoshell:hardware:registry" {
    type: "pub_sub"
    priority: "critical"
    description: "Installed and running programs represented as HoloShell program objects"
  }

  channel "holoshell:hardware:program-registry" {
    type: "pub_sub"
    priority: "critical"
    description: "Launchable installed programs, Start Menu shortcuts, App Paths, and running-window correlation"
  }

  channel "holoshell:hardware:action-request" {
    type: "request_response"
    priority: "critical"
    description: "Program and hardware action requests from Brittney, shell objects, or user gestures"
  }

  channel "holoshell:hardware:approval" {
    type: "request_response"
    priority: "critical"
    description: "Human approval lane for mutating local hardware actions"
  }

  channel "holoshell:hardware:control-daemon" {
    type: "request_response"
    priority: "critical"
    description: "Loopback-only bridge between browser shell and local hardware executor"
  }

  channel "holoshell:workflow:room-marathon" {
    type: "request_response"
    priority: "critical"
    description: "Compound Brittney workflow for Claude, terminal, room marathon, Kimi route, browser, and YouTube lofi"
  }

  channel "holoshell:workflow:claude-chat" {
    type: "request_response"
    priority: "critical"
    description: "Guarded Brittney workflow for opening Claude, starting a chat, and staging a prompt without shell context by default"
  }

  channel "holoshell:workflow:ollama-cloud-agent" {
    type: "request_response"
    priority: "critical"
    description: "Guarded Brittney workflow for launching Ollama Cloud agent runtimes from HoloShell"
  }

  channel "holoshell:workflow:grok-build" {
    type: "request_response"
    priority: "critical"
    description: "Guarded Brittney workflow for launching Grok Build as a local coding-agent lane"
  }

  channel "holoshell:trust:ledger" {
    type: "pub_sub"
    priority: "critical"
    description: "Receipt-derived autonomy ladder for local hardware and program control"
  }

  channel "holoshell:workflow:agent-dispatch" {
    type: "request_response"
    priority: "critical"
    description: "Brittney intent router from natural language to guarded HoloShell workflows and hardware actions"
  }

  channel "holoshell:workflow:approval" {
    type: "request_response"
    priority: "critical"
    description: "Human approval lane for nonce-bound compound Brittney workflows"
  }

  channel "holoshell:workflow:intent-gate" {
    type: "request_response"
    priority: "critical"
    description: "Runtime-blocking HoloScript brain intent gate for compound Brittney workflows"
  }

  channel "holoshell:founder:command-pipeline" {
    type: "append_only"
    priority: "critical"
    description: "Founder demo pipeline from natural command to launcher and receipt"
  }

  channel "holoshell:hardware:receipt" {
    type: "append_only"
    priority: "critical"
    description: "Before/after receipts for every read or mutating hardware action"
  }

  template "ProgramWindowObject" {
    type: "program_window_object"
    objectKind: "program"
    title: ""
    processName: ""
    processId: 0
    handle: ""
    bounds: { left: 0, top: 0, width: 0, height: 0 }
    controlCount: 0
    shellObjectId: ""
    intentAddressable: true
    receiptRequired: true
  }

  template "InstalledProgramObject" {
    type: "installed_program_object"
    objectKind: "program"
    displayName: ""
    capabilityClass: "application"
    source: "start_menu_or_app_paths"
    launchable: true
    runningWindowId: ""
    permissionEnvelope: "guarded_execute"
    approvalRequiredForLaunch: true
    receiptRequired: true
  }

  template "HardwareActionRequest" {
    type: "hardware_action_request"
    actor: "user_or_brittney"
    actionKind: "list_windows"
    targetWindowId: ""
    targetWindowTitle: ""
    targetProcessName: ""
    targetProgramName: ""
    targetControlId: ""
    permissionEnvelope: "read_only"
    approved: false
    executeRequested: false
    secretsIncluded: false
    receiptRequired: true
  }

  template "PermissionEnvelope" {
    type: "permission_envelope"
    envelope: "read_only"
    approvalRequired: false
    breakGlass: false
    mutating: false
    receiptRequired: true
  }

  template "BeforeAfterWitness" {
    type: "hardware_witness"
    beforeCaptureHash: ""
    afterCaptureHash: ""
    targetWindowId: ""
    targetControlId: ""
    screenshotHash: ""
    secretsCaptured: false
  }

  template "BrowserBoundaryReceipt" {
    type: "browser_boundary"
    receiptType: "hololand.holoshell.browser-boundary.v0.1.0"
    browser: "system_default_browser"
    profileBoundary: "not_declared"
    sessionBoundary: "credential_bearing_requires_explicit_profile"
    urlClassification: "unknown_web"
    cookiePolicy: "requires_explicit_cookie_policy"
    screenshotPolicy: "local_only_redacted_or_manual_witness"
    formSubmitPolicy: "break_glass"
    downloadUploadPolicy: "break_glass"
    screenshotLocality: "local_receipt_only"
    receiptRequired: true
  }

  template "HardwareActionReceipt" {
    type: "receipt"
    receiptType: "hololand.holoshell.hardware-action.v0.1.0"
    actionId: ""
    actionKind: ""
    actor: "holoshell"
    permissionEnvelope: "read_only"
    status: "unknown"
    approvalRequired: false
    approved: false
    executed: false
    mutatingActionExecuted: false
    latestWriteMode: "locked_atomic_same_directory_rename"
    browserBoundaryReceipt: "optional_for_browser_actions"
    rollback: "not_applicable_for_read_only"
  }

  template "HardwareApprovalBundle" {
    type: "hardware_approval_bundle"
    receiptType: "hololand.holoshell.hardware-approval.v0.1.0"
    approvalId: ""
    sourceActionId: ""
    status: "pending_user_approval"
    actionKind: ""
    target: ""
    permissionEnvelope: "guarded_execute"
    expiresAt: ""
    requiresFreshUserGesture: true
    nonceBound: true
    executionAllowed: false
    latestWriteMode: "locked_atomic_same_directory_rename"
    browserBoundaryRequired: false
    receiptRequired: true
  }

  template "HardwareControlDaemon" {
    type: "hardware_control_daemon"
    receiptType: "hololand.holoshell.control-daemon.v0.1.0"
    url: "http://127.0.0.1:4747"
    loopbackOnly: true
    executeEnabled: false
    routes: ["GET /health", "GET /feed", "GET /dispatch/latest", "GET /trust/ledger", "GET /workflow/grok-build/setup", "GET /agents/grok-heartbeat", "GET /workflow/founder-command/latest", "POST /action", "POST /approval/execute", "POST /workflow/agent-dispatch", "POST /workflow/room-marathon", "POST /workflow/claude-chat", "POST /workflow/ollama-cloud-agent", "POST /workflow/grok-build", "POST /workflow/founder-command", "POST /workflow/approval", "POST /workflow/intent-gate", "POST /workflow/execute"]
    defaultExecutionPolicy: "stage_only"
    receiptRequired: true
  }

  template "RoomMarathonWorkflow" {
    type: "room_marathon_workflow"
    receiptType: "hololand.holoshell.workflow.v0.1.0"
    title: "Room Marathon with Lofi"
    modelRoute: "ollama_cloud"
    model: "kimi-cloud"
    steps: ["resolve_claude_cli", "open_terminal", "stage_room_command", "submit_room_command", "open_browser", "play_lofi_youtube"]
    defaultExecutionPolicy: "stage_only"
    approvalRequired: true
    mutationExecuted: false
    receiptRequired: true
  }

  template "ClaudeChatWorkflow" {
    type: "claude_chat_workflow"
    receiptType: "hololand.holoshell.workflow.v0.1.0"
    title: "Claude Chat"
    targetSurface: "Claude"
    steps: ["resolve_claude_surface", "open_claude", "start_new_chat", "stage_chat_prompt"]
    defaultExecutionPolicy: "staged_until_user_approval"
    shellContextAttachedByDefault: false
    submitRequiresApproval: true
    approvalRequired: true
    mutationExecuted: false
    receiptRequired: true
  }

  template "OllamaCloudAgentWorkflow" {
    type: "ollama_cloud_agent_workflow"
    receiptType: "hololand.holoshell.workflow.v0.1.0"
    title: "Ollama Cloud Agent"
    commandPrefix: "ollama launch"
    supportedAgents: ["claude", "openclaw", "hermes", "opencode", "codex", "copilot", "droid", "pi"]
    steps: ["resolve_ollama_cloud_cli", "resolve_agent_target", "launch_ollama_cloud_agent"]
    defaultExecutionPolicy: "staged_until_user_approval"
    shellContextAttachedByDefault: false
    terminalLaunchRequiresApproval: true
    approvalRequired: true
    mutationExecuted: false
    receiptRequired: true
  }

  template "GrokBuildWorkflow" {
    type: "grok_build_workflow"
    receiptType: "hololand.holoshell.workflow.v0.1.0"
    title: "Grok Build"
    model: "grok-build"
    mode: "interactive"
    steps: ["resolve_grok_build_cli", "verify_grok_auth", "verify_grok_build_model", "inspect_project_trust", "launch_grok_build"]
    defaultExecutionPolicy: "staged_until_user_approval"
    shellContextAttachedByDefault: false
    terminalLaunchRequiresApproval: true
    promptBodyStoredLocallyOnly: true
    projectHooksTrustedRequiredForHookReliance: true
    grokObservationReturnedToShell: false
    approvalRequired: true
    mutationExecuted: false
    receiptRequired: true
  }

  template "GrokObservation" {
    type: "grok_observation"
    receiptType: "hololand.holoshell.grok-observation.v0.1.0"
    agentLane: "grok-build"
    peerInvocation: true
    shellContextAttached: false
    returnedToBrittney: true
    receiptRequired: true
  }

  template "TrustedAutonomyLedger" {
    type: "trust_ledger_receipt"
    receiptType: "hololand.holoshell.trust-ledger.v0.1.0"
    levels: ["read_only", "guarded", "trusted", "break_glass"]
    promotionThreshold: 3
    trustedAutonomyRequiresDaemonFlag: true
    breakGlassPromotesNever: true
    receiptRequired: true
  }

  template "AgentDispatchWorkflow" {
    type: "agent_dispatch_workflow"
    receiptType: "hololand.holoshell.agent-dispatch.v0.1.0"
    title: "Agent Dispatch"
    route: "POST /workflow/agent-dispatch"
    supportedCapabilities: ["claude_chat", "ollama_cloud_agent", "grok_build", "room_marathon", "browser_lofi", "open_excel", "open_terminal", "open_browser", "launch_program"]
    steps: ["parse_intent", "rank_capabilities", "select_guarded_route", "handoff_to_existing_adapter"]
    defaultExecutionPolicy: "dispatch_only"
    directExecutionAllowed: false
    downstreamAdapterOwnsApproval: true
    approvalRequired: false
    mutationExecuted: false
    receiptRequired: true
  }

  template "WorkflowApprovalBundle" {
    type: "workflow_approval_bundle"
    receiptType: "hololand.holoshell.workflow-approval.v0.1.0"
    approvalId: ""
    sourceWorkflowId: ""
    status: "pending_user_approval"
    workflowTitle: "Room Marathon with Lofi"
    pendingApprovalCount: 0
    expiresAt: ""
    requiresFreshUserGesture: true
    nonceBound: true
    executionAllowed: false
    receiptRequired: true
  }

  template "WorkflowBrainIntentGate" {
    type: "workflow_brain_intent_gate"
    receiptType: "hololand.holoshell.brain-intent-gate.v0.1.0"
    status: "unknown"
    caseId: "holoshell-room-marathon-lofi.v0"
    runtimeBlocking: true
    executionAllowed: false
    failedCheckCount: 0
    sourceReceiptType: "holoscript.brain-intent-loop.eval.v0.1.0"
    receiptRequired: true
  }

  template "FounderCommandReceipt" {
    type: "founder_command_receipt"
    receiptType: "hololand.holoshell.founder-command.v0.1.0"
    commandId: ""
    intent: "Brittney, open Claude, start a room marathon using Ollama Kimi Cloud, open a browser, and play lofi music on YouTube"
    pipeline: ["intent", "plan", "approval", "trust_gate", "launcher", "receipt"]
    targetSurfaces: ["Claude", "Windows Terminal", "Ollama Kimi Cloud", "browser", "YouTube lofi"]
    confidence: 0.86
    trustLevel: "guarded"
    executionDefault: "staged_not_run"
    executionAllowed: false
    mutationExecuted: false
    approvalRequired: true
    receiptRequired: true
  }

  policy "ReadOnlyHardwareControl" {
    appliesTo: ["list_windows", "list_programs", "read_window", "read_controls", "resolve_target", "dry_run_action"]
    permissionEnvelope: "read_only"
    approvalRequired: false
    mutating: false
    receiptRequired: true
  }

  policy "GuardedHardwareControl" {
    appliesTo: ["focus_window", "launch_app", "open_url", "open_path", "hotkey", "click_control", "type_text", "invoke_control"]
    permissionEnvelope: "guarded_execute"
    approvalRequired: true
    mutating: true
    receiptRequired: true
  }

  policy "BreakGlassHardwareControl" {
    appliesTo: ["enter_secret", "send_message", "delete_file", "publish", "pay", "install", "uninstall", "system_settings"]
    permissionEnvelope: "break_glass"
    approvalRequired: true
    mutating: true
    defaultStatus: "blocked"
    receiptRequired: true
  }

  action record_program_registry(registry) {
    state.hardwareControlStatus = registry.summary.status
    state.platform = registry.host.platform
    state.installedProgramCount = registry.summary.programCount || state.installedProgramCount
    state.launchableProgramCount = registry.summary.launchableProgramCount || state.launchableProgramCount
    state.startMenuProgramCount = registry.summary.startMenuProgramCount || state.startMenuProgramCount
    state.appPathProgramCount = registry.summary.appPathProgramCount || state.appPathProgramCount
    state.programWindowCount = registry.summary.runningWindowCount || registry.summary.windowCount || state.programWindowCount
    state.programControlCount = registry.summary.controlCount || state.programControlCount
    state.programRegistryHash = registry.receipt.registryHash
    emit("holoshell:hardware:registry", {
      action: "program_registry_recorded",
      status: state.hardwareControlStatus,
      platform: state.platform,
      installed_programs: state.installedProgramCount,
      launchable_programs: state.launchableProgramCount,
      start_menu_programs: state.startMenuProgramCount,
      app_path_programs: state.appPathProgramCount,
      windows: state.programWindowCount,
      controls: state.programControlCount,
      registry_hash: state.programRegistryHash,
      source: "scripts/holoshell-program-registry.mjs",
      receipt_required: true
    })
    emit("holoshell:hardware:program-registry", {
      action: "launchable_programs_recorded",
      programs: state.installedProgramCount,
      launchable: state.launchableProgramCount,
      permission_envelope: "guarded_execute_for_launch",
      source: "scripts/holoshell-program-registry.mjs",
      receipt_required: true
    })
  }

  action request_hardware_action(request) {
    state.lastActionKind = request.actionKind
    state.lastTargetWindowId = request.targetWindowId
    state.lastPermissionEnvelope = request.permissionEnvelope
    state.approvalRequired = request.permissionEnvelope != "read_only"
    state.approvedByUser = request.approved
    emit("holoshell:hardware:action-request", {
      action: "hardware_action_requested",
      request: request,
      permission_envelope: state.lastPermissionEnvelope,
      approval_required: state.approvalRequired,
      execute_requested: request.executeRequested,
      receipt_required: true
    })
    if (state.approvalRequired && !state.approvedByUser) {
      emit("holoshell:hardware:approval", {
        action: "hardware_action_approval_required",
        request: request,
        reason: "mutates local machine state",
        receipt_required: true
      })
    }
  }

  action apply_hardware_action_receipt(receipt) {
    state.lastActionId = receipt.actionId
    state.lastActionKind = receipt.request.actionKind
    state.lastActionStatus = receipt.summary.status
    state.lastPermissionEnvelope = receipt.permission.envelope
    state.lastTargetProgramName = receipt.summary.targetAppName
    state.lastTargetWindowId = receipt.target.windowId
    state.lastTargetWindowTitle = receipt.target.title
    state.lastTargetProcessName = receipt.target.processName
    state.programWindowCount = receipt.summary.windowCount
    state.programControlCount = receipt.summary.controlCount
    state.actionReceiptCount = state.actionReceiptCount + 1
    state.readOnlyActionCount = receipt.permission.envelope == "read_only" ? state.readOnlyActionCount + 1 : state.readOnlyActionCount
    state.guardedActionCount = receipt.permission.envelope == "guarded_execute" ? state.guardedActionCount + 1 : state.guardedActionCount
    state.breakGlassBlockedCount = receipt.permission.envelope == "break_glass" ? state.breakGlassBlockedCount + 1 : state.breakGlassBlockedCount
    state.mutatingActionExecuted = receipt.summary.mutatingActionExecuted
    state.latestBrowserBoundaryStatus = receipt.summary.browserBoundaryStatus || "none"
    state.latestBrowserProfileBoundary = receipt.summary.browserProfileBoundary || ""
    state.latestBrowserCookiePolicy = receipt.browserBoundary.cookiePolicy || ""
    state.latestBrowserScreenshotPolicy = receipt.browserBoundary.screenshotPolicy || ""
    emit("holoshell:hardware:receipt", {
      action: "hardware_action_receipt_applied",
      action_id: state.lastActionId,
      action_kind: state.lastActionKind,
      status: state.lastActionStatus,
      permission_envelope: state.lastPermissionEnvelope,
      target_program: state.lastTargetProgramName,
      target_window: state.lastTargetWindowTitle,
      target_process: state.lastTargetProcessName,
      browser_boundary_status: state.latestBrowserBoundaryStatus,
      browser_profile_boundary: state.latestBrowserProfileBoundary,
      browser_cookie_policy: state.latestBrowserCookiePolicy,
      browser_screenshot_policy: state.latestBrowserScreenshotPolicy,
      windows: state.programWindowCount,
      controls: state.programControlCount,
      mutating_action_executed: state.mutatingActionExecuted,
      receipt_required: true
    })
  }

  action apply_hardware_approval_bundle(bundle) {
    state.latestApprovalId = bundle.approvalId
    state.latestApprovalStatus = bundle.summary.status
    state.latestApprovalTarget = bundle.summary.target
    state.latestApprovalExpiresAt = bundle.summary.expiresAt
    state.latestBrowserBoundaryStatus = bundle.summary.browserBoundaryStatus || "none"
    state.latestBrowserProfileBoundary = bundle.summary.browserProfileBoundary || ""
    state.latestBrowserCookiePolicy = bundle.browserBoundary.cookiePolicy || ""
    state.latestBrowserScreenshotPolicy = bundle.browserBoundary.screenshotPolicy || ""
    state.pendingHardwareApprovalCount = bundle.summary.approvalRequired && bundle.summary.executionAllowed ? 1 : 0
    emit("holoshell:hardware:approval", {
      action: "hardware_approval_bundle_applied",
      approval_id: state.latestApprovalId,
      status: state.latestApprovalStatus,
      target: state.latestApprovalTarget,
      expires_at: state.latestApprovalExpiresAt,
      browser_boundary_status: state.latestBrowserBoundaryStatus,
      browser_profile_boundary: state.latestBrowserProfileBoundary,
      browser_cookie_policy: state.latestBrowserCookiePolicy,
      browser_screenshot_policy: state.latestBrowserScreenshotPolicy,
      pending_approvals: state.pendingHardwareApprovalCount,
      nonce_bound: true,
      execution_allowed: bundle.summary.executionAllowed,
      receipt_required: true
    })
  }

  action apply_control_daemon_health(health) {
    state.controlDaemonStatus = health.status
    state.controlDaemonExecuteEnabled = health.executeEnabled
    emit("holoshell:hardware:control-daemon", {
      action: "control_daemon_health_applied",
      status: state.controlDaemonStatus,
      url: config.controlDaemonUrl,
      loopback_only: true,
      execute_enabled: state.controlDaemonExecuteEnabled,
      default_execution_policy: state.controlDaemonExecuteEnabled ? "approved_execute" : "stage_only",
      receipt_required: true
    })
  }

  action apply_agent_dispatch_receipt(receipt) {
    state.latestAgentDispatchId = receipt.dispatchId
    state.latestAgentDispatchStatus = receipt.summary.status
    state.latestAgentDispatchCapabilityId = receipt.summary.capabilityId
    state.latestAgentDispatchCapabilityLabel = receipt.summary.capabilityLabel
    state.latestAgentDispatchKind = receipt.summary.dispatchKind
    state.latestAgentDispatchRoute = receipt.summary.route
    state.latestAgentDispatchConfidence = receipt.summary.confidence
    state.latestAgentDispatchApprovalRequired = receipt.summary.approvalRequired
    emit("holoshell:workflow:agent-dispatch", {
      action: "agent_dispatch_receipt_applied",
      dispatch_id: state.latestAgentDispatchId,
      status: state.latestAgentDispatchStatus,
      capability_id: state.latestAgentDispatchCapabilityId,
      capability_label: state.latestAgentDispatchCapabilityLabel,
      dispatch_kind: state.latestAgentDispatchKind,
      route: state.latestAgentDispatchRoute,
      confidence: state.latestAgentDispatchConfidence,
      approval_required: state.latestAgentDispatchApprovalRequired,
      downstream_receipt: receipt.dispatch.downstreamReceipt,
      approval_surface: receipt.dispatch.approvalSurface,
      receipt_required: true
    })
  }

  action apply_grok_build_setup(setup) {
    state.grokBuildSetupStatus = setup.summary.status
    state.grokBuildCliStatus = setup.summary.cliStatus
    state.grokBuildCliVersion = setup.summary.cliVersion
    state.grokBuildAuthStatus = setup.summary.authStatus
    state.grokBuildAuthRuntimeStatus = setup.summary.authRuntimeStatus || "unknown"
    state.grokBuildAuthProvider = setup.summary.authProvider || ""
    state.grokBuildOperatorStatus = setup.summary.operatorStatus || "unknown"
    state.grokBuildAutonomyStatus = setup.summary.autonomyStatus || "unknown"
    state.grokBuildModelStatus = setup.summary.modelStatus
    state.grokBuildProjectTrusted = setup.summary.projectTrusted
    state.grokBuildProjectTrustStatus = setup.summary.projectTrustStatus
    state.grokBuildWarningCount = setup.summary.warningCount
    state.grokBuildHeavyAccessStatus = setup.summary.heavyAccessStatus
    state.grokBuildReadyForHeavyRecheck = setup.summary.readyForHeavyRecheck
    state.grokBuildReadyForGrokBuild = setup.summary.readyForGrokBuild
    emit("holoshell:workflow:grok-build", {
      action: "grok_build_setup_applied",
      status: state.grokBuildSetupStatus,
      cli_status: state.grokBuildCliStatus,
      cli_version: state.grokBuildCliVersion,
      auth_status: state.grokBuildAuthStatus,
      auth_runtime_status: state.grokBuildAuthRuntimeStatus,
      auth_provider: state.grokBuildAuthProvider,
      operator_status: state.grokBuildOperatorStatus,
      autonomy_status: state.grokBuildAutonomyStatus,
      model_status: state.grokBuildModelStatus,
      project_trusted: state.grokBuildProjectTrusted,
      project_trust_status: state.grokBuildProjectTrustStatus,
      warning_count: state.grokBuildWarningCount,
      heavy_access_status: state.grokBuildHeavyAccessStatus,
      ready_for_heavy_recheck: state.grokBuildReadyForHeavyRecheck,
      ready_for_grok_build: state.grokBuildReadyForGrokBuild,
      source: "scripts/holoshell-grok-build-workflow.mjs",
      receipt_required: true
    })
  }

  action apply_trust_ledger(ledger) {
    state.trustLedgerStatus = ledger.summary.status
    state.trustLedgerRecordCount = ledger.summary.recordCount
    state.trustLedgerReadOnlyCount = ledger.summary.readOnlyRecordCount
    state.trustLedgerGuardedCount = ledger.summary.guardedRecordCount
    state.trustLedgerTrustedCount = ledger.summary.trustedRecordCount
    state.trustLedgerBreakGlassCount = ledger.summary.breakGlassRecordCount
    state.trustedAutonomyLatestLevel = ledger.summary.latestTrustLevel
    state.trustedAutonomyLatestActionKind = ledger.summary.latestActionKind
    state.trustedAutonomyLatestTarget = ledger.summary.latestTarget
    state.trustedAutonomyEligible = ledger.summary.trustedAutonomyEligible
    state.trustedAutonomySuccessesUntilTrusted = ledger.summary.successesUntilTrusted
    emit("holoshell:trust:ledger", {
      action: "trust_ledger_applied",
      status: state.trustLedgerStatus,
      records: state.trustLedgerRecordCount,
      read_only: state.trustLedgerReadOnlyCount,
      guarded: state.trustLedgerGuardedCount,
      trusted: state.trustLedgerTrustedCount,
      break_glass: state.trustLedgerBreakGlassCount,
      latest_trust_level: state.trustedAutonomyLatestLevel,
      latest_action: state.trustedAutonomyLatestActionKind,
      latest_target: state.trustedAutonomyLatestTarget,
      trusted_autonomy_eligible: state.trustedAutonomyEligible,
      successes_until_trusted: state.trustedAutonomySuccessesUntilTrusted,
      source: "scripts/holoshell-trust-ledger.mjs",
      receipt_required: true
    })
  }

  action apply_room_marathon_workflow(workflow) {
    state.activeWorkflowId = workflow.workflowId
    state.activeWorkflowKind = workflow.summary.workflowKind || "room_marathon"
    state.activeWorkflowStatus = workflow.summary.status
    state.activeWorkflowTitle = workflow.title
    state.activeWorkflowTargetSurface = workflow.summary.targetSurface || "Claude + Terminal + Browser"
    state.activeWorkflowPendingApprovalCount = workflow.summary.pendingApprovalCount
    state.activeWorkflowStepCount = workflow.summary.stepCount
    state.activeWorkflowModelRoute = workflow.summary.modelRoute
    state.activeWorkflowMutationExecuted = workflow.summary.mutationExecuted
    emit("holoshell:workflow:room-marathon", {
      action: "room_marathon_workflow_applied",
      workflow_id: state.activeWorkflowId,
      status: state.activeWorkflowStatus,
      title: state.activeWorkflowTitle,
      steps: state.activeWorkflowStepCount,
      pending_approvals: state.activeWorkflowPendingApprovalCount,
      model_route: state.activeWorkflowModelRoute,
      mutation_executed: state.activeWorkflowMutationExecuted,
      receipt_required: true
    })
  }

  action apply_claude_chat_workflow(workflow) {
    state.activeWorkflowId = workflow.workflowId
    state.activeWorkflowKind = workflow.summary.workflowKind || "claude_chat"
    state.activeWorkflowStatus = workflow.summary.status
    state.activeWorkflowTitle = workflow.title
    state.activeWorkflowTargetSurface = workflow.summary.targetSurface
    state.activeWorkflowPendingApprovalCount = workflow.summary.pendingApprovalCount
    state.activeWorkflowStepCount = workflow.summary.stepCount
    state.activeWorkflowMutationExecuted = workflow.summary.mutationExecuted
    emit("holoshell:workflow:claude-chat", {
      action: "claude_chat_workflow_applied",
      workflow_id: state.activeWorkflowId,
      status: state.activeWorkflowStatus,
      title: state.activeWorkflowTitle,
      target_surface: state.activeWorkflowTargetSurface,
      steps: state.activeWorkflowStepCount,
      pending_approvals: state.activeWorkflowPendingApprovalCount,
      shell_context_attached_by_default: workflow.summary.shellContextAttachedByDefault,
      mutation_executed: state.activeWorkflowMutationExecuted,
      receipt_required: true
    })
  }

  action apply_ollama_cloud_agent_workflow(workflow) {
    state.activeWorkflowId = workflow.workflowId
    state.activeWorkflowKind = workflow.summary.workflowKind || "ollama_cloud_agent"
    state.activeWorkflowStatus = workflow.summary.status
    state.activeWorkflowTitle = workflow.title
    state.activeWorkflowTargetSurface = "Ollama Cloud"
    state.activeWorkflowAgent = workflow.summary.agentSlug
    state.activeWorkflowPendingApprovalCount = workflow.summary.pendingApprovalCount
    state.activeWorkflowStepCount = workflow.summary.stepCount
    state.activeWorkflowMutationExecuted = workflow.summary.mutationExecuted
    emit("holoshell:workflow:ollama-cloud-agent", {
      action: "ollama_cloud_agent_workflow_applied",
      workflow_id: state.activeWorkflowId,
      status: state.activeWorkflowStatus,
      title: state.activeWorkflowTitle,
      target_surface: state.activeWorkflowTargetSurface,
      agent: state.activeWorkflowAgent,
      command: workflow.summary.command,
      steps: state.activeWorkflowStepCount,
      pending_approvals: state.activeWorkflowPendingApprovalCount,
      shell_context_attached_by_default: workflow.summary.shellContextAttachedByDefault,
      mutation_executed: state.activeWorkflowMutationExecuted,
      receipt_required: true
    })
  }

  action apply_grok_build_workflow(workflow) {
    state.activeWorkflowId = workflow.workflowId
    state.activeWorkflowKind = workflow.summary.workflowKind || "grok_build"
    state.activeWorkflowStatus = workflow.summary.status
    state.activeWorkflowTitle = workflow.title
    state.activeWorkflowTargetSurface = "Grok Build"
    state.activeWorkflowAgent = "grok-build"
    state.activeWorkflowPendingApprovalCount = workflow.summary.pendingApprovalCount
    state.activeWorkflowStepCount = workflow.summary.stepCount
    state.activeWorkflowMutationExecuted = workflow.summary.mutationExecuted
    state.grokBuildCliVersion = workflow.summary.cliVersion
    state.grokBuildAuthStatus = workflow.summary.authStatus
    state.grokBuildAuthRuntimeStatus = workflow.summary.authRuntimeStatus || "unknown"
    state.grokBuildAuthProvider = workflow.summary.authProvider || ""
    state.grokBuildOperatorStatus = workflow.summary.operatorStatus || "unknown"
    state.grokBuildAutonomyStatus = workflow.summary.autonomyStatus || "unknown"
    state.grokBuildProjectTrusted = workflow.summary.projectTrusted
    state.grokBuildProjectTrustStatus = workflow.summary.projectTrustStatus
    state.grokBuildObservationStatus = workflow.summary.grokObservationStatus || "none"
    state.grokBuildPrimaryFinding = workflow.summary.grokObservationPrimaryFinding || ""
    emit("holoshell:workflow:grok-build", {
      action: "grok_build_workflow_applied",
      workflow_id: state.activeWorkflowId,
      status: state.activeWorkflowStatus,
      title: state.activeWorkflowTitle,
      target_surface: state.activeWorkflowTargetSurface,
      mode: workflow.summary.mode,
      model: workflow.summary.model,
      cli_version: state.grokBuildCliVersion,
      auth_status: state.grokBuildAuthStatus,
      auth_runtime_status: state.grokBuildAuthRuntimeStatus,
      auth_provider: state.grokBuildAuthProvider,
      operator_status: state.grokBuildOperatorStatus,
      autonomy_status: state.grokBuildAutonomyStatus,
      project_trusted: state.grokBuildProjectTrusted,
      project_trust_status: state.grokBuildProjectTrustStatus,
      prompt_present: workflow.summary.promptPresent,
      permission_mode: workflow.summary.permissionMode,
      steps: state.activeWorkflowStepCount,
      pending_approvals: state.activeWorkflowPendingApprovalCount,
      shell_context_attached_by_default: workflow.summary.shellContextAttachedByDefault,
      mutation_executed: state.activeWorkflowMutationExecuted,
      grok_observation_status: state.grokBuildObservationStatus,
      grok_primary_finding: state.grokBuildPrimaryFinding,
      receipt_required: true
    })
  }

  action apply_workflow_approval_bundle(bundle) {
    state.activeWorkflowApprovalId = bundle.approvalId
    state.activeWorkflowApprovalStatus = bundle.summary.status
    state.activeWorkflowApprovalExpiresAt = bundle.summary.expiresAt
    state.activeWorkflowApprovalExecutionAllowed = bundle.summary.executionAllowed
    emit("holoshell:workflow:approval", {
      action: "workflow_approval_bundle_applied",
      approval_id: state.activeWorkflowApprovalId,
      workflow_id: bundle.summary.workflowId,
      title: bundle.summary.title,
      status: state.activeWorkflowApprovalStatus,
      expires_at: state.activeWorkflowApprovalExpiresAt,
      pending_approvals: bundle.summary.pendingApprovalCount,
      nonce_bound: true,
      execution_allowed: state.activeWorkflowApprovalExecutionAllowed,
      receipt_required: true
    })
  }

  action apply_workflow_intent_gate_receipt(gateReceipt) {
    state.activeWorkflowIntentGateStatus = gateReceipt.summary.status
    state.activeWorkflowIntentGateExecutionAllowed = gateReceipt.summary.executionAllowed
    state.activeWorkflowIntentGateRuntimeBlocking = gateReceipt.summary.runtimeBlocking
    state.activeWorkflowIntentGateCaseId = gateReceipt.summary.caseId
    state.activeWorkflowIntentGateFailedCheckCount = gateReceipt.summary.failedCheckCount
    emit("holoshell:workflow:intent-gate", {
      action: "workflow_intent_gate_receipt_applied",
      status: state.activeWorkflowIntentGateStatus,
      case_id: state.activeWorkflowIntentGateCaseId,
      runtime_blocking: state.activeWorkflowIntentGateRuntimeBlocking,
      execution_allowed: state.activeWorkflowIntentGateExecutionAllowed,
      failed_checks: state.activeWorkflowIntentGateFailedCheckCount,
      source_receipt: gateReceipt.output.sourceReceiptPath,
      receipt_required: true
    })
  }

  action apply_founder_command_receipt(receipt) {
    state.founderCommandConfidence = receipt.summary.confidence
    state.founderCommandTrustLevel = receipt.summary.trustLevel || state.founderCommandTrustLevel
    state.founderCommandReceiptStatus = receipt.summary.status
    state.founderCommandApprovalCount = receipt.summary.approvalCount
    state.founderCommandExecutionAllowed = receipt.summary.executionAllowed
    state.founderCommandMutationExecuted = receipt.summary.mutationExecuted
    emit("holoshell:founder:command-pipeline", {
      action: "founder_command_receipt_applied",
      command_id: receipt.commandId,
      status: state.founderCommandReceiptStatus,
      trust_level: state.founderCommandTrustLevel,
      confidence: state.founderCommandConfidence,
      pipeline_shape: state.founderCommandPipelineShape,
      approvals: state.founderCommandApprovalCount,
      execution_allowed: state.founderCommandExecutionAllowed,
      mutation_executed: state.founderCommandMutationExecuted,
      execution_default: state.founderCommandExecutionDefault,
      receipt_required: true
    })
  }

  action route_brittney_program_control(proposal) {
    emit("holoshell:hardware:action-request", {
      action: "brittney_program_control_routed",
      proposal: proposal,
      routes_to: "scripts/holoshell-action-executor.mjs",
      permission_envelope: proposal.permissionEnvelope || "read_only",
      approval_required: proposal.permissionEnvelope != "read_only",
      receipt_required: true
    })
  }
}
