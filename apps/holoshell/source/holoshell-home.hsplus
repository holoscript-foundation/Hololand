      installed_programs: state.installedProgramCount,
      launchable_programs: state.launchableProgramCount,
      start_menu_programs: state.startMenuProgramCount,
      app_path_programs: state.appPathProgramCount,
      source_contract: "apps/holoshell/source/holoshell-hardware-control.hsplus",
      receipt_required: true
    })
  }

  action apply_shell_object_graph(graph) {
    state.shellObjectGraphStatus = graph.summary.status
    state.shellObjectCount = graph.summary.shellObjectCount
    state.firstScreenObjectCount = graph.summary.firstScreenObjectCount
    state.appShellObjectCount = graph.summary.programObjectCount
    state.browserShellObjectCount = graph.summary.browserSurfaceCount
    state.terminalShellObjectCount = graph.summary.terminalSurfaceCount
    state.documentAppShellObjectCount = graph.summary.documentAppCount
    state.agentShellObjectCount = graph.summary.agentObjectCount
    state.workflowShellObjectCount = graph.summary.workflowObjectCount
    state.approvalShellObjectCount = graph.summary.approvalObjectCount
    state.receiptShellObjectCount = graph.summary.receiptObjectCount
    state.capturedShellObjectCount = graph.summary.capturedWindowObjectCount
    state.runningShellObjectCount = graph.summary.runningObjectCount
    state.guardedShellObjectCount = graph.summary.guardedExecuteCount
    state.firstProgramShellObject = graph.summary.firstProgramObject
