// HoloShell Home
//
// Canonical HoloScript source for the HoloLand non-developer hardware surface.
// TypeScript, Tauri, Windows UI Automation, browser automation, and MCP bridges
// are host adapters. The product behavior starts here.

composition "HoloShell Home" {
  config {
    title: "HoloShell"
    owner: "HoloLand"
    audience: "non_developer"
    renderMode: "desktop_spatial"
    sourceLayer: "HoloScript"
    operationModel: "intent_capability_receipt"
    shellModel: "holo_os_replacement"
    visualWorldSource: "apps/holoshell/source/holoshell-shell-world.holo"
    renderSliceSource: "apps/holoshell/source/holoshell-shell-render.hs"
    founderCommandPipelineSource: "apps/holoshell/source/holoshell-founder-command-pipeline.hs"
    founderIntentPolicySource: "apps/holoshell/source/holoshell-founder-intent-policy.hsplus"
    brittneyAvatarSource: "apps/holoshell/source/holoshell-brittney-avatar.hsplus"
    brittneyRuntimeBridgeSource: "apps/holoshell/source/holoshell-brittney-runtime-bridge.hsplus"
    hardwareControlSource: "apps/holoshell/source/holoshell-hardware-control.hsplus"
    hardwareControlDaemon: "http://127.0.0.1:4747"
    brittneyAvatarManifest: ".tmp/holoshell/brittney-avatar.json"
    brittneyTurnReceipt: ".tmp/holoshell/brittney-turn-latest.json"
    programRegistry: ".tmp/holoshell/program-registry.json"
    shellObjectGraph: ".tmp/holoshell/shell-objects.json"
    wildHoloScriptIntakeSource: "apps/holoshell/source/holoshell-wild-holoscript-intake.hsplus"
    wildHoloScriptIntakeReceipt: ".tmp/holoshell/wild-holoscript-intake.json"
    hardwareActionReceipt: ".tmp/holoshell/action-latest.json"
    hardwareApprovalBundle: ".tmp/holoshell/approval-latest.json"
    workflowReceipt: ".tmp/holoshell/workflow-latest.json"
    workflowApprovalBundle: ".tmp/holoshell/workflow-approval-latest.json"
    workflowIntentGateReceipt: ".tmp/holoshell/brain-intent-gate-latest.json"
    readinessEvidencePack: ".tmp/holoshell/readiness-evidence.json"
    assetShardWorkflowReceipt: ".tmp/holoshell/shard-workflow-latest.json"
    assetShardPreviewSource: ".tmp/holoshell/shard-preview.holo"
    assetShardPrivateReceiptDir: ".tmp/holoshell/shard-receipts"
    assetShardImportApprovalBundle: ".tmp/holoshell/shard-import-approval-latest.json"
    assetShardImportReceipt: ".tmp/holoshell/shard-import-latest.json"
    previewProjection: "apps/holoshell/prototype/local-capability-room.html"
  }

  state {
    compositeHealth: "unknown"
    activeIntent: ""
    flagshipFounderIntent: "Brittney, open Claude, start a room marathon using Ollama Kimi Cloud, open a browser, and play lofi music on YouTube"
    founderCommandPipelineShape: "intent_plan_approval_trust_launcher_receipt"
    founderCommandExecutionDefault: "staged_not_run"
    founderCommandAutonomyLevel: "guarded"
    founderCommandConfidence: 0.86
    activeAgent: ""
    selectedCapability: ""
    pendingApprovals: 0
    capabilityCount: 0
    legacyMachineCount: 0
    activeAgentLaneCount: 0
    processHealthStatus: "unknown"
    networkRealityStatus: "unknown"
    networkRealityContractStatus: "unknown"
    networkBandwidthPosture: "unknown"
    networkHeavyWorkPolicy: "unknown"
    networkBlockedRunCount: 0
    networkBandwidthSpendRunCount: 0
    networkOwnerGestureCount: 0
    activeShellRunCount: 0
    registeredRunCount: 0
    ownedProcessCount: 0
    unmatchedActiveRunCount: 0
    actionableCleanupCandidateCount: 0
    ownerHandoffPlanCount: 0
    cleanupStopPlanCount: 0
    processRiskCount: 0
    stopPlanCount: 0
    receiptCount: 0
    timelineNodeCount: 0
    capturedWindowCount: 0
    capturedControlCount: 0
    capturedGeometryNodeCount: 0
    osUiActionBridgeStatus: "unknown"
    hardwareControlStatus: "unknown"
    programRegistryStatus: "unknown"
    installedProgramCount: 0
    launchableProgramCount: 0
    startMenuProgramCount: 0
    appPathProgramCount: 0
    hardwareActionStatus: "unknown"
    hardwareActionKind: ""
    hardwareActionPermissionEnvelope: "unknown"
    hardwareActionReceiptCount: 0
    hardwareMutatingActionExecuted: false
    hardwareApprovalRequired: false
    hardwareTargetWindowTitle: ""
    hardwareTargetProcessName: ""
    pendingHardwareApprovalCount: 0
    hardwareApprovalStatus: "unknown"
    hardwareApprovalActionKind: ""
    hardwareApprovalTarget: ""
    hardwareApprovalExpiresAt: ""
    hardwareApprovalExecutionAllowed: false
    hardwareControlDaemonStatus: "offline"
    hardwareControlDaemonExecuteEnabled: false
    activeApprovalReviewKind: ""
    activeApprovalReviewId: ""
    activeApprovalReviewTarget: ""
    activeApprovalReviewRisk: ""
    activeApprovalReviewExpiresAt: ""
    activeApprovalReviewExecutionAllowed: false
    activeApprovalReviewCommandPreview: ""
    activeApprovalReviewDaemonReady: false
    lastApprovalExecutionStatus: "none"
    lastApprovalExecutionRoute: ""
    lastApprovalExecutionMutationRecorded: false
    activeWorkflowStatus: "unknown"
    activeWorkflowTitle: ""
    activeWorkflowStepCount: 0
    activeWorkflowPendingApprovalCount: 0
    activeWorkflowModel: ""
    activeWorkflowModelRoute: ""
    activeWorkflowMusicTarget: ""
    activeWorkflowMutationExecuted: false
    activeWorkflowApprovalStatus: "unknown"
    activeWorkflowApprovalId: ""
    activeWorkflowApprovalExpiresAt: ""
    activeWorkflowApprovalExecutionAllowed: false
    activeWorkflowApprovalPendingCount: 0
    activeWorkflowIntentGateStatus: "unknown"
    activeWorkflowIntentGateCaseId: ""
    activeWorkflowIntentGateExecutionAllowed: false
    activeWorkflowIntentGateRuntimeBlocking: false
    activeWorkflowIntentGateFailedCheckCount: 0
    activeWorkflowIntentGateReceiptStatus: "unknown"
    pilotReceiptCount: 0
    readinessEvidenceStatus: "unknown"
    readinessScenario: ""
    readinessTokenCount: 0
    readinessWarningCount: 0
    readinessBuildStatus: "unknown"
    readinessValidationStatus: "unknown"
    readinessDeviceLabStatus: "unknown"
    readinessWasmSimdStatus: "unknown"
    readinessWebgpuStatus: "unknown"
    readinessHeadsetStatus: "unknown"
    readinessReplayStatus: "unknown"
    readinessGraphStatus: "unknown"
    readinessTaskCount: 0
    readinessNextWorkflow: ""
    activeShardWorkflowStatus: "unknown"
    activeShardWorkflowId: ""
    activeShardId: ""
    activeShardAssetCount: 0
    activeShardModelCount: 0
    activeShardImageCount: 0
    activeShardAudioCount: 0
    activeShardSourceCount: 0
    activeShardUnknownCount: 0
    activeShardBlockedAssetCount: 0
    activeShardPreviewObjectCount: 0
    activeShardApprovalRequired: false
    activeShardPendingApprovalCount: 0
    activeShardMutationExecuted: false
    activeShardPreviewSourcePath: ""
    activeShardPrivateReceiptPath: ""
    activeShardNextWorkflow: ""
    activeShardImportApprovalStatus: "unknown"
    activeShardImportApprovalId: ""
    activeShardImportApprovalExpiresAt: ""
    activeShardImportExecutionAllowed: false
    activeShardImportCommandPreview: ""
    activeShardImportStatus: "unknown"
    activeShardImportManifestPath: ""
    activeShardImportSourcePath: ""
    activeShardImportReceiptPath: ""
    activeShardImportRuntimeMutationExecuted: false
    activeShardImportSourceAssetsMutated: false
    wildHoloScriptStatus: "unknown"
    wildHoloScriptFileCount: 0
    wildHoloScriptHoloCount: 0
    wildHoloScriptHsCount: 0
    wildHoloScriptHsplusCount: 0
    wildHoloScriptFrontierSyntaxCount: 0
    wildHoloScriptAdapterNeededCount: 0
    wildHoloScriptCanonicalCandidateCount: 0
    wildHoloScriptFlagshipCount: 0
    wildHoloScriptTopPattern: ""
    wildHoloScriptNextMove: ""
    wildHoloScriptTopFlagship: ""
    activePilot: ""
    lastFeedGeneratedAt: ""
    operatingStage: "ask"
    nextMove: "read_machine"
    evidenceDrawerOpen: false
    skinMode: "liquid"
    shellObjectCount: 0
    shellObjectGraphStatus: "unknown"
    firstScreenObjectCount: 0
    appShellObjectCount: 0
    browserShellObjectCount: 0
    terminalShellObjectCount: 0
    documentAppShellObjectCount: 0
    agentShellObjectCount: 0
    workflowShellObjectCount: 0
    approvalShellObjectCount: 0
    receiptShellObjectCount: 0
    capturedShellObjectCount: 0
    runningShellObjectCount: 0
    guardedShellObjectCount: 0
    firstProgramShellObject: ""
    activeShellObject: "hololand"
    brittneyMode: "assistant_presence"
    brittneyAvatarStatus: "unknown"
    brittneyRuntimeStatus: "unknown"
    brittneyAvatarEmotion: "attentive"
    brittneyVoiceState: "ready"
    brittneyRuntimeRoute: "unknown"
    brittneyLastTurnStatus: "unknown"
    brittneyRuntimeEventCount: 0
    brittneyActionProposalCount: 0
    brittneyFirstProposalObject: ""
    brittneyFinalAvatarStage: "idle"
    brittneyKeyboardReachable: true
    brittneyScreenReaderReachable: true
    desktopReplacementActive: true
    trustFilter: "all"
    capabilityInventoryGeneratedAt: ""
    capabilityInventoryUpstreamGapCount: 0
    capabilityInventoryTrustVerified: 0
    capabilityInventoryTrustPartial: 0
    capabilityInventoryTrustUnknown: 0
    capabilityInventoryReceiptStatus: "pending"
    capabilityTrustHardwareProof: "unknown"
    capabilityTrustHoloScriptMcp: "unknown"
    capabilityTrustHoloMeshTeam: "unknown"
    capabilityTrustBrowserOperator: "unknown"
    capabilityTrustLocalProjects: "unknown"
    capabilityTrustLegacyApps: "unknown"
    capabilityTrustProcessHealth: "unknown"
  }

  channel "holoshell:intent" {
    type: "request_response"
    priority: "critical"
    description: "Natural-language user outcomes entering the local operating surface"
  }

  channel "holoshell:capabilities" {
    type: "pub_sub"
    priority: "high"
    description: "Discovered local, HoloScript, HoloLand, HoloMesh, MCP, browser, CLI, and app capabilities"
  }

  channel "holoshell:legacy" {
    type: "pub_sub"
    priority: "medium"
    description: "Installed programs and old workflows absorbed as HoloScript capability objects"
  }

  channel "holoshell:receipts" {
    type: "append_only"
    priority: "high"
    description: "Runtime, hardware, HoloDoor, and agent action receipts"
  }

  channel "holoshell:agent-presence" {
    type: "pub_sub"
    priority: "high"
    description: "Active agent lane presence from shells, IDEs, desktop apps, browsers, and HoloMesh"
  }

  channel "holoshell:process-health" {
    type: "pub_sub"
    priority: "critical"
    description: "PID custody, shell-run health, and local hardware pressure"
  }

  channel "holoshell:live-feed" {
    type: "pub_sub"
    priority: "critical"
    description: "Bundled HoloShell runtime feeds from local adapters, receipts, and pilot witnesses"
  }

  channel "holoshell:wild-holoscript" {
    type: "append_only"
    priority: "high"
    description: "Wild HoloScript source corpus scanned read-only for HoloShell module promotion"
  }

  channel "holoshell:readiness" {
    type: "append_only"
    priority: "high"
    description: "World build readiness evidence packs from HoloScript automation rendered as shell-room receipt tokens"
  }

  channel "holoshell:shard-workflow" {
    type: "request_response"
    priority: "high"
    description: "Local asset folders staged as playable HoloLand shard previews with receipts and guarded import"
  }

  channel "holoshell:shard-import" {
    type: "append_only"
    priority: "high"
    description: "Nonce-bound asset shard import approvals and local runtime import receipts"
  }

  channel "holoshell:pilot" {
    type: "append_only"
    priority: "high"
    description: "Browser, project, and legacy absorption pilot receipts"
  }

  channel "holoshell:approval" {
    type: "request_response"
    priority: "critical"
    description: "Break-glass approval lane for risky local actions"
  }

  channel "holoshell:workflow:approval" {
    type: "request_response"
    priority: "critical"
    description: "Nonce-bound approval lane for compound Brittney workflows"
  }

  channel "holoshell:workflow:intent-gate" {
    type: "request_response"
    priority: "critical"
    description: "Runtime-blocking HoloScript brain intent gate for Brittney workflow execution"
  }

  channel "holoshell:skin" {
    type: "pub_sub"
    priority: "medium"
    description: "Visual and behavioral skins for the HoloShell operating surface"
  }

  channel "holoshell:shell-object" {
    type: "pub_sub"
    priority: "high"
    description: "Programs, files, browser surfaces, agents, worlds, and powers as launchable shell objects"
  }

  channel "holoshell:os-ui-capture" {
    type: "pub_sub"
    priority: "critical"
    description: "Read-only legacy OS windows captured as shell objects and geometric wrappers"
  }

  channel "holoshell:hardware:action-request" {
    type: "request_response"
    priority: "critical"
    description: "Guarded local program control requests routed to the hardware-native executor"
  }

  channel "holoshell:hardware:program-registry" {
    type: "pub_sub"
    priority: "critical"
    description: "Launchable installed programs available to HoloShell through guarded action receipts"
  }

  channel "holoshell:hardware:receipt" {
    type: "append_only"
    priority: "critical"
    description: "Receipts proving every read-only or mutating hardware program action"
  }

  channel "holoshell:brittney" {
    type: "request_response"
    priority: "critical"
    description: "Brittney assistant and AGI-facing presence inside the HoloShell world"
  }

  channel "holoshell:brittney:avatar" {
    type: "pub_sub"
    priority: "critical"
    description: "Accessible embodied Brittney avatar connected to HoloScript AIBrittney runtime state"
  }

  channel "holoshell:brittney:turn" {
    type: "request_response"
    priority: "critical"
    description: "HoloShell chat turn routed through @holoscript/aibrittney and recorded as a receipt"
  }

  channel "holoshell:brittney:action-proposal" {
    type: "append_only"
    priority: "critical"
    description: "Brittney-proposed shell object actions with permission envelopes and receipts"
  }

  template "CapabilityGlyph" {
    type: "ui"
    uiType: "capability_glyph"
    width: 180
    height: 120
    trust_state: "unknown"
    permission: "read_only"
    receipt_required: true
  }

  template "LegacyMachine" {
    type: "ui"
    uiType: "legacy_machine"
    width: 260
    height: 170
    trust_state: "unknown"
    adapter: "unclassified"
    replacement_path: "undecided"
  }

  template "ReceiptNode" {
    type: "ui"
    uiType: "receipt_node"
    width: 320
    height: 96
    state: "pending"
    rollback: "unknown"
  }

  template "AgentLaneGlyph" {
    type: "ui"
    uiType: "agent_lane_glyph"
    width: 260
    height: 72
    colorIsVisualHintOnly: true
    requiresSemanticLaneId: true
    receipt_required: true
  }

  template "StopPlanNode" {
    type: "ui"
    uiType: "stop_plan_node"
    width: 320
    height: 112
    approvalRequired: true
    automaticTerminationAllowed: false
    receipt_required: true
  }

  template "PilotOutcomeNode" {
    type: "ui"
    uiType: "pilot_outcome_node"
    width: 320
    height: 112
    requiresWitness: true
    receipt_required: true
  }

  template "OutcomeStage" {
    type: "ui"
    uiType: "outcome_stage"
    width: 220
    height: 112
    stage: "ask"
    status: "pending"
    receipt_required: true
  }

  template "OperatingAction" {
    type: "ui"
    uiType: "operating_action"
    width: 360
    height: 104
    userFacing: true
    hidesBackendTelemetry: true
    receipt_required: true
  }

  template "ShellObjectBubble" {
    type: "ui"
    uiType: "shell_object_bubble"
    width: 132
    height: 132
    objectKind: "program"
    launchable: true
    receipt_required: true
  }

  template "HardwareControlBubble" {
    type: "ui"
    uiType: "hardware_control_bubble"
    width: 148
    height: 148
    objectKind: "hardware_power"
    launchable: true
    permissionEnvelope: "guarded_execute"
    approvalRequiredForMutation: true
    receipt_required: true
  }

  template "ProgramRegistryBubble" {
    type: "ui"
    uiType: "program_registry_bubble"
    width: 148
    height: 112
    objectKind: "program_registry"
    launchablePrograms: 0
    approvalRequiredForLaunch: true
    receipt_required: true
  }

  template "HardwareApprovalBubble" {
    type: "ui"
    uiType: "hardware_approval_bubble"
    width: 260
    height: 116
    objectKind: "approval"
    status: "unknown"
    target: ""
    expiresAt: ""
    nonceBound: true
    receipt_required: true
  }

  template "WorkflowBubble" {
    type: "ui"
    uiType: "workflow_bubble"
    width: 260
    height: 132
    objectKind: "workflow"
    status: "unknown"
    stepCount: 0
    pendingApprovals: 0
    modelRoute: ""
    mutationExecuted: false
    receipt_required: true
  }

  template "WorkflowIntentGateBubble" {
    type: "ui"
    uiType: "workflow_intent_gate_bubble"
    width: 260
    height: 116
    objectKind: "intent_gate"
    status: "unknown"
    caseId: ""
    runtimeBlocking: true
    executionAllowed: false
    failedCheckCount: 0
    receipt_required: true
  }

  template "ShellSkin" {
    type: "ui"
    uiType: "shell_skin"
    name: "liquid"
    visualEffect: "liquid_world"
    customizable: true
  }

  template "BrittneyPresence" {
    type: "ui"
    uiType: "assistant_avatar_presence"
    role: "assistant"
    agiVisionCompatible: true
    canOperateShellObjects: true
    embodiedAvatar: true
    avatarSource: "apps/holoshell/source/holoshell-brittney-avatar.hsplus"
    runtimePackage: "@holoscript/aibrittney"
    accessibilityRole: "button"
    keyboardShortcut: "Alt+B"
    liveRegion: "polite"
    receipt_required: true
  }

  page "Home" {
    object "SystemPulse" {
      type: "ui"
      uiType: "status_banner"
      text: "HoloLand has taken over the computer"
      health: $compositeHealth
      position: [0, 0]
    }

    object "LiquidWorld" {
      type: "ui"
      uiType: "full_screen_liquid_world"
      skin: $skinMode
      desktop_replacement_active: $desktopReplacementActive
      position: [0, 0]
    }

    object "Brittney" using "BrittneyPresence" {
      label: "Brittney"
      mode: $brittneyMode
      active_object: $activeShellObject
      avatar_status: $brittneyAvatarStatus
      runtime_status: $brittneyRuntimeStatus
      emotion: $brittneyAvatarEmotion
      voice_state: $brittneyVoiceState
      runtime_route: $brittneyRuntimeRoute
      last_turn_status: $brittneyLastTurnStatus
      runtime_events: $brittneyRuntimeEventCount
      action_proposals: $brittneyActionProposalCount
      keyboard_reachable: $brittneyKeyboardReachable
      screen_reader_reachable: $brittneyScreenReaderReachable
      position: [-3, 1]
    }

    spatial_group "ShellObjects" {
      position: [0, 1, -2]

      object "BrowserBubble" using "ShellObjectBubble" {
        label: "Browser"
        objectKind: "program"
        capability: "browser-operator"
      }

      object "FilesBubble" using "ShellObjectBubble" {
        label: "Files"
        objectKind: "file_space"
        capability: "local-projects"
      }

      object "AgentsBubble" using "ShellObjectBubble" {
        label: "Agents"
        objectKind: "agent_space"
        capability: "holomesh-team"
      }

      object "BrittneyAvatarBubble" using "ShellObjectBubble" {
        label: "Brittney"
        objectKind: "assistant_avatar"
        capability: "@holoscript/aibrittney"
        avatar_status: $brittneyAvatarStatus
        runtime_status: $brittneyRuntimeStatus
      }

      object "ProgramsBubble" using "ShellObjectBubble" {
        label: "Programs"
        objectKind: "legacy_program_space"
        capability: "legacy-apps"
        installed_programs: $installedProgramCount
        launchable_programs: $launchableProgramCount
      }

      object "ProgramRegistryBubble" using "ProgramRegistryBubble" {
        label: "App Registry"
        objectKind: "program_registry"
        launchablePrograms: $launchableProgramCount
      }

      object "CapturedUiBubble" using "ShellObjectBubble" {
        label: "Captured UI"
        objectKind: "legacy_surface"
        capability: "os-ui-capture"
        geometry_node_count: $capturedGeometryNodeCount
      }

      object "HoloLandBubble" using "ShellObjectBubble" {
        label: "HoloLand"
        objectKind: "world"
        capability: "hololand"
      }
    }

    spatial_group "SkinDock" {
      position: [0, -2, -1]

      object "LiquidSkin" using "ShellSkin" {
        label: "Water"
        name: "liquid"
        visualEffect: "water_ripple_caustics_sim"
      }

      object "FireSkin" using "ShellSkin" {
        label: "Fire"
        name: "fire"
        visualEffect: "fire_embers_heat_haze_sim"
      }

      object "DeveloperSkin" using "ShellSkin" {
        label: "Developer"
        name: "developer"
        visualEffect: "circuit_trace_data_pulse_sim"
      }

      object "AuraSkin" using "ShellSkin" {
        label: "Aura"
        name: "aura"
        visualEffect: "aura_field_orbital_particle_sim"
      }
    }

    object "OutcomeRequest" {
      type: "ui"
      uiType: "outcome_request"
      label: $activeIntent == "" ? "Prepare this computer for HoloLand work" : $activeIntent
      stage: $operatingStage
      position: [0, 0.5]
    }

    spatial_group "OutcomePath" {
      position: [0, 1, -2]

      object "AskStage" using "OutcomeStage" {
        label: "Ask"
        stage: "ask"
        status: $operatingStage == "ask" ? "active" : "complete"
      }

      object "PathStage" using "OutcomeStage" {
        label: "Choose Path"
        stage: "choose_path"
        status: $capabilityCount > 0 ? "ready" : "pending"
      }

      object "ApprovalStage" using "OutcomeStage" {
        label: "Approve"
        stage: "approve"
        status: $stopPlanCount > 0 ? "needs_user" : "quiet"
      }

      object "ReceiptStage" using "OutcomeStage" {
        label: "Receive"
        stage: "receive"
        status: $timelineNodeCount > 0 ? "linked" : "pending"
      }
    }

    spatial_group "OperatingRoom" {
      position: [0, 2, -2]

      object "NextMove" using "OperatingAction" {
        label: $nextMove
        status: $processHealthStatus == "pass" ? "can_run" : "clear_custody_first"
        detail: "Show the next user-facing move before backend telemetry"
      }

      object "HardwareProgramControl" using "HardwareControlBubble" {
        label: "Program Control"
        status: $hardwareActionStatus
        permission: $hardwareActionPermissionEnvelope
        target: $hardwareTargetWindowTitle
        launchable_programs: $launchableProgramCount
      }

      object "ApprovalQueue" using "StopPlanNode" {
        label: "Approval Lane"
        count: $stopPlanCount + $pendingHardwareApprovalCount
        status: ($stopPlanCount + $pendingHardwareApprovalCount) > 0 ? "approval_required" : "quiet"
      }

      object "HardwareApproval" using "HardwareApprovalBubble" {
        label: "Hardware Approval"
        status: $hardwareApprovalStatus
        target: $hardwareApprovalTarget
        expiresAt: $hardwareApprovalExpiresAt
      }

      object "RoomMarathon" using "WorkflowBubble" {
        label: "Room Marathon"
        status: $activeWorkflowStatus
        stepCount: $activeWorkflowStepCount
        pendingApprovals: $activeWorkflowPendingApprovalCount
        modelRoute: $activeWorkflowModelRoute
        mutationExecuted: $activeWorkflowMutationExecuted
      }

      object "BrainIntentGate" using "WorkflowIntentGateBubble" {
        label: "Brain Intent Gate"
        status: $activeWorkflowIntentGateStatus
        caseId: $activeWorkflowIntentGateCaseId
        runtimeBlocking: $activeWorkflowIntentGateRuntimeBlocking
        executionAllowed: $activeWorkflowIntentGateExecutionAllowed
        failedCheckCount: $activeWorkflowIntentGateFailedCheckCount
      }

      object "ReceiptRail" using "ReceiptNode" {
        label: "Receipts"
        state: $timelineNodeCount > 0 ? "linked" : "pending"
        rollback: "per_receipt"
      }
    }

    spatial_group "CapabilityMap" {
      position: [0, 1, -3]

      object "HardwareProof" using "CapabilityGlyph" {
        label: "Hardware Proof"
        source_kind: "hardware"
        trust_state: $capabilityTrustHardwareProof
        permission: "read_only"
      }

      object "HoloScriptRuntime" using "CapabilityGlyph" {
        label: "HoloScript Runtime"
        source_kind: "holoscript"
        trust_state: $capabilityTrustHoloScriptMcp
        permission: "read_execute"
      }

      object "HoloMeshTeam" using "CapabilityGlyph" {
        label: "Agent Team"
        source_kind: "holomesh"
        trust_state: $capabilityTrustHoloMeshTeam
        permission: "coordinate"
      }

      object "BrowserOperator" using "CapabilityGlyph" {
        label: "Browser"
        source_kind: "browser"
        trust_state: $capabilityTrustBrowserOperator
        permission: "guarded_write"
      }

      object "LocalFiles" using "CapabilityGlyph" {
        label: "Files"
        source_kind: "filesystem"
        trust_state: $capabilityTrustLocalProjects
        permission: "guarded_write"
      }

      object "LegacyApps" using "CapabilityGlyph" {
        label: "Legacy Apps"
        source_kind: "app"
        trust_state: $capabilityTrustLegacyApps
        permission: "classified_per_app"
      }

      object "ProcessHealth" using "CapabilityGlyph" {
        label: "Process Health"
        source_kind: "process_table"
        trust_state: $capabilityTrustProcessHealth
        permission: "read_only_then_break_glass"
      }
    }

    spatial_group "LegacyMachineGallery" {
      position: [-3, 1, -2]

      object "UnclassifiedProgram" using "LegacyMachine" {
        label: "Unclassified Program"
        adapter: "pending_discovery"
        replacement_path: "wrap_then_reimagine"
      }
    }

    spatial_group "AgentOperatorRoom" {
      position: [3, 1, -2]

      object "ActiveAgent" {
        type: "ui"
        uiType: "agent_operator"
        label: $activeAgent == "" ? "No active operator" : $activeAgent
        status: "standing_by"
        permission: "bounded_by_holodoor"
      }

      object "AgentLaneStack" using "AgentLaneGlyph" {
        label: "Agent Lanes"
        active_lanes: $activeAgentLaneCount
        source_kind: "agent_presence"
        color_semantics: "metadata_first"
      }

      object "ProcessHealthPulse" {
        type: "ui"
        uiType: "process_health_pulse"
        label: "Process Health"
        status: $processHealthStatus
        shell_runs: $activeShellRunCount
        registered_runs: $registeredRunCount
        owned_processes: $ownedProcessCount
        unmatched_runs: $unmatchedActiveRunCount
        risks: $processRiskCount
        stop_policy: "break_glass_required"
      }

      object "NetworkBandwidthGuard" {
        type: "ui"
        uiType: "network_bandwidth_guard"
        label: "Network Guard"
        status: $networkRealityStatus
        contract: $networkRealityContractStatus
        bandwidth_posture: $networkBandwidthPosture
        heavy_work_policy: $networkHeavyWorkPolicy
        blocked_runs: $networkBlockedRunCount
        bandwidth_spending_runs: $networkBandwidthSpendRunCount
        owner_gestures: $networkOwnerGestureCount
      }

      object "StopPlanQueue" using "StopPlanNode" {
        label: "Cleanup Plans"
        count: $stopPlanCount
        status: $stopPlanCount > 0 ? "approval_required" : "quiet"
      }
    }

    spatial_group "TrustTimeline" {
      position: [0, -1, -2]

      object "LatestReceipt" using "ReceiptNode" {
        label: "Waiting for first receipt"
        state: "pending"
        rollback: "not_applicable"
      }

      object "TimelineBundle" using "ReceiptNode" {
        label: "Runtime feed timeline"
        state: $timelineNodeCount > 0 ? "linked" : "pending"
        rollback: "per_receipt"
      }

      object "PilotReceipts" using "PilotOutcomeNode" {
        label: $activePilot == "" ? "Pilot receipts" : $activePilot
        count: $pilotReceiptCount
        state: $pilotReceiptCount > 0 ? "recorded" : "pending"
      }
    }

    object "ApprovalLane" {
      type: "ui"
      uiType: "break_glass_lane"
      label: "Approvals"
      count: $pendingApprovals
      visible_when: $pendingApprovals > 0
      position: [0, 3]
    }
  }

  action submit_intent(intentText) {
    state.activeIntent = intentText
    state.operatingStage = "choose_path"
    emit("holoshell:intent", {
      intent: intentText,
      surface: "holoshell",
      user_model: "non_developer",
      requires_plan: true,
      requires_receipt: true
    })
  }

  action select_shell_object(shellObject) {
    state.activeShellObject = shellObject.id
    emit("holoshell:shell-object", {
      action: "shell_object_selected",
      object: shellObject,
      brittney_mode: state.brittneyMode,
      receipt_required: true
    })
  }

  action change_skin(name) {
    state.skinMode = name
    emit("holoshell:skin", {
      action: "skin_changed",
      skin: name,
      shell: "holoshell",
      desktop_replacement_active: state.desktopReplacementActive
    })
  }

  action brittney_reply(message) {
    state.brittneyVoiceState = "speaking"
    emit("holoshell:brittney", {
      action: "assistant_reply",
      message: message,
      active_object: state.activeShellObject,
      mode: state.brittneyMode,
      avatar_status: state.brittneyAvatarStatus,
      voice_state: state.brittneyVoiceState,
      receipt_required: true
    })
  }

  action submit_brittney_turn(message) {
    state.activeIntent = message
    state.brittneyVoiceState = "quiet"
    state.brittneyAvatarEmotion = "focused"
    emit("holoshell:brittney:turn", {
      action: "brittney_turn_submitted",
      message: message,
      runtime: "@holoscript/aibrittney",
      source_contract: "apps/holoshell/source/holoshell-brittney-runtime-bridge.hsplus",
      receipt_required: true
    })
  }

  action apply_brittney_turn_receipt(turnReceipt) {
    state.brittneyLastTurnStatus = turnReceipt.summary.status
    state.brittneyRuntimeEventCount = turnReceipt.summary.eventCount
    state.brittneyActionProposalCount = turnReceipt.summary.actionProposalCount
    state.brittneyFirstProposalObject = turnReceipt.summary.firstProposalObject
    state.brittneyFinalAvatarStage = turnReceipt.summary.finalAvatarStage
    state.brittneyAvatarEmotion = turnReceipt.summary.finalEmotion
    state.brittneyVoiceState = turnReceipt.summary.finalVoiceState
    emit("holoshell:brittney:turn", {
      action: "brittney_turn_receipt_applied",
      turn_id: turnReceipt.turnId,
      status: state.brittneyLastTurnStatus,
      runtime_events: state.brittneyRuntimeEventCount,
      proposals: state.brittneyActionProposalCount,
      first_proposal_object: state.brittneyFirstProposalObject,
      avatar_stage: state.brittneyFinalAvatarStage,
      receipt: turnReceipt.receipt
    })
  }

  action apply_brittney_action_proposal(proposal) {
    state.activeShellObject = proposal.objectId
    emit("holoshell:brittney:action-proposal", {
      action: "brittney_action_proposal_applied",
      proposal: proposal,
      active_shell_object: state.activeShellObject,
      approval_required: proposal.approvalRequired,
      receipt_required: true
    })
  }

  action apply_brittney_avatar_manifest(manifest) {
    state.brittneyAvatarStatus = manifest.summary.avatarStatus
    state.brittneyRuntimeStatus = manifest.summary.runtimeStatus
    state.brittneyAvatarEmotion = manifest.summary.emotion
    state.brittneyVoiceState = manifest.summary.voiceState
    state.brittneyRuntimeRoute = manifest.summary.ollamaHostKind
    state.brittneyKeyboardReachable = manifest.accessibility.keyboardReachable
    state.brittneyScreenReaderReachable = manifest.accessibility.screenReaderReachable
    emit("holoshell:brittney:avatar", {
      action: "brittney_avatar_manifest_applied",
      avatar_status: state.brittneyAvatarStatus,
      runtime_status: state.brittneyRuntimeStatus,
      emotion: state.brittneyAvatarEmotion,
      voice_state: state.brittneyVoiceState,
      route: state.brittneyRuntimeRoute,
      keyboard_reachable: state.brittneyKeyboardReachable,
      screen_reader_reachable: state.brittneyScreenReaderReachable,
      source_contract: "apps/holoshell/source/holoshell-brittney-avatar.hsplus",
      receipt_required: true
    })
  }

  action absorb_capability(capability) {
    state.capabilityCount = state.capabilityCount + 1
    emit("holoshell:capabilities", {
      action: "capability_absorbed",
      capability: capability,
      trust_state: capability.trust_state || "unknown"
    })
  }

  action absorb_legacy_machine(programManifest) {
    state.legacyMachineCount = state.legacyMachineCount + 1
    emit("holoshell:legacy", {
      action: "legacy_machine_absorbed",
      manifest: programManifest,
      adapter: programManifest.adapter || "unclassified",
      replacement_path: programManifest.replacement_path || "wrap_then_reimagine"
    })
  }

  action update_agent_presence(laneManifest) {
    state.activeAgentLaneCount = laneManifest.summary.activeLaneCount
    emit("holoshell:agent-presence", {
      action: "agent_lanes_updated",
      lanes: laneManifest.summary.laneCount,
      active_lanes: state.activeAgentLaneCount,
      color_is_visual_hint_only: true
    })
  }

  action update_process_health(processHealth) {
    state.processHealthStatus = processHealth.summary.riskState
    state.activeShellRunCount = processHealth.summary.shellRunCount
    state.registeredRunCount = processHealth.summary.registeredRunCount
    state.ownedProcessCount = processHealth.summary.ownedProcessCount
    state.unmatchedActiveRunCount = processHealth.summary.unmatchedActiveRunCount
    state.actionableCleanupCandidateCount = processHealth.summary.actionableCleanupCandidateCount || 0
    state.ownerHandoffPlanCount = processHealth.summary.ownerHandoffPlanCount || 0
    state.cleanupStopPlanCount = processHealth.summary.cleanupStopPlanCount || processHealth.summary.stopPlanCount || 0
    state.stopPlanCount = state.cleanupStopPlanCount
    state.processRiskCount = state.actionableCleanupCandidateCount
      + state.ownerHandoffPlanCount
      + processHealth.summary.overdueRegisteredRunCount
      + processHealth.summary.unmatchedActiveRunCount
    emit("holoshell:process-health", {
      action: "process_health_updated",
      risk_state: state.processHealthStatus,
      shell_runs: state.activeShellRunCount,
      registered_runs: state.registeredRunCount,
      owned_processes: state.ownedProcessCount,
      unmatched_runs: state.unmatchedActiveRunCount,
      actionable_cleanup_candidates: state.actionableCleanupCandidateCount,
      owner_handoff_plans: state.ownerHandoffPlanCount,
      risk_count: state.processRiskCount,
      cleanup_stop_plans: state.cleanupStopPlanCount,
      stop_plans: state.stopPlanCount,
      automatic_termination_allowed: false
    })
  }

  action apply_live_feed(feedBundle) {
    state.capabilityCount = feedBundle.summary.capabilityCount
    state.capabilityInventoryGeneratedAt = feedBundle.feeds.inventory?.generatedAt || ""
    state.capabilityInventoryUpstreamGapCount = (feedBundle.feeds.inventory?.upstreamGaps || []).length
    state.capabilityInventoryTrustVerified = feedBundle.feeds.inventory?.summary?.verified || 0
    state.capabilityInventoryTrustPartial = feedBundle.feeds.inventory?.summary?.partial || 0
    state.capabilityInventoryTrustUnknown = feedBundle.feeds.inventory?.summary?.unknown || 0
    state.capabilityInventoryReceiptStatus = feedBundle.feeds.inventory ? "linked" : "pending"
    const inventoryCapabilities = feedBundle.feeds.inventory?.capabilities || []
    state.capabilityTrustHardwareProof = inventoryCapabilities.find((c) => c.id === 'hardware-proof')?.trustState || 'unknown'
    state.capabilityTrustHoloScriptMcp = inventoryCapabilities.find((c) => c.id === 'holoscript-mcp')?.trustState || 'unknown'
    state.capabilityTrustHoloMeshTeam = inventoryCapabilities.find((c) => c.id === 'holomesh-team')?.trustState || 'unknown'
    state.capabilityTrustBrowserOperator = inventoryCapabilities.find((c) => c.id === 'browser-operator')?.trustState || 'unknown'
    state.capabilityTrustLocalProjects = inventoryCapabilities.find((c) => c.id === 'local-projects')?.trustState || 'unknown'
    state.capabilityTrustLegacyApps = inventoryCapabilities.find((c) => c.id === 'legacy-apps')?.trustState || 'unknown'
    state.capabilityTrustProcessHealth = inventoryCapabilities.find((c) => c.id === 'process-run-custody')?.trustState || 'unknown'
    state.legacyMachineCount = feedBundle.summary.legacyProgramCount
    state.activeAgentLaneCount = feedBundle.summary.activeLaneCount
    state.processHealthStatus = feedBundle.summary.processRisk
    state.networkRealityStatus = feedBundle.summary.networkRealityStatus
    state.networkRealityContractStatus = feedBundle.summary.networkRealityContractStatus
    state.networkBandwidthPosture = feedBundle.summary.networkRealityBandwidthPosture
    state.networkHeavyWorkPolicy = feedBundle.summary.networkRealityHeavyWorkPolicy
    state.networkBlockedRunCount = feedBundle.summary.runNetworkBlockedCount || 0
    state.networkBandwidthSpendRunCount = feedBundle.summary.runBandwidthSpendingCount || 0
    state.networkOwnerGestureCount = feedBundle.summary.runOwnerNetworkGestureCount || 0
    state.activeShellRunCount = feedBundle.feeds.processHealth.summary.shellRunCount
    state.registeredRunCount = feedBundle.feeds.processHealth.summary.registeredRunCount
    state.ownedProcessCount = feedBundle.feeds.processHealth.summary.ownedProcessCount
    state.unmatchedActiveRunCount = feedBundle.feeds.processHealth.summary.unmatchedActiveRunCount
    state.actionableCleanupCandidateCount = feedBundle.feeds.processHealth.summary.actionableCleanupCandidateCount || 0
    state.ownerHandoffPlanCount = feedBundle.feeds.processHealth.summary.ownerHandoffPlanCount || 0
    state.cleanupStopPlanCount = feedBundle.feeds.processHealth.summary.cleanupStopPlanCount || feedBundle.summary.stopPlanCount
    state.stopPlanCount = state.cleanupStopPlanCount
    state.processRiskCount = state.actionableCleanupCandidateCount
      + state.ownerHandoffPlanCount
      + state.unmatchedActiveRunCount
    state.timelineNodeCount = feedBundle.summary.timelineCount
    state.capturedWindowCount = feedBundle.summary.capturedWindowCount
    state.capturedControlCount = feedBundle.summary.capturedControlCount
    state.capturedGeometryNodeCount = feedBundle.summary.capturedGeometryNodeCount
    state.osUiActionBridgeStatus = feedBundle.summary.osUiActionBridgeStatus
    state.programRegistryStatus = feedBundle.summary.programRegistryStatus
    state.installedProgramCount = feedBundle.summary.installedProgramCount
    state.launchableProgramCount = feedBundle.summary.launchableProgramCount
    state.startMenuProgramCount = feedBundle.summary.startMenuProgramCount
    state.appPathProgramCount = feedBundle.summary.appPathProgramCount
    state.readinessEvidenceStatus = feedBundle.summary.readinessEvidenceStatus
    state.readinessScenario = feedBundle.summary.readinessScenario
    state.readinessTokenCount = feedBundle.summary.readinessTokenCount
    state.readinessWarningCount = feedBundle.summary.readinessWarningCount
    state.readinessBuildStatus = feedBundle.summary.readinessBuildStatus
    state.readinessValidationStatus = feedBundle.summary.readinessValidationStatus
    state.readinessDeviceLabStatus = feedBundle.summary.readinessDeviceLabStatus
    state.readinessWasmSimdStatus = feedBundle.summary.readinessWasmSimdStatus
    state.readinessWebgpuStatus = feedBundle.summary.readinessWebgpuStatus
    state.readinessHeadsetStatus = feedBundle.summary.readinessHeadsetStatus
    state.readinessReplayStatus = feedBundle.summary.readinessReplayStatus
    state.readinessGraphStatus = feedBundle.summary.readinessGraphStatus
    state.readinessTaskCount = feedBundle.summary.readinessTaskCount
    state.readinessNextWorkflow = feedBundle.summary.readinessNextWorkflow
    state.shellObjectGraphStatus = feedBundle.summary.shellObjectGraphStatus
    state.shellObjectCount = feedBundle.summary.shellObjectCount
    state.firstScreenObjectCount = feedBundle.summary.firstScreenObjectCount
    state.appShellObjectCount = feedBundle.summary.appShellObjectCount
    state.browserShellObjectCount = feedBundle.summary.browserShellObjectCount
    state.terminalShellObjectCount = feedBundle.summary.terminalShellObjectCount
    state.documentAppShellObjectCount = feedBundle.summary.documentAppShellObjectCount
    state.agentShellObjectCount = feedBundle.summary.agentShellObjectCount
    state.workflowShellObjectCount = feedBundle.summary.workflowShellObjectCount
    state.approvalShellObjectCount = feedBundle.summary.approvalShellObjectCount
    state.receiptShellObjectCount = feedBundle.summary.receiptShellObjectCount
    state.capturedShellObjectCount = feedBundle.summary.capturedShellObjectCount
    state.runningShellObjectCount = feedBundle.summary.runningShellObjectCount
    state.guardedShellObjectCount = feedBundle.summary.guardedShellObjectCount
    state.firstProgramShellObject = feedBundle.summary.firstProgramShellObject
    state.brittneyAvatarStatus = feedBundle.summary.brittneyAvatarStatus
    state.brittneyRuntimeStatus = feedBundle.summary.brittneyRuntimeStatus
    state.brittneyAvatarEmotion = feedBundle.summary.brittneyEmotion
    state.brittneyVoiceState = feedBundle.summary.brittneyVoiceState
    state.brittneyRuntimeRoute = feedBundle.summary.brittneyRuntimeRoute
    state.brittneyLastTurnStatus = feedBundle.summary.brittneyLastTurnStatus
    state.brittneyRuntimeEventCount = feedBundle.summary.brittneyRuntimeEventCount
    state.brittneyActionProposalCount = feedBundle.summary.brittneyActionProposalCount
    state.brittneyFirstProposalObject = feedBundle.summary.brittneyFirstProposalObject
    state.brittneyFinalAvatarStage = feedBundle.summary.brittneyFinalAvatarStage
    state.hardwareControlStatus = feedBundle.summary.hardwareControlStatus
    state.hardwareActionStatus = feedBundle.summary.hardwareActionStatus
    state.hardwareActionKind = feedBundle.summary.hardwareActionKind
    state.hardwareActionPermissionEnvelope = feedBundle.summary.hardwareActionPermissionEnvelope
    state.hardwareActionReceiptCount = feedBundle.summary.hardwareActionReceiptCount
    state.hardwareMutatingActionExecuted = feedBundle.summary.hardwareMutatingActionExecuted
    state.hardwareApprovalRequired = feedBundle.summary.hardwareApprovalRequired
    state.hardwareTargetWindowTitle = feedBundle.summary.hardwareTargetWindowTitle
    state.hardwareTargetProcessName = feedBundle.summary.hardwareTargetProcessName
    state.pendingHardwareApprovalCount = feedBundle.summary.pendingHardwareApprovalCount
    state.hardwareApprovalStatus = feedBundle.summary.hardwareApprovalStatus
    state.hardwareApprovalActionKind = feedBundle.summary.hardwareApprovalActionKind
    state.hardwareApprovalTarget = feedBundle.summary.hardwareApprovalTarget
    state.hardwareApprovalExpiresAt = feedBundle.summary.hardwareApprovalExpiresAt
    state.hardwareApprovalExecutionAllowed = feedBundle.summary.hardwareApprovalExecutionAllowed
    state.activeApprovalReviewKind = feedBundle.summary.hardwareApprovalStatus == "pending_user_approval" ? "hardware" : state.activeApprovalReviewKind
    state.activeApprovalReviewTarget = feedBundle.summary.hardwareApprovalTarget || state.activeApprovalReviewTarget
    state.activeApprovalReviewExpiresAt = feedBundle.summary.hardwareApprovalExpiresAt || state.activeApprovalReviewExpiresAt
    state.activeApprovalReviewExecutionAllowed = feedBundle.summary.hardwareApprovalExecutionAllowed || state.activeApprovalReviewExecutionAllowed
    state.activeApprovalReviewDaemonReady = state.hardwareControlDaemonStatus == "online" && state.hardwareControlDaemonExecuteEnabled
    state.activeWorkflowStatus = feedBundle.summary.activeWorkflowStatus
    state.activeWorkflowTitle = feedBundle.summary.activeWorkflowTitle
    state.activeWorkflowStepCount = feedBundle.summary.activeWorkflowStepCount
    state.activeWorkflowPendingApprovalCount = feedBundle.summary.activeWorkflowPendingApprovalCount
    state.activeWorkflowModel = feedBundle.summary.activeWorkflowModel
    state.activeWorkflowModelRoute = feedBundle.summary.activeWorkflowModelRoute
    state.activeWorkflowMusicTarget = feedBundle.summary.activeWorkflowMusicTarget
    state.activeWorkflowMutationExecuted = feedBundle.summary.activeWorkflowMutationExecuted
    state.activeWorkflowApprovalStatus = feedBundle.summary.activeWorkflowApprovalStatus
    state.activeWorkflowApprovalId = feedBundle.summary.activeWorkflowApprovalId
    state.activeWorkflowApprovalExpiresAt = feedBundle.summary.activeWorkflowApprovalExpiresAt
    state.activeWorkflowApprovalExecutionAllowed = feedBundle.summary.activeWorkflowApprovalExecutionAllowed
    state.activeWorkflowApprovalPendingCount = feedBundle.summary.activeWorkflowApprovalPendingCount
    state.activeWorkflowIntentGateStatus = feedBundle.summary.activeWorkflowIntentGateStatus
    state.activeWorkflowIntentGateCaseId = feedBundle.summary.activeWorkflowIntentGateCaseId
    state.activeWorkflowIntentGateExecutionAllowed = feedBundle.summary.activeWorkflowIntentGateExecutionAllowed
    state.activeWorkflowIntentGateRuntimeBlocking = feedBundle.summary.activeWorkflowIntentGateRuntimeBlocking
    state.activeWorkflowIntentGateFailedCheckCount = feedBundle.summary.activeWorkflowIntentGateFailedCheckCount
    state.activeWorkflowIntentGateReceiptStatus = feedBundle.summary.activeWorkflowIntentGateReceiptStatus
    state.activeShardWorkflowStatus = feedBundle.summary.activeShardWorkflowStatus
    state.activeShardWorkflowId = feedBundle.summary.activeShardWorkflowId
    state.activeShardId = feedBundle.summary.activeShardId
    state.activeShardAssetCount = feedBundle.summary.activeShardAssetCount
    state.activeShardModelCount = feedBundle.summary.activeShardModelCount
    state.activeShardImageCount = feedBundle.summary.activeShardImageCount
    state.activeShardAudioCount = feedBundle.summary.activeShardAudioCount
    state.activeShardSourceCount = feedBundle.summary.activeShardSourceCount
    state.activeShardUnknownCount = feedBundle.summary.activeShardUnknownCount
    state.activeShardBlockedAssetCount = feedBundle.summary.activeShardBlockedAssetCount
    state.activeShardPreviewObjectCount = feedBundle.summary.activeShardPreviewObjectCount
    state.activeShardApprovalRequired = feedBundle.summary.activeShardApprovalRequired
    state.activeShardPendingApprovalCount = state.activeShardApprovalRequired && state.activeShardWorkflowStatus == "staged" ? 1 : 0
    state.activeShardMutationExecuted = feedBundle.summary.activeShardMutationExecuted
    state.activeShardPreviewSourcePath = feedBundle.summary.activeShardPreviewSourcePath
    state.activeShardPrivateReceiptPath = feedBundle.summary.activeShardPrivateReceiptPath
    state.activeShardNextWorkflow = feedBundle.summary.activeShardNextWorkflow
    state.activeShardImportApprovalStatus = feedBundle.summary.activeShardImportApprovalStatus
    state.activeShardImportApprovalId = feedBundle.summary.activeShardImportApprovalId
    state.activeShardImportApprovalExpiresAt = feedBundle.summary.activeShardImportApprovalExpiresAt
    state.activeShardImportExecutionAllowed = feedBundle.summary.activeShardImportExecutionAllowed
    state.activeShardImportCommandPreview = feedBundle.summary.activeShardImportCommandPreview
    state.activeShardImportStatus = feedBundle.summary.activeShardImportStatus
    state.activeShardImportManifestPath = feedBundle.summary.activeShardImportManifestPath
    state.activeShardImportSourcePath = feedBundle.summary.activeShardImportSourcePath
    state.activeShardImportReceiptPath = feedBundle.summary.activeShardImportReceiptPath
    state.activeShardImportRuntimeMutationExecuted = feedBundle.summary.activeShardImportRuntimeMutationExecuted
    state.activeShardImportSourceAssetsMutated = feedBundle.summary.activeShardImportSourceAssetsMutated
    state.wildHoloScriptStatus = feedBundle.summary.wildHoloScriptStatus
    state.wildHoloScriptFileCount = feedBundle.summary.wildHoloScriptFileCount
    state.wildHoloScriptHoloCount = feedBundle.summary.wildHoloScriptHoloCount
    state.wildHoloScriptHsCount = feedBundle.summary.wildHoloScriptHsCount
    state.wildHoloScriptHsplusCount = feedBundle.summary.wildHoloScriptHsplusCount
    state.wildHoloScriptFrontierSyntaxCount = feedBundle.summary.wildHoloScriptFrontierSyntaxCount
    state.wildHoloScriptAdapterNeededCount = feedBundle.summary.wildHoloScriptAdapterNeededCount
    state.wildHoloScriptCanonicalCandidateCount = feedBundle.summary.wildHoloScriptCanonicalCandidateCount
    state.wildHoloScriptFlagshipCount = feedBundle.summary.wildHoloScriptFlagshipCount
    state.wildHoloScriptTopPattern = feedBundle.summary.wildHoloScriptTopPattern
    state.wildHoloScriptNextMove = feedBundle.summary.wildHoloScriptNextMove
    state.wildHoloScriptTopFlagship = feedBundle.feeds.wildHoloScript?.topFlagships[0]?.path || state.wildHoloScriptTopFlagship
    state.pilotReceiptCount = feedBundle.summary.pilotReceiptCount
    state.lastFeedGeneratedAt = feedBundle.generatedAt
    state.compositeHealth = feedBundle.summary.overallRisk
    state.pendingApprovals = state.stopPlanCount + state.pendingHardwareApprovalCount + (state.activeWorkflowApprovalExecutionAllowed ? state.activeWorkflowApprovalPendingCount : 0) + state.activeShardPendingApprovalCount + (state.activeShardImportExecutionAllowed ? 1 : 0)
    state.operatingStage = state.pendingApprovals > 0 ? "approve" : "receive"
    state.nextMove = state.stopPlanCount > 0 ? "review_cleanup_plan" : state.activeWorkflowApprovalExecutionAllowed ? "review_workflow_approval" : state.activeShardImportExecutionAllowed ? "review_asset_shard_import_approval" : state.activeShardPendingApprovalCount > 0 ? "stage_asset_shard_import_approval" : "run_project_check"
    emit("holoshell:live-feed", {
      action: "live_feed_applied",
      generated_at: state.lastFeedGeneratedAt,
      overall_risk: state.compositeHealth,
      capabilities: state.capabilityCount,
      lanes: state.activeAgentLaneCount,
      captured_windows: state.capturedWindowCount,
      captured_controls: state.capturedControlCount,
      captured_geometry_nodes: state.capturedGeometryNodeCount,
      os_ui_action_bridge: state.osUiActionBridgeStatus,
      program_registry: state.programRegistryStatus,
      installed_programs: state.installedProgramCount,
      launchable_programs: state.launchableProgramCount,
      readiness_evidence: state.readinessEvidenceStatus,
      readiness_scenario: state.readinessScenario,
      readiness_tokens: state.readinessTokenCount,
      readiness_warnings: state.readinessWarningCount,
      readiness_build: state.readinessBuildStatus,
      readiness_validation: state.readinessValidationStatus,
      readiness_device_lab: state.readinessDeviceLabStatus,
      readiness_webgpu: state.readinessWebgpuStatus,
      readiness_wasm_simd: state.readinessWasmSimdStatus,
      readiness_headset: state.readinessHeadsetStatus,
      readiness_replay: state.readinessReplayStatus,
      readiness_graph_status: state.readinessGraphStatus,
      readiness_tasks: state.readinessTaskCount,
      readiness_next_workflow: state.readinessNextWorkflow,
      shell_object_graph: state.shellObjectGraphStatus,
      shell_objects: state.shellObjectCount,
      first_screen_objects: state.firstScreenObjectCount,
      app_shell_objects: state.appShellObjectCount,
      browser_shell_objects: state.browserShellObjectCount,
      terminal_shell_objects: state.terminalShellObjectCount,
      document_app_shell_objects: state.documentAppShellObjectCount,
      agent_shell_objects: state.agentShellObjectCount,
      workflow_shell_objects: state.workflowShellObjectCount,
      approval_shell_objects: state.approvalShellObjectCount,
      receipt_shell_objects: state.receiptShellObjectCount,
      captured_shell_objects: state.capturedShellObjectCount,
