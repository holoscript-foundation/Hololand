  action apply_capability_inventory(inventory) {
    state.capabilityCount = inventory.summary.capabilityCount
    state.capabilityInventoryGeneratedAt = inventory.generatedAt
    state.capabilityInventoryUpstreamGapCount = (inventory.upstreamGaps || []).length
    state.capabilityInventoryTrustVerified = inventory.summary.verified || 0
    state.capabilityInventoryTrustPartial = inventory.summary.partial || 0
    state.capabilityInventoryTrustUnknown = inventory.summary.unknown || 0
    state.capabilityInventoryReceiptStatus = "recorded"
    const capabilities = inventory.capabilities || []
    state.capabilityTrustHardwareProof = capabilities.find((c) => c.id === 'hardware-proof')?.trustState || 'unknown'
    state.capabilityTrustHoloScriptMcp = capabilities.find((c) => c.id === 'holoscript-mcp')?.trustState || 'unknown'
    state.capabilityTrustHoloMeshTeam = capabilities.find((c) => c.id === 'holomesh-team')?.trustState || 'unknown'
    state.capabilityTrustBrowserOperator = capabilities.find((c) => c.id === 'browser-operator')?.trustState || 'unknown'
    state.capabilityTrustLocalProjects = capabilities.find((c) => c.id === 'local-projects')?.trustState || 'unknown'
    state.capabilityTrustLegacyApps = capabilities.find((c) => c.id === 'legacy-apps')?.trustState || 'unknown'
    state.capabilityTrustProcessHealth = capabilities.find((c) => c.id === 'process-run-custody')?.trustState || 'unknown'
    emit("holoshell:capabilities", {
      action: "capability_inventory_applied",
      capability_count: state.capabilityCount,
      trust_verified: state.capabilityInventoryTrustVerified,
      trust_partial: state.capabilityInventoryTrustPartial,
      trust_unknown: state.capabilityInventoryTrustUnknown,
      upstream_gaps: state.capabilityInventoryUpstreamGapCount,
      receipt_required: true
    })
  }

  action link_receipt_timeline(feedBundle) {
    state.timelineNodeCount = feedBundle.summary.timelineCount
    state.receiptCount = state.receiptCount + feedBundle.summary.timelineCount
    emit("holoshell:receipts", {
      action: "timeline_linked",
      timeline: feedBundle.timeline,
      count: state.timelineNodeCount,
      rollback: "per_receipt",
      trust_state: feedBundle.summary.overallRisk == "pass" ? "verified" : "partial"
    })
  }

  action apply_readiness_evidence(evidencePack) {
    state.readinessEvidenceStatus = evidencePack.summary.status
    state.readinessScenario = evidencePack.summary.scenario
    state.readinessTokenCount = evidencePack.summary.tokenCount
    state.readinessWarningCount = evidencePack.summary.warningCount
    state.readinessBuildStatus = evidencePack.summary.buildStatus
    state.readinessValidationStatus = evidencePack.summary.validationStatus
    state.readinessDeviceLabStatus = evidencePack.summary.deviceLabStatus
    state.readinessWasmSimdStatus = evidencePack.summary.wasmSimdStatus
    state.readinessWebgpuStatus = evidencePack.summary.webgpuStatus
    state.readinessHeadsetStatus = evidencePack.summary.headsetStatus
    state.readinessReplayStatus = evidencePack.summary.replayStatus
    state.readinessGraphStatus = evidencePack.summary.graphStatus
    state.readinessTaskCount = evidencePack.summary.taskCount
    state.readinessNextWorkflow = evidencePack.summary.nextWorkflow
    state.receiptCount = state.receiptCount + state.readinessTokenCount
    state.operatingStage = state.readinessWarningCount > 0 ? "receive" : state.operatingStage
    state.nextMove = state.readinessNextWorkflow || state.nextMove
    emit("holoshell:readiness", {
      action: "readiness_evidence_applied",
      readiness_id: evidencePack.readinessId,
      status: state.readinessEvidenceStatus,
      scenario: state.readinessScenario,
      tokens: state.readinessTokenCount,
      warnings: state.readinessWarningCount,
      build: state.readinessBuildStatus,
      validation: state.readinessValidationStatus,
      device_lab: state.readinessDeviceLabStatus,
      webgpu: state.readinessWebgpuStatus,
      wasm_simd: state.readinessWasmSimdStatus,
      headset: state.readinessHeadsetStatus,
      replay: state.readinessReplayStatus,
      graph_status: state.readinessGraphStatus,
      tasks: state.readinessTaskCount,
      next_workflow: state.readinessNextWorkflow,
      receipt_required: true
    })
  }

  action apply_wild_holoscript_intake(receipt) {
    state.wildHoloScriptStatus = receipt.summary.status
    state.wildHoloScriptFileCount = receipt.summary.fileCount
    state.wildHoloScriptHoloCount = receipt.summary.holoCount
    state.wildHoloScriptHsCount = receipt.summary.hsCount
    state.wildHoloScriptHsplusCount = receipt.summary.hsplusCount
    state.wildHoloScriptFrontierSyntaxCount = receipt.summary.frontierSyntaxCount
    state.wildHoloScriptAdapterNeededCount = receipt.summary.adapterNeededCount
    state.wildHoloScriptCanonicalCandidateCount = receipt.summary.canonicalCandidateCount
    state.wildHoloScriptFlagshipCount = receipt.summary.flagshipCount
    state.wildHoloScriptTopPattern = receipt.summary.topPattern
    state.wildHoloScriptNextMove = receipt.summary.nextMove
    state.wildHoloScriptTopFlagship = receipt.topFlagships[0]?.path || ""
    state.activeShellObject = "source.wild-holoscript.uaa2"
    state.nextMove = state.wildHoloScriptNextMove || state.nextMove
    emit("holoshell:wild-holoscript", {
      action: "wild_holoscript_intake_applied",
      status: state.wildHoloScriptStatus,
      files: state.wildHoloScriptFileCount,
      holo: state.wildHoloScriptHoloCount,
      hs: state.wildHoloScriptHsCount,
      hsplus: state.wildHoloScriptHsplusCount,
      frontier_syntax: state.wildHoloScriptFrontierSyntaxCount,
      adapter_needed: state.wildHoloScriptAdapterNeededCount,
      canonical_candidates: state.wildHoloScriptCanonicalCandidateCount,
      flagships: state.wildHoloScriptFlagshipCount,
      top_pattern: state.wildHoloScriptTopPattern,
      top_flagship: state.wildHoloScriptTopFlagship,
      next_move: state.wildHoloScriptNextMove,
      read_only_scan: receipt.invariants.readOnlyScan,
      source_files_mutated: receipt.invariants.sourceFilesMutated,
      adapter_required_for_execution: receipt.invariants.adapterRequiredForExecution,
      receipt_required: true
    })
  }

  action queue_stop_plan(stopPlan) {
    state.stopPlanCount = state.stopPlanCount + 1
    state.pendingApprovals = state.pendingApprovals + 1
    state.operatingStage = "approve"
    state.nextMove = "review_cleanup_plan"
    emit("holoshell:approval", {
      action: "stop_plan_queued",
      stop_plan: stopPlan,
      approval_required: true,
      automatic_termination_allowed: false,
      receipt_required: true
    })
  }

  action record_pilot_receipt(receipt) {
    state.activePilot = receipt.pilot
    state.pilotReceiptCount = state.pilotReceiptCount + 1
    state.receiptCount = state.receiptCount + 1
    state.operatingStage = "receive"
    emit("holoshell:pilot", {
      action: "pilot_receipt_recorded",
      pilot: receipt.pilot,
      receipt: receipt,
      witness_state: receipt.status,
      trust_state: receipt.trustState || "partial"
    })
  }

  action apply_os_ui_capture(capture) {
    state.capturedWindowCount = capture.summary.windowCount
    state.capturedControlCount = capture.summary.controlCount
    state.capturedGeometryNodeCount = capture.summary.geometryNodeCount
    state.osUiActionBridgeStatus = capture.summary.actionBridgeStatus
    state.activeShellObject = "captured-ui"
    emit("holoshell:os-ui-capture", {
      action: "legacy_ui_capture_applied",
      windows: state.capturedWindowCount,
      controls: state.capturedControlCount,
      geometry_nodes: state.capturedGeometryNodeCount,
      action_bridge: state.osUiActionBridgeStatus,
      mutating_actions_executed: false,
      receipt: capture.receipt
    })
  }

  action apply_program_registry(registry) {
    state.programRegistryStatus = registry.summary.status
    state.installedProgramCount = registry.summary.programCount
    state.launchableProgramCount = registry.summary.launchableProgramCount
    state.startMenuProgramCount = registry.summary.startMenuProgramCount
    state.appPathProgramCount = registry.summary.appPathProgramCount
    state.activeShellObject = "programs"
