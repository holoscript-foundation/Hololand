// HoloShell Desktop Control Bridge
//
// Source contract for desktop-app control planning. Brittney remains the user
// facing operator; Fara is free to chat and co-plan with Brittney as a read-only
// peer. Fara provides GUI/visual grounding only when a screenshot or
// coordinate-bearing control step is needed. This bridge supports preflight and
// HoloGate consent-token staging. Public open_url is the first admitted action
// executor lane; consent is bound to the exact preflight target fingerprint, and
// every other host mutation still requires a later admitted action executor receipt.

composition "HoloShell Desktop Control Bridge" {
  config {
    title: "HoloShell Desktop Control Bridge"
    product: "HoloShell"
    sourceLayer: "HoloScript"
    runtimeSurface: "Brittney Studio desktop app"
    planEndpoint: "POST /api/desktop-control/plan"
    statusEndpoint: "GET /api/desktop-control/bridge"
    bridgeReportEndpoint: "POST /api/desktop-control/bridge/report"
    daemonStatusEndpoint: "GET http://127.0.0.1:8751/api/desktop-control/bridge"
    daemonFallbackStatusEndpoint: "GET http://127.0.0.1:8752/api/desktop-control/bridge"
    daemonTertiaryStatusEndpoint: "GET http://127.0.0.1:8753/api/desktop-control/bridge"
    daemonPreflightEndpoint: "POST http://127.0.0.1:8751/api/desktop-control/preflight"
    daemonFallbackPreflightEndpoint: "POST http://127.0.0.1:8752/api/desktop-control/preflight"
    daemonTertiaryPreflightEndpoint: "POST http://127.0.0.1:8753/api/desktop-control/preflight"
    daemonGestureProofEndpoint: "POST http://127.0.0.1:8751/api/desktop-control/gesture-proof"
    daemonFallbackGestureProofEndpoint: "POST http://127.0.0.1:8752/api/desktop-control/gesture-proof"
    daemonTertiaryGestureProofEndpoint: "POST http://127.0.0.1:8753/api/desktop-control/gesture-proof"
    daemonConsentTokenEndpoint: "POST http://127.0.0.1:8751/api/desktop-control/consent-token"
    daemonFallbackConsentTokenEndpoint: "POST http://127.0.0.1:8752/api/desktop-control/consent-token"
    daemonTertiaryConsentTokenEndpoint: "POST http://127.0.0.1:8753/api/desktop-control/consent-token"
    daemonExecuteEndpoint: "POST http://127.0.0.1:8751/api/desktop-control/execute"
    daemonFallbackExecuteEndpoint: "POST http://127.0.0.1:8752/api/desktop-control/execute"
    daemonTertiaryExecuteEndpoint: "POST http://127.0.0.1:8753/api/desktop-control/execute"
    chatEndpoint: "POST /api/brittney/chat"
    bridgeScript: "scripts/holoshell-desktop-control-plan.mjs"
    daemonScript: "scripts/holoshell-laptop-desktop-bridge.mjs"
    hardwareActionExecutorScript: "scripts/holoshell-action-executor.mjs"
    admittedExecutorActions: ["open_url"]
    latestPlanReceipt: ".tmp/holoshell/desktop-control-latest.json"
    latestPlanBootstrap: ".tmp/holoshell/desktop-control-latest.js"
    latestBridgeReport: ".tmp/holoshell/desktop-control-bridge/latest-status.json"
    latestBridgeReportFreshnessMs: 120000
    preflightReceiptDir: ".tmp/holoshell/desktop-control-bridge/preflights"
    primaryOperator: "brittney"
    peerChatLane: "fara_peer_chat"
    peerChatParticipants: ["brittney", "fara"]
    peerChatPermissionEnvelope: "read_only"
    visualGroundingLane: "fara_gui_grounding"
    visualGroundingModel: "fara:7b"
    fallbackVisionModel: "qwen3-vl:4b"
    executionDefault: "staged_not_run"
  }

  state {
    controlStatus: "idle"
    currentPlanId: ""
    currentIntent: ""
    peerChatAllowed: true
    peerChatPermissionEnvelope: "read_only"
    modelLane: "fara_gui_grounding"
    recommendedModel: "fara:7b"
    bridgeStatus: "awaiting_laptop_daemon"
    lastBridgeReportId: ""
    lastBridgeHeartbeat: ""
    lastPreflightId: ""
    lastConsentTokenId: ""
    lastExecutionId: ""
    lastHardwareActionId: ""
    screenshotRequired: true
    permissionEnvelope: "guarded_execute"
    approvalRequired: true
    executionDefault: "staged_not_run"
    lastReceiptPath: ".tmp/holoshell/desktop-control-latest.json"
  }

  channel "holoshell:desktop-control:plan" {
    type: "request_response"
    priority: "critical"
    description: "Brittney turns desktop-control intent into a receipt-backed plan"
  }

  channel "holoshell:desktop-control:fara-grounding" {
    type: "append_only"
    priority: "high"
    description: "Fara GUI grounding requests for screenshot/coordinate-bearing actions"
  }

  channel "holoshell:fara:brittney-peer-chat" {
    type: "append_only"
    priority: "high"
    description: "Free read-only Fara and Brittney peer chat for coordination before any desktop action"
  }

  channel "holoshell:desktop-control:execution-request" {
    type: "request_response"
    priority: "critical"
    description: "Guarded execution request created only after explicit approval"
  }

  channel "holoshell:desktop-control:bridge-status" {
    type: "append_only"
    priority: "high"
    description: "Browser-proxied laptop bridge status reports received by the Jetson surface"
  }

  channel "holoshell:desktop-control:preflight" {
    type: "append_only"
    priority: "critical"
    description: "Laptop bridge preflight receipts for desktop action proposals"
  }

  channel "holoshell:desktop-control:consent-token" {
    type: "append_only"
    priority: "critical"
    description: "HoloGate consent tokens bound to exact preflight receipts"
  }

  channel "holoshell:desktop-control:gesture-proof" {
    type: "request_response"
    priority: "critical"
    description: "Fresh physical keypress proofs bound to a preflight challenge nonce"
  }

  channel "holoshell:desktop-control:execution-staging" {
    type: "append_only"
    priority: "critical"
    description: "Approved execution staging receipts that still do not mutate the OS"
  }

  channel "holoshell:desktop-control:open-url-execution" {
    type: "append_only"
    priority: "critical"
    description: "Admitted public open_url executions through the hardware action executor"
  }

  template "DesktopControlPlan" {
    type: "desktop_control_plan"
    actor: "brittney"
    planner: "fara_gui_grounding"
    intent: ""
    planId: ""
    screenshotRequired: true
    allowedActionTypes: ["inspect_screen", "focus_window", "launch_app", "open_url", "click_control", "type_text", "hotkey"]
    permissionEnvelope: "guarded_execute"
    approvalRequired: true
    executionDefault: "staged_not_run"
    receiptRequired: true
  }

  template "LaptopDesktopBridgeStatus" {
    type: "desktop_control_bridge_status"
    schemaVersion: "hololand.holoshell.laptop-desktop-bridge.v0.1.0"
    status: "ready"
    url: "http://127.0.0.1:8751"
    hostRole: "laptop_desktop_bridge"
    modelLane: "fara_gui_grounding"
    capabilities: ["bridge_status", "desktop_action_preflight", "consent_token_issue", "consent_token_verify", "approved_execution_staging", "admitted_open_url_executor", "execution_refusal", "receipt_write"]
    destructiveActionsTaken: false
    approvalRequiredForDesktopAutomation: true
    latestStatusReceipt: ".tmp/holoshell/desktop-control-bridge/latest-status.json"
    liveFeedConsumesLatestStatus: true
    maxFreshnessMs: 120000
  }

  template "DesktopControlPreflight" {
    type: "desktop_control_preflight"
    schemaVersion: "hololand.holoshell.desktop-control-preflight.v0.1.0"
    preflightId: ""
    planId: ""
    modelLane: "fara_gui_grounding"
    permissionEnvelope: "guarded_execute"
    executionAllowed: false
    consentRequired: true
    consentChallenge: ""
    consentGesture: { schemaVersion: "hololand.holoshell.consent-gesture.v0.1.0", challenge: "", key: "F8", ttlMs: 30000, proofRequired: true }
    target: { operation: "", url: "", windowTitle: "", handle: "", controlName: "", text: "", hotkey: "", x: "", y: "" }
    targetFingerprint: ""
    targetUrlClassification: "not_applicable"
    requiresExactExecutionTarget: true
    destructiveActionsTaken: false
    desktopAutomationExecuted: false
    receiptRequired: true
  }

  template "DesktopControlConsentToken" {
    type: "desktop_control_consent_token"
    schemaVersion: "hololand.holoshell.desktop-control-consent-token.v0.1.0"
    tokenId: ""
    preflightId: ""
    preflightReceiptHash: ""
    targetFingerprint: ""
    tokenBoundToTargetFingerprint: true
    consentChallenge: ""
    operation: ""
    permissionEnvelope: "guarded_execute"
    freshUserGestureObserved: true
    gestureVerified: true
    gestureProofSchema: "hololand.holoshell.consent-gesture.v0.1.0"
    futureGestureProofAllowed: false
    futureClockSkewAllowanceMs: 5000
    maxGestureProofTtlMs: 30000
    excessiveGestureProofTtlAllowed: false
    executionAllowed: true
    executionMode: "staged_receipt_only_until_action_executor"
    requiresExactExecutionTarget: true
    preflightTargetFingerprint: ""
    executionTargetFingerprint: ""
    executionTargetMatchVerified: false
    destructiveActionsTaken: false
    desktopAutomationExecuted: false
    receiptRequired: true
  }

  template "DesktopControlExecutionStaging" {
    type: "desktop_control_execution"
    schemaVersion: "hololand.holoshell.desktop-control-execution.v0.1.0"
    executionId: ""
    preflightId: ""
    consentTokenId: ""
    operation: ""
    status: "approved_execution_staged"
    executionAllowed: true
    executionMode: "staged_receipt_only_until_action_executor"
    destructiveActionsTaken: false
    desktopAutomationExecuted: false
    receiptRequired: true
  }

  template "DesktopControlOpenUrlExecution" {
    type: "desktop_control_open_url_execution"
    schemaVersion: "hololand.holoshell.desktop-control-execution.v0.1.0"
    executionId: ""
    preflightId: ""
    consentTokenId: ""
    operation: "open_url"
    urlClassification: "public_web"
    requiresExactExecutionTarget: true
    executionTargetMatchVerified: true
    executionMode: "admitted_open_url_executor"
    hardwareActionExecutor: "scripts/holoshell-action-executor.mjs"
    desktopAutomationExecuted: true
    destructiveActionsTaken: false
    receiptRequired: true
  }

  template "FaraGroundingRequest" {
    type: "fara_grounding_request"
    modelLane: "fara_gui_grounding"
    recommendedModel: "fara:7b"
    fallbackModel: "qwen3-vl:4b"
    requiresScreenshot: true
    outputFormat: "json_action_plan"
    coordinateSystem: "screen_pixels"
    mayExecute: false
  }

  template "FaraBrittneyPeerChat" {
    type: "fara_brittney_peer_chat"
    participants: ["brittney", "fara"]
    lane: "fara_peer_chat"
    permissionEnvelope: "read_only"
    approvalRequired: false
    mayDiscussDesktopPlans: true
    mayInspectReceipts: true
    mayExecuteDesktopActions: false
    destructiveActionsTaken: false
    desktopAutomationExecuted: false
    receiptRequired: true
  }

  template "DesktopControlReceipt" {
    type: "receipt"
    receiptType: "hololand.holoshell.desktop-control-plan.v0.1.0"
    actor: "brittney"
    modelLane: "fara_gui_grounding"
    destructiveActionsTaken: false
    approvalRequired: true
    executionDefault: "staged_not_run"
    rollback: "not_applicable_for_plan_only"
  }

  policy "ReadOnlyDesktopInspection" {
    appliesTo: ["inspect_screen", "summarize_window", "identify_control", "explain_next_step"]
    permissionEnvelope: "read_only"
    approvalRequired: false
    screenshotAllowed: true
    receiptRequired: true
  }

  policy "FaraPeerChatIsFree" {
    appliesTo: ["fara_brittney_chat", "planning_dialogue", "receipt_discussion", "desktop_plan_discussion"]
    participants: ["brittney", "fara"]
    lane: "fara_peer_chat"
    permissionEnvelope: "read_only"
    approvalRequired: false
    mayDiscussDesktopPlans: true
    mayExecuteDesktopActions: false
    desktopMutationRequires: ["desktop_action_preflight", "fresh_user_gesture", "consent_token", "execution_receipt"]
    destructiveActionsTaken: false
    desktopAutomationExecuted: false
    receiptRequired: true
  }

  policy "GuardedDesktopControl" {
    appliesTo: ["focus_window", "launch_app", "open_url", "click_control", "type_text", "hotkey"]
    permissionEnvelope: "guarded_execute"
    approvalRequired: true
    requiresFreshUserGesture: true
    screenshotRequired: true
    receiptRequired: true
    executionDefault: "staged_not_run"
  }

  policy "LaptopBridgePreflightOnly" {
    appliesTo: ["desktop_action_preflight", "execution_refusal", "receipt_write"]
    hostRole: "laptop_desktop_bridge"
    statusReportAllowedWithoutConsent: true
    statusEndpointWritesLatestReceipt: true
    latestStatusReceipt: ".tmp/holoshell/desktop-control-bridge/latest-status.json"
    liveFeedConsumesLatestStatus: true
    operatorTerminalAcceptsReadyWhenFresh: true
    staleStatusMustRemainVisible: true
    maxFreshnessMs: 120000
    preflightAllowedWithoutConsent: true
    executionAllowedWithoutConsent: false
    desktopAutomationExecutedByDaemonDefault: false
    destructiveActionsTaken: false
    receiptRequired: true
  }

  policy "HoloGateConsentTokenStaging" {
    appliesTo: ["consent_token_issue", "consent_token_verify", "approved_execution_staging"]
    hostRole: "laptop_desktop_bridge"
    holoGateStages: ["identify", "scope", "log"]
    requiresExactPreflightReceipt: true
    requiresFreshUserGesture: true
    requiresPreflightChallengeNonce: true
    rejectFutureGestureProofs: true
    futureClockSkewAllowanceMs: 5000
    rejectExcessiveGestureProofTtl: true
    maxGestureProofTtlMs: 30000
    tokenBoundToOperation: true
    tokenBoundToPreflightHash: true
    tokenBoundToTargetFingerprint: true
    tokenBoundToConsentChallenge: true
    executionAllowedWithValidToken: true
    osMutationAllowedByThisLane: false
    desktopAutomationExecutedByDaemonDefault: false
    destructiveActionsTaken: false
    receiptRequired: true
  }

  policy "AdmittedOpenUrlExecutor" {
    appliesTo: ["open_url"]
    hostRole: "laptop_desktop_bridge"
    hardwareActionExecutor: "scripts/holoshell-action-executor.mjs"
    requiresExactPreflightReceipt: true
    requiresFreshUserGesture: true
    requiresPreflightChallengeNonce: true
    requiresValidConsentToken: true
    requiresExactExecutionTarget: true
    requiresTargetFingerprintMatch: true
    allowedUrlClassification: "public_web"
    blockedUrlClassifications: ["credential_adjacent", "break_glass_payment", "blocked_scheme", "invalid_url"]
    executionMode: "admitted_open_url_executor"
    destructiveActionsTaken: false
    receiptRequired: true
  }

  policy "BreakGlassDesktopControl" {
    appliesTo: ["credential_entry", "account_change", "purchase", "delete_data", "send_message", "install_software", "registry_change"]
    permissionEnvelope: "break_glass"
    approvalRequired: true
    founderReviewRequired: true
    executionDefault: "blocked_until_review"
    receiptRequired: true
  }

  action plan_desktop_control(request) {
    state.currentIntent = request.intent
    state.controlStatus = "plan_ready"
    state.currentPlanId = request.planId
    state.permissionEnvelope = request.permissionEnvelope
    state.approvalRequired = request.permissionEnvelope != "read_only"
    state.screenshotRequired = request.screenshotRequired
    emit("holoshell:desktop-control:plan", {
      action: "desktop_control_plan_created",
      intent: state.currentIntent,
      plan_id: state.currentPlanId,
      model_lane: state.modelLane,
      recommended_model: state.recommendedModel,
      permission_envelope: state.permissionEnvelope,
      approval_required: state.approvalRequired,
      screenshot_required: state.screenshotRequired,
      execution_default: state.executionDefault,
      receipt_required: true
    })
  }

  action request_fara_grounding(plan) {
    emit("holoshell:desktop-control:fara-grounding", {
      action: "fara_grounding_requested",
      plan_id: plan.planId,
      model_lane: "fara_gui_grounding",
      recommended_model: "fara:7b",
      fallback_model: "qwen3-vl:4b",
      requires_screenshot: true,
      may_execute: false,
      receipt_required: true
    })
  }

  action record_fara_brittney_peer_chat(turn) {
    emit("holoshell:fara:brittney-peer-chat", {
      action: "fara_brittney_peer_chat_recorded",
      lane: "fara_peer_chat",
      participants: ["brittney", "fara"],
      permission_envelope: "read_only",
      approval_required: false,
      may_discuss_desktop_plans: true,
      may_execute_desktop_actions: false,
      destructive_actions_taken: false,
      desktop_automation_executed: false,
      receipt_required: true
    })
  }

  action report_laptop_bridge_status(report) {
    state.bridgeStatus = report.status
    state.lastBridgeReportId = report.reportId
    state.lastBridgeHeartbeat = report.generatedAt
    emit("holoshell:desktop-control:bridge-status", {
      action: "laptop_desktop_bridge_reported",
      report_id: state.lastBridgeReportId,
      status: state.bridgeStatus,
      url: report.url,
      host_role: "laptop_desktop_bridge",
      destructive_actions_taken: false,
      approval_required_for_desktop_automation: true,
      receipt_required: true
    })
  }

  action preflight_desktop_control(preflight) {
    state.lastPreflightId = preflight.preflightId
    state.permissionEnvelope = preflight.permissionEnvelope
    state.approvalRequired = preflight.consentRequired
    emit("holoshell:desktop-control:preflight", {
      action: "desktop_control_preflight_created",
      preflight_id: state.lastPreflightId,
      plan_id: preflight.planId,
      model_lane: "fara_gui_grounding",
      permission_envelope: state.permissionEnvelope,
      execution_allowed: false,
      consent_required: true,
      target_fingerprint: preflight.targetFingerprint,
      requires_exact_execution_target: preflight.requiresExactExecutionTarget,
      destructive_actions_taken: false,
      desktop_automation_executed: false,
      receipt_required: true
    })
  }

  action issue_desktop_control_consent(token) {
    state.lastConsentTokenId = token.tokenId
    emit("holoshell:desktop-control:consent-token", {
      action: "desktop_control_consent_token_issued",
      token_id: state.lastConsentTokenId,
      preflight_id: token.preflightId,
      operation: token.operation,
      permission_envelope: token.permissionEnvelope,
      target_fingerprint: token.targetFingerprint,
      token_bound_to_target_fingerprint: token.tokenBoundToTargetFingerprint,
      execution_allowed: token.executionAllowed,
      execution_mode: "staged_receipt_only_until_action_executor",
      destructive_actions_taken: false,
      desktop_automation_executed: false,
      receipt_required: true
    })
  }

  action stage_desktop_control_execution(execution) {
    state.lastExecutionId = execution.executionId
    emit("holoshell:desktop-control:execution-staging", {
      action: "desktop_control_execution_staged",
      execution_id: state.lastExecutionId,
      preflight_id: execution.preflightId,
      consent_token_id: execution.consentTokenId,
      operation: execution.operation,
      execution_allowed: true,
      execution_mode: "staged_receipt_only_until_action_executor",
      preflight_target_fingerprint: execution.preflightTargetFingerprint,
      execution_target_match_verified: execution.executionTargetMatchVerified,
      destructive_actions_taken: false,
      desktop_automation_executed: false,
      receipt_required: true
    })
  }

  action execute_open_url_after_consent(execution) {
    state.lastExecutionId = execution.executionId
    state.lastHardwareActionId = execution.hardwareAction.actionId
    emit("holoshell:desktop-control:open-url-execution", {
      action: "desktop_control_open_url_executed",
      execution_id: state.lastExecutionId,
      preflight_id: execution.preflightId,
      consent_token_id: execution.consentTokenId,
      hardware_action_id: state.lastHardwareActionId,
      target_url_host: execution.hardwareAction.targetUrlHost,
      preflight_target_fingerprint: execution.preflightTargetFingerprint,
      execution_target_fingerprint: execution.executionTargetFingerprint,
      execution_target_match_verified: execution.executionTargetMatchVerified,
      execution_mode: "admitted_open_url_executor",
      desktop_automation_executed: true,
      destructive_actions_taken: false,
      receipt_required: true
    })
  }

  action request_guarded_execution(plan, approval) {
    emit("holoshell:desktop-control:execution-request", {
      action: "desktop_control_execution_requested",
      plan_id: plan.planId,
      approval_receipt: approval.receiptId,
      permission_envelope: plan.permissionEnvelope,
      approval_required: true,
      destructive_actions_taken: false,
      receipt_required: true
    })
  }
}
