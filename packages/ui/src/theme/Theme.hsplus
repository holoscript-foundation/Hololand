// =============================================================================
// THEME MANAGER MODULE
// =============================================================================

/**
 * Manages application themes
 */
module ThemeManager {
  @state {
    currentTheme: Theme = DEFAULT_THEME,
    availableThemes: Map<string, Theme> = new Map(),
    listeners: Set<(theme: Theme) => void> = new Set()
  }

  @action initialize() {
    // Register built-in themes
    self.availableThemes.set("default", DEFAULT_THEME)
    self.availableThemes.set("dark", DARK_THEME)
    self.availableThemes.set("vr", VR_THEME)
  }

  /**
   * Get the current theme
   */
  @computed getTheme() -> Theme {
    return self.currentTheme
  }

  /**
   * Set the active theme by name
   */
  @action setTheme(name: string) {
    let theme = self.availableThemes.get(name)
    if theme {
      self.currentTheme = theme
      self.notifyListeners()
    } else {
      console.warn(`[ThemeManager] Theme '${name}' not found`)
    }
  }

  /**
   * Set a custom theme
   */
  @action setCustomTheme(theme: Theme) {
    self.currentTheme = theme
    self.notifyListeners()
  }

  /**
   * Register a new theme
   */
  @action registerTheme(name: string, theme: Theme) {
    self.availableThemes.set(name, { ...theme, name: name })
  }

  /**
   * Get list of available theme names
   */
  @computed getAvailableThemes() -> array<string> {
    return Array.from(self.availableThemes.keys())
  }

  /**
   * Subscribe to theme changes
   */
  @action subscribe(listener: (theme: Theme) => void) {
    self.listeners.add(listener)
    return () => self.listeners.delete(listener)
  }

  /**
   * Notify all listeners of theme change
   */
  @method notifyListeners() {
    for listener in self.listeners {
      listener(self.currentTheme)
    }
  }

  // ==========================================================================
  // COLOR UTILITIES
  // ==========================================================================

  /**
   * Parse hex color to RGB
   */
  @method hexToRgb(hex: string) -> { r: number, g: number, b: number } | null {
    let result = /^#?([a-f\d]{2})([a-f\d]{2})([a-f\d]{2})$/i.exec(hex)
    if result {
      return {
        r: parseInt(result[1], 16),
        g: parseInt(result[2], 16),
        b: parseInt(result[3], 16)
      }
    }
    return null
  }

  /**
   * Convert RGB to hex
   */
  @method rgbToHex(r: number, g: number, b: number) -> string {
    return "#" + [r, g, b].map(x => {
      let hex = Math.round(x).toString(16)
      return hex.length == 1 ? "0" + hex : hex
    }).join("")
  }

  /**
   * Lighten a color by a percentage
   */
  @method lighten(color: string, percent: number) -> string {
    let rgb = self.hexToRgb(color)
    if !rgb { return color }

    let factor = percent / 100
    return self.rgbToHex(
      Math.min(255, rgb.r + (255 - rgb.r) * factor),
      Math.min(255, rgb.g + (255 - rgb.g) * factor),
      Math.min(255, rgb.b + (255 - rgb.b) * factor)
    )
  }

  /**
   * Darken a color by a percentage
   */
  @method darken(color: string, percent: number) -> string {
    let rgb = self.hexToRgb(color)
    if !rgb { return color }

    let factor = 1 - percent / 100
    return self.rgbToHex(
      rgb.r * factor,
      rgb.g * factor,
      rgb.b * factor
    )
  }

  /**
   * Add alpha to a color
   */
  @method withAlpha(color: string, alpha: number) -> string {
    let rgb = self.hexToRgb(color)
    if !rgb { return color }

    return `rgba(${rgb.r}, ${rgb.g}, ${rgb.b}, ${alpha})`
  }

  /**
   * Get contrast color (black or white)
   */
  @method getContrastColor(backgroundColor: string) -> string {
    let rgb = self.hexToRgb(backgroundColor)
    if !rgb { return "#000000" }

    // Calculate relative luminance
    let luminance = (0.299 * rgb.r + 0.587 * rgb.g + 0.114 * rgb.b) / 255
    return luminance > 0.5 ? "#000000" : "#ffffff"
  }
}

// =============================================================================
// SINGLETON
// =============================================================================

let _themeManager: typeof ThemeManager = null

function getThemeManager() -> typeof ThemeManager {
  if !_themeManager {
    ThemeManager.initialize()
    _themeManager = ThemeManager
  }
  return _themeManager
}

// =============================================================================
// EXPORTS
// =============================================================================

export {
  // Themes
  DEFAULT_THEME,
  DARK_THEME,
  VR_THEME,

  // Default values
  DEFAULT_COLORS,
  DEFAULT_SPACING,
  DEFAULT_TYPOGRAPHY,
  DEFAULT_BORDERS,

  // Manager
  ThemeManager,
  getThemeManager
}
