  primaryLight: "#5dade2",
  primaryDark: "#2980b9",
  secondary: "#2ecc71",
  secondaryLight: "#58d68d",
  secondaryDark: "#27ae60",
  background: "#ffffff",
  surface: "#f5f5f5",
  surfaceVariant: "#eeeeee",
  textPrimary: "#333333",
  textSecondary: "#666666",
  textDisabled: "#999999",
  textOnPrimary: "#ffffff",
