{
  "name": "@hololand/ai-bridge",
  "version": "1.0.0-alpha.1",
  "description": "AI Bridge for Natural Language → HoloScript Translation - Build in VR using natural language",
  "main": "./dist/index.js",
  "module": "./dist/index.mjs",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.mjs",
      "require": "./dist/index.js"
    }
  },
  "files": [
    "dist",
    "README.md",
    "LICENSE"
  ],
  "scripts": {
    "build": "tsup --treeshake",
    "dev": "tsup --watch",
    "test": "vitest run",
    "test:watch": "vitest",
    "typecheck": "tsc --noEmit && eslint src --ext .ts",
    "lint": "tsc --noEmit && eslint src --ext .ts",
    "format": "prettier --write \"src/**/*.ts\" && eslint --fix src",
    "clean": "rm -rf dist"
  },
  "keywords": [
    "hololand",
    "holoscript",
    "vr",
    "virtual-reality",
    "ai",
    "natural-language",
    "voice-commands",
    "code-generation",
    "webxr",
    "metaverse"
  ],
  "author": "Hololand Contributors",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/brianonbased-dev/Hololand.git",
    "directory": "packages/ai-bridge"
  },
  "bugs": {
    "url": "https://github.com/brianonbased-dev/Hololand/issues"
  },
  "homepage": "https://github.com/brianonbased-dev/Hololand#readme",
  "dependencies": {
    "@hololand/logger": "workspace:*",
    "@holoscript/cli": "^2.0.1",
    "@holoscript/core": "^2.0.0"
  },
  "devDependencies": {
    "@types/node": "^20.10.0",
    "@typescript-eslint/eslint-plugin": "^6.13.0",
    "@typescript-eslint/parser": "^6.13.0",
    "eslint": "^8.55.0",
    "eslint-config-prettier": "^9.1.0",
    "eslint-plugin-prettier": "^5.0.1",
    "prettier": "^3.1.1",
    "tsup": "^8.0.1",
    "typescript": "^5.3.3",
    "vitest": "^1.0.4"
  },
  "peerDependencies": {
    "@hololand/core": "^1.0.0-alpha.1"
  },
  "engines": {
    "node": ">=18.0.0"
  }
}
