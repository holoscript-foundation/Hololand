{
  "name": "@hololand/devtools",
  "version": "1.0.0",
  "description": "Developer tools for Hololand - performance profiler, visual debugger, network inspector, and in-VR console",
  "type": "module",
  "main": "./dist/index.js",
  "module": "./dist/index.mjs",
  "types": "./dist/index.d.ts",
  "sideEffects": false,
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.mjs",
      "require": "./dist/index.js"
    }
  },
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch",
    "test": "echo 'No tests yet' && exit 0",
    "test:watch": "vitest"
  },
  "keywords": [
    "hololand",
    "devtools",
    "profiler",
    "debugger",
    "performance",
    "vr-debugging",
    "ar-debugging",
    "metaverse"
  ],
  "author": "Hololand Team",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/hololand/hololand.git",
    "directory": "packages/devtools"
  },
  "devDependencies": {
    "tsup": "^8.0.1",
    "typescript": "^5.3.3",
    "vitest": "^1.0.0"
  }
}
