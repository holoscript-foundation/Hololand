{
  "$schema": "https://raw.githubusercontent.com/martinring/tmlanguage/master/tmlanguage.json",
  "name": "HoloScript Plus",
  "scopeName": "source.hsplus",
  "patterns": [
    { "include": "#comments" },
    { "include": "#strings" },
    { "include": "#numbers" },
    { "include": "#keywords" },
    { "include": "#types" },
    { "include": "#networked" },
    { "include": "#physics" },
    { "include": "#procedural" },
    { "include": "#systems" },
    { "include": "#objects" },
    { "include": "#properties" },
    { "include": "#functions" },
    { "include": "#constants" },
    { "include": "#operators" }
  ],
  "repository": {
    "comments": {
      "patterns": [
        {
          "name": "comment.line.double-slash.hsplus",
          "match": "//.*$"
        },
        {
          "name": "comment.block.hsplus",
          "begin": "/\\*",
          "end": "\\*/"
        }
      ]
    },
    "strings": {
      "patterns": [
        {
          "name": "string.quoted.double.hsplus",
          "begin": "\"",
          "end": "\"",
          "patterns": [
            {
              "name": "constant.character.escape.hsplus",
              "match": "\\\\."
            }
          ]
        },
        {
          "name": "string.quoted.single.hsplus",
          "begin": "'",
          "end": "'",
          "patterns": [
            {
              "name": "constant.character.escape.hsplus",
              "match": "\\\\."
            }
          ]
        }
      ]
    },
    "numbers": {
      "patterns": [
        {
          "name": "constant.numeric.hex.hsplus",
          "match": "#[0-9A-Fa-f]{3,8}\\b"
        },
        {
          "name": "constant.numeric.float.hsplus",
          "match": "\\b\\d+\\.\\d+\\b"
        },
        {
          "name": "constant.numeric.integer.hsplus",
          "match": "\\b\\d+\\b"
        },
        {
          "name": "constant.numeric.angle.hsplus",
          "match": "\\b-?\\d+deg\\b"
        },
        {
          "name": "constant.numeric.time.hsplus",
          "match": "\\b\\d+(\\.\\d+)?(s|ms)\\b"
        },
        {
          "name": "constant.numeric.frequency.hsplus",
          "match": "\\b\\d+hz\\b"
        }
      ]
    },
    "keywords": {
      "patterns": [
        {
          "name": "keyword.control.hsplus",
          "match": "\\b(if|else|for|while|return|break|continue|switch|case|default|await|async)\\b"
        },
        {
          "name": "keyword.other.import.hsplus",
          "match": "\\b(import|export|from)\\b"
        },
        {
          "name": "storage.type.hsplus",
          "match": "\\b(let|const|var|function)\\b"
        }
      ]
    },
    "types": {
      "patterns": [
        {
          "name": "entity.name.type.object.hsplus",
          "match": "\\b(cube|sphere|cylinder|plane|box|mesh|model|text|panel|button|slider|image|light|camera|audio|video|particle)\\b"
        },
        {
          "name": "entity.name.type.component.hsplus",
          "match": "\\b(animation|trigger|collider|rigidbody|material|texture|shader)\\b"
        }
      ]
    },
    "networked": {
      "patterns": [
        {
          "name": "keyword.other.networked.hsplus",
          "match": "\\b(networked_object|networked|synced|sync_rate|interpolation|authority|owner|replicated|rpc|broadcast|multicast)\\b"
        },
        {
          "name": "entity.name.type.network.hsplus",
          "match": "\\b(NetworkedWorldState|LocalNetworking|PartySystem)\\b"
        },
        {
          "name": "variable.other.network.hsplus",
          "match": "\\b(max_players|discovery|local_network|peer_to_peer|server_authoritative|client_predicted)\\b"
        },
        {
          "name": "variable.other.event.network.hsplus",
          "match": "\\b(on_player_join|on_player_leave|on_sync|on_disconnect|on_reconnect)\\b"
        }
      ]
    },
    "physics": {
      "patterns": [
        {
          "name": "keyword.other.physics.hsplus",
          "match": "\\b(constraint|joint|hinge|slider|spring|ball|fixed|distance|rope|chain)\\b"
        },
        {
          "name": "entity.name.type.physics.hsplus",
          "match": "\\b(PhysicsConstraints)\\b"
        },
        {
          "name": "variable.other.physics.hsplus",
          "match": "\\b(body_a|body_b|anchor_a|anchor_b|axis|limits|stiffness|damping|motor|motor_speed|motor_force|break_force|break_torque)\\b"
        }
      ]
    },
    "procedural": {
      "patterns": [
        {
          "name": "keyword.other.procedural.hsplus",
          "match": "\\b(terrain|generator|procedural|noise|perlin|simplex|voronoi|fractal|heightmap)\\b"
        },
        {
          "name": "entity.name.type.procedural.hsplus",
          "match": "\\b(ProceduralGeneration)\\b"
        },
        {
          "name": "variable.other.procedural.hsplus",
          "match": "\\b(seed|octaves|persistence|lacunarity|height_scale|water_level|biome|erosion)\\b"
        }
      ]
    },
    "systems": {
      "patterns": [
        {
          "name": "entity.name.type.system.hsplus",
          "match": "\\b(HoloScriptMarketplace|SceneVersionControl|LocalAnalytics|OfflineSync|ExampleWorlds)\\b"
        },
        {
          "name": "keyword.other.system.hsplus",
          "match": "\\b(snapshot|diff|merge|commit|branch|checkout|analytics|track|offline|sync|cache)\\b"
        }
      ]
    },
    "objects": {
      "patterns": [
        {
          "name": "entity.name.class.hsplus",
          "match": "\\b(cube|sphere|cylinder|plane|box|mesh|model|text|panel|button|slider|image|light|camera|audio|video|particle|animation|trigger|zone|portal|npc|item|world|scene|networked_object|constraint|terrain|party)\\s+([a-zA-Z_][a-zA-Z0-9_]*)\\s*\\{",
          "captures": {
            "1": { "name": "storage.type.hsplus" },
            "2": { "name": "entity.name.tag.hsplus" }
          }
        }
      ]
    },
    "properties": {
      "patterns": [
        {
          "name": "variable.other.property.hsplus",
          "match": "\\b(position|rotation|scale|size|color|opacity|material|texture|visible|enabled|interactive|velocity|mass|gravity|friction|restitution|static|kinematic|trigger|label|value|range|default|duration|delay|loop|easing|target|property|src|volume|pitch|spatial|radius|intensity|falloff|fov|near|far|rate|lifetime|speed|direction|spread|count|emission|type)\\b"
        },
        {
          "name": "variable.other.event.hsplus",
          "match": "\\b(on_click|on_hover|on_enter|on_exit|on_collision|on_trigger|on_start|on_update|on_end|on_change|on_complete)\\b"
        }
      ]
    },
    "functions": {
      "patterns": [
        {
          "name": "entity.name.function.hsplus",
          "match": "\\b([a-zA-Z_][a-zA-Z0-9_]*)\\s*\\("
        }
      ]
    },
    "constants": {
      "patterns": [
        {
          "name": "constant.language.boolean.hsplus",
          "match": "\\b(true|false)\\b"
        },
        {
          "name": "constant.language.null.hsplus",
          "match": "\\b(null|none|random)\\b"
        },
        {
          "name": "support.constant.material.hsplus",
          "match": "\\b(glass|metal|wood|plastic|fabric|stone|water|emissive|unlit|pbr)\\b"
        },
        {
          "name": "support.constant.easing.hsplus",
          "match": "\\b(linear|ease|ease-in|ease-out|ease-in-out|bounce|elastic|back)\\b"
        }
      ]
    },
    "operators": {
      "patterns": [
        {
          "name": "keyword.operator.assignment.hsplus",
          "match": "=|:|\\+=|-=|\\*=|/="
        },
        {
          "name": "keyword.operator.comparison.hsplus",
          "match": "==|!=|<=|>=|<|>"
        },
        {
          "name": "keyword.operator.arithmetic.hsplus",
          "match": "\\+|-|\\*|/|%"
        },
        {
          "name": "keyword.operator.logical.hsplus",
          "match": "&&|\\|\\||!"
        }
      ]
    }
  }
}
