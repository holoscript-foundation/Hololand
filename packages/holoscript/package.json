{
  "name": "@hololand/holoscript",
  "version": "0.1.0",
  "description": "HoloScript compiler - Text to VR code language",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.js"
    },
    "./parser/lexer": "./dist/parser/lexer.js",
    "./parser/parser": "./dist/parser/parser.js",
    "./compiler/r3f-compiler": "./dist/compiler/r3f-compiler.js",
    "./cli/build": "./dist/cli/build.js"
  },
  "bin": {
    "holoscript": "./bin/holoscript.js"
  },
  "scripts": {
    "build": "tsc",
    "cli": "node bin/holoscript.js",
    "cli:build": "node bin/holoscript.js build",
    "cli:watch": "node bin/holoscript.js build --watch",
    "compile": "node bin/holoscript.js build",
    "test": "vitest",
    "test:coverage": "vitest --coverage",
    "dev": "tsc --watch",
    "lint": "eslint src --ext .ts",
    "format": "prettier --write src"
  },
  "dependencies": {
    "@react-three/fiber": "^9.5.0",
    "chalk": "^5.3.0",
    "commander": "^11.0.0",
    "ora": "^8.0.1",
    "react": "^19.2.3",
    "react-dom": "^19.2.3"
  },
  "devDependencies": {
    "@react-three/drei": "^10.7.7",
    "@types/node": "^20.0.0",
    "@types/react": "^19.2.8",
    "@types/react-dom": "^19.2.3",
    "@types/three": "^0.182.0",
    "@typescript-eslint/eslint-plugin": "^6.0.0",
    "@typescript-eslint/parser": "^6.0.0",
    "eslint": "^8.0.0",
    "prettier": "^3.0.0",
    "ts-node": "^10.9.0",
    "typescript": "^5.0.0",
    "vitest": "^0.34.0"
  },
  "keywords": [
    "holoscript",
    "vr",
    "spatial-programming",
    "3d",
    "react-three-fiber",
    "compiler",
    "metaverse"
  ],
  "repository": {
    "type": "git",
    "url": "https://github.com/hololand/hololand",
    "directory": "packages/holoscript"
  },
  "license": "MIT",
  "author": "Hololand Team",
  "publishConfig": {
    "access": "public"
  },
  "files": [
    "dist",
    "bin",
    "README.md",
    "LICENSE"
  ]
}
