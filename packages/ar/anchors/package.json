{
  "name": "@hololand/ar-anchors",
  "version": "1.0.0",
  "description": "Coordinate system alignment for shared AR - QR codes, AprilTags, VPS, GPS anchors",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "type": "module",
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "types": "./dist/index.d.ts"
    },
    "./detectors": {
      "import": "./dist/detectors/index.js",
      "types": "./dist/detectors/index.d.ts"
    }
  },
  "scripts": {
    "build": "tsup src/index.ts src/detectors/index.ts --format esm --dts",
    "dev": "tsup src/index.ts --format esm --dts --watch",
    "test": "vitest run",
    "test:coverage": "vitest --coverage",
    "type-check": "tsc --noEmit"
  },
  "keywords": [
    "ar",
    "anchors",
    "qr-code",
    "apriltag",
    "vps",
    "coordinate-system",
    "hololand"
  ],
  "author": "Hololand",
  "license": "MIT",
  "dependencies": {
    "@hololand/logger": "workspace:*",
    "jsqr": "^1.4.0"
  },
  "devDependencies": {
    "@types/node": "^20.10.6",
    "tsup": "^8.0.2",
    "typescript": "^5.3.3",
    "vitest": "^1.1.0"
  }
}
