{
  "name": "@hololand/volumetric-bridge",
  "version": "0.1.0",
  "description": "NeRF, Gaussian Splatting, and photogrammetry loader for Three.js scenes",
  "type": "module",
  "main": "./dist/index.js",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "files": ["dist", "README.md"],
  "scripts": {
    "build": "tsup src/index.ts --format esm --dts",
    "dev": "tsup src/index.ts --format esm --dts --watch",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@holoscript/core": "^4.2.0"
  },
  "peerDependencies": {
    "three": ">=0.150.0",
    "@react-three/fiber": "^8.0.0"
  },
  "peerDependenciesMeta": {
    "@react-three/fiber": { "optional": true }
  },
  "devDependencies": {
    "@types/node": "^20.10.0",
    "@types/three": "^0.170.0",
    "three": "^0.170.0",
    "tsup": "^8.0.1",
    "typescript": "^5.3.2"
  },
  "keywords": ["volumetric", "nerf", "gaussian-splatting", "photogrammetry", "three.js", "hololand"],
  "license": "MIT"
}
