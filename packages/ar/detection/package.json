{
  "name": "@hololand/ar-detection",
  "version": "0.1.0",
  "description": "Pose detection for AR applications - BlazePose, MediaPipe, depth sensors",
  "type": "module",
  "main": "./dist/index.js",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    },
    "./blazepose": {
      "types": "./dist/blazepose/index.d.ts",
      "import": "./dist/blazepose/index.js"
    },
    "./mediapipe": {
      "types": "./dist/mediapipe/index.d.ts",
      "import": "./dist/mediapipe/index.js"
    },
    "./depth": {
      "types": "./dist/depth/index.d.ts",
      "import": "./dist/depth/index.js"
    }
  },
  "files": [
    "dist",
    "README.md"
  ],
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@hololand/logger": "workspace:*",
    "@mediapipe/tasks-vision": "^0.10.14"
  },
  "devDependencies": {
    "@types/node": "^20.10.0",
    "tsup": "^8.0.1",
    "typescript": "^5.3.2"
  },
  "peerDependencies": {
    "@tensorflow/tfjs": "^4.0.0",
    "@tensorflow-models/pose-detection": "^2.0.0"
  },
  "peerDependenciesMeta": {
    "@tensorflow/tfjs": {
      "optional": true
    },
    "@tensorflow-models/pose-detection": {
      "optional": true
    }
  },
  "keywords": [
    "ar",
    "pose-detection",
    "blazepose",
    "mediapipe",
    "skeleton",
    "hololand"
  ],
  "license": "MIT"
}
