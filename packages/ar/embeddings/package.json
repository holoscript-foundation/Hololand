{
  "name": "@hololand/ar-embeddings",
  "version": "0.1.0",
  "description": "Person re-identification embeddings for AR tracking",
  "type": "module",
  "main": "./dist/index.js",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "files": [
    "dist",
    "README.md"
  ],
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@hololand/logger": "workspace:*"
  },
  "peerDependencies": {
    "@tensorflow/tfjs": "^4.0.0",
    "onnxruntime-web": "^1.17.0"
  },
  "peerDependenciesMeta": {
    "@tensorflow/tfjs": {
      "optional": true
    },
    "onnxruntime-web": {
      "optional": true
    }
  },
  "devDependencies": {
    "@types/node": "^20.10.0",
    "tsup": "^8.0.1",
    "typescript": "^5.3.2"
  },
  "keywords": [
    "ar",
    "reid",
    "person-reidentification",
    "embeddings",
    "osnet",
    "hololand"
  ],
  "license": "MIT"
}
