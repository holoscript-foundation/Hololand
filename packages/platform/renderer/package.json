{
  "name": "@hololand/renderer",
  "version": "1.0.0",
  "description": "Three.js renderer for Hololand VR worlds with WebXR support",
  "main": "./dist/index.js",
  "module": "./dist/index.mjs",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.mjs",
      "require": "./dist/index.js"
    }
  },
  "files": [
    "dist",
    "README.md"
  ],
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch",
    "test": "vitest run --config vitest.config.ts src/components/grpo-training-dashboard",
    "typecheck": "tsc --noEmit -p tsconfig.typecheck.json",
    "lint": "node ../../../node_modules/eslint/bin/eslint.js src",
    "clean": "rm -rf dist"
  },
  "keywords": [
    "hololand",
    "threejs",
    "renderer",
    "vr",
    "webxr",
    "3d",
    "graphics",
    "metaverse"
  ],
  "author": "Hololand Contributors",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/brianonbased-dev/Hololand.git",
    "directory": "packages/renderer"
  },
  "dependencies": {
    "@holoscript/core": "^3.43.0",
    "@holoscript/mvc-schema": "file:../../../../HoloScript/packages/mvc-schema",
    "@hololand/logger": "workspace:*",
    "@hololand/quality-profiles": "workspace:*",
    "@react-three/drei": "^10.7.7",
    "react-router-dom": "^6.28.0"
  },
  "devDependencies": {
    "@react-three/fiber": "^9.5.0",
    "@storybook/react": "^8.6.14",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^14.3.1",
    "@testing-library/user-event": "^14.5.2",
    "@types/node": "^20.19.29",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@types/three": "^0.159.0",
    "react": "^19.2.4",
    "react-dom": "^19.2.4",
    "tsup": "^8.0.1",
    "typescript": "^5.3.3"
  },
  "peerDependencies": {
    "@react-three/fiber": ">=8.0.0 <10.0.0",
    "@hololand/world": "workspace:*",
    "react": ">=18.0.0 <20.0.0",
    "react-dom": ">=18.0.0 <20.0.0",
    "three": "^0.159.0"
  },
  "engines": {
    "node": ">=18.0.0"
  }
}
