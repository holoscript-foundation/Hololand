{
  "name": "@hololand/renderer",
  "version": "1.0.0",
  "description": "Three.js renderer for Hololand VR worlds with WebXR support",
  "main": "./dist/index.js",
  "module": "./dist/index.mjs",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.mjs",
      "require": "./dist/index.js"
    }
  },
  "files": [
    "dist",
    "README.md"
  ],
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch",
    "test": "vitest run --config vitest.config.ts src/components/grpo-training-dashboard",
    "lint": "tsc --noEmit",
    "clean": "rm -rf dist"
  },
  "keywords": [
    "hololand",
    "threejs",
    "renderer",
    "vr",
    "webxr",
    "3d",
    "graphics",
    "metaverse"
  ],
  "author": "Hololand Contributors",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/brianonbased-dev/Hololand.git",
    "directory": "packages/renderer"
  },
  "dependencies": {
    "@hololand/logger": "workspace:*",
    "@holoscript/agent-protocol": "workspace:*"
  },
  "devDependencies": {
    "@types/react": "^18.2.0",
    "@types/three": "^0.159.0",
    "react": "^18.2.0",
    "react-dom": "^18.2.0",
    "tsup": "^8.0.1",
    "typescript": "^5.3.3"
  },
  "peerDependencies": {
    "@hololand/world": "^1.0.0",
    "react": ">=17.0.0",
    "react-dom": ">=17.0.0",
    "three": "^0.159.0"
  },
  "engines": {
    "node": ">=18.0.0"
  }
}
