<?xml version="1.0" encoding="utf-8"?>
<manifest xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:tools="http://schemas.android.com/tools">

    <!-- ========================================== -->
    <!-- GEOSPATIAL AR PERMISSIONS                  -->
    <!-- ========================================== -->

    <!-- Camera (Required for ARCore) -->
    <uses-permission android:name="android.permission.CAMERA" />

    <!-- Location (Required for Geospatial API) -->
    <uses-permission android:name="android.permission.ACCESS_FINE_LOCATION" />
    <uses-permission android:name="android.permission.ACCESS_COARSE_LOCATION" />

    <!-- Internet (Required for VPS and Cloud Anchors) -->
    <uses-permission android:name="android.permission.INTERNET" />

    <!-- Optional: Background location (if you need background tracking) -->
    <!--
    <uses-permission android:name="android.permission.ACCESS_BACKGROUND_LOCATION" />
    -->

    <!-- ========================================== -->
    <!-- HARDWARE FEATURES                          -->
    <!-- ========================================== -->

    <!-- ARCore camera requirement -->
    <uses-feature
        android:name="android.hardware.camera.ar"
        android:required="true" />

    <!-- OpenGL ES 3.0 (Required for ARCore) -->
    <uses-feature
        android:glEsVersion="0x00030000"
        android:required="true" />

    <!-- GPS (Required for Geospatial API) -->
    <uses-feature
        android:name="android.hardware.location.gps"
        android:required="true" />

    <!-- ========================================== -->
    <!-- APPLICATION                                -->
    <!-- ========================================== -->

    <application
        android:allowBackup="true"
        android:icon="@mipmap/ic_launcher"
        android:label="@string/app_name"
        android:roundIcon="@mipmap/ic_launcher_round"
        android:supportsRtl="true"
        android:theme="@style/AppTheme"
        android:usesCleartextTraffic="true">

        <!-- ========================================== -->
        <!-- ARCORE METADATA                            -->
        <!-- ========================================== -->

        <!-- ARCore requirement: "required" | "optional" -->
        <meta-data
            android:name="com.google.ar.core"
            android:value="required" />

        <!-- Google Cloud API Key (for VPS and Geospatial API) -->
        <!-- IMPORTANT: Replace YOUR_API_KEY_HERE with your actual key -->
        <!-- Get key from: https://console.cloud.google.com/apis/credentials -->
        <meta-data
            android:name="com.google.android.geo.API_KEY"
            android:value="YOUR_API_KEY_HERE" />

        <!-- ========================================== -->
        <!-- MAIN ACTIVITY                              -->
        <!-- ========================================== -->

        <activity
            android:name=".MainActivity"
            android:configChanges="orientation|keyboardHidden|keyboard|screenSize|locale|smallestScreenSize|screenLayout|uiMode"
            android:exported="true"
            android:label="@string/app_name"
            android:launchMode="singleTask"
            android:theme="@style/AppTheme.NoActionBarLaunch">

            <intent-filter>
                <action android:name="android.intent.action.MAIN" />
                <category android:name="android.intent.category.LAUNCHER" />
            </intent-filter>
        </activity>

        <!-- ========================================== -->
        <!-- CAPACITOR PLUGINS                          -->
        <!-- ========================================== -->

        <!-- Add any additional Capacitor plugins here -->

    </application>

</manifest>
