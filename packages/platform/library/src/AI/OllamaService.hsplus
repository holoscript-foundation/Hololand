/**
 * OllamaService.hsplus
 * 
 * Local Ollama integration for HoloScript code generation.
 * Provides streaming chat and embedding capabilities.
 * 
 * @package @hololand/library
 * @version 2.0.0
 */

// =============================================================================
// TYPES
// =============================================================================

struct OllamaModel {
  name: string
  modified_at: string
  size: number
  digest: string
}

struct OllamaGenerateOptions {
  model: string
  prompt: string
  system?: string
  template?: string
  context?: number[]
  options?: {
    temperature?: number
    top_p?: number
    top_k?: number
    num_predict?: number
    stop?: string[]
  }
}

struct OllamaEmbeddingRequest {
  model: string
  prompt: string
}

// =============================================================================
// OLLAMA SERVICE MODULE
// =============================================================================

module OllamaService {
  // =========================================================================
  // STATE
  // =========================================================================
  
  @state {
    baseUrl: string = "http://localhost:11434"
    currentModel: string = "neural-chat"
    isConnected: boolean = false
    isGenerating: boolean = false
    abortController: AbortController = null
    availableModels: OllamaModel[] = []
    contextWindow: number[] = []
  }
  
  // =========================================================================
  // INITIALIZATION
  // =========================================================================
  
  @action async initialize(baseUrl?: string): Promise<boolean> {
    if (baseUrl) {
      this.state.baseUrl = baseUrl
    }
    
    try {
      // Test connection by listing models
      const response = await fetch(`${this.state.baseUrl}/api/tags`)
      
      if (!response.ok) {
        this.state.isConnected = false
        return false
      }
      
      const data = await response.json()
      this.state.availableModels = data.models || []
      this.state.isConnected = true
      
      // Set default model if available
      if (this.state.availableModels.length > 0) {
        const preferredModels = ["neural-chat", "codellama", "mistral", "llama2"]
        for (const preferred of preferredModels) {
          const found = this.state.availableModels.find(m => 
            m.name.includes(preferred)
          )
          if (found) {
            this.state.currentModel = found.name
            break
          }
        }
      }
      
      return true
    } catch (err) {
      console.error("Ollama connection failed:", err)
      this.state.isConnected = false
      return false
    }
  }
  
  // =========================================================================
  // MODEL MANAGEMENT
  // =========================================================================
  
  @action async refreshModels(): Promise<OllamaModel[]> {
    try {
      const response = await fetch(`${this.state.baseUrl}/api/tags`)
      const data = await response.json()
      this.state.availableModels = data.models || []
      return this.state.availableModels
    } catch (err) {
      console.error("Failed to refresh models:", err)
      return []
    }
  }
  
  @action setModel(modelName: string): boolean {
    const exists = this.state.availableModels.some(m => m.name === modelName)
    if (exists) {
      this.state.currentModel = modelName
      this.state.contextWindow = [] // Reset context for new model
      return true
    }
    return false
  }
  
  @method getModels(): OllamaModel[] {
    return [...this.state.availableModels]
  }
  
  @method hasModel(name: string): boolean {
    return this.state.availableModels.some(m => m.name.includes(name))
  }
  
  // =========================================================================
  // STREAMING GENERATION
  // =========================================================================
  
  @action async *generate(
    prompt: string,
    options?: Partial<OllamaGenerateOptions>
  ): AsyncGenerator<string> {
    if (!this.state.isConnected) {
      throw new Error("Ollama not connected")
    }
    
    if (this.state.isGenerating) {
      throw new Error("Generation already in progress")
    }
    
    this.state.isGenerating = true
    this.state.abortController = new AbortController()
    
    try {
      const requestBody = {
        model: options?.model || this.state.currentModel,
        prompt,
        system: options?.system || this.getSystemPrompt(),
        context: this.state.contextWindow,
        stream: true,
        options: {
          temperature: options?.options?.temperature || 0.7,
          top_p: options?.options?.top_p || 0.9,
          top_k: options?.options?.top_k || 40,
          num_predict: options?.options?.num_predict || 1024,
          stop: options?.options?.stop || ["```\n\n", "---"]
        }
      }
      
      const response = await fetch(`${this.state.baseUrl}/api/generate`, {
        method: "POST",
        headers: { "Content-Type": "application/json" },
        body: JSON.stringify(requestBody),
        signal: this.state.abortController.signal
      })
      
      if (!response.ok) {
        throw new Error(`Ollama API error: ${response.status}`)
      }
      
      const reader = response.body.getReader()
      const decoder = new TextDecoder()
      
      while (true) {
        const { done, value } = await reader.read()
        if (done) break
        
        const chunk = decoder.decode(value, { stream: true })
        const lines = chunk.split("\n").filter(line => line.trim())
        
        for (const line of lines) {
          try {
            const json = JSON.parse(line)
            
            if (json.response) {
              yield json.response
            }
            
            // Update context window for continuation
            if (json.context) {
              this.state.contextWindow = json.context
            }
            
            if (json.done) {
              break
            }
          } catch (parseErr) {
            // Skip malformed JSON
          }
        }
      }
    } catch (err) {
      if (err.name !== "AbortError") {
        console.error("Ollama generation error:", err)
        throw err
      }
    } finally {
      this.state.isGenerating = false
      this.state.abortController = null
    }
  }
  
  // =========================================================================
  // NON-STREAMING GENERATION
  // =========================================================================
  
  @action async complete(
    prompt: string,
    options?: Partial<OllamaGenerateOptions>
  ): Promise<string> {
    let result = ""
    
    for await (const chunk of this.generate(prompt, options)) {
      result += chunk
    }
    
    return result
  }
  
  // =========================================================================
  // CHAT INTERFACE
  // =========================================================================
  
  @action async *chat(
    messages: { role: string, content: string }[],
    options?: object
  ): AsyncGenerator<string> {
    if (!this.state.isConnected) {
      throw new Error("Ollama not connected")
    }
    
    this.state.isGenerating = true
    this.state.abortController = new AbortController()
    
    try {
      const response = await fetch(`${this.state.baseUrl}/api/chat`, {
        method: "POST",
        headers: { "Content-Type": "application/json" },
        body: JSON.stringify({
          model: this.state.currentModel,
          messages,
          stream: true,
          options: options || {}
        }),
        signal: this.state.abortController.signal
      })
      
      if (!response.ok) {
        throw new Error(`Ollama chat error: ${response.status}`)
      }
      
      const reader = response.body.getReader()
      const decoder = new TextDecoder()
      
      while (true) {
        const { done, value } = await reader.read()
        if (done) break
        
        const chunk = decoder.decode(value, { stream: true })
        const lines = chunk.split("\n").filter(line => line.trim())
        
        for (const line of lines) {
          try {
            const json = JSON.parse(line)
            if (json.message?.content) {
              yield json.message.content
            }
          } catch {}
        }
      }
    } finally {
      this.state.isGenerating = false
      this.state.abortController = null
    }
  }
  
  // =========================================================================
  // EMBEDDINGS
  // =========================================================================
  
  @action async embed(text: string, model?: string): Promise<number[]> {
    if (!this.state.isConnected) {
      throw new Error("Ollama not connected")
    }
    
    const response = await fetch(`${this.state.baseUrl}/api/embeddings`, {
      method: "POST",
      headers: { "Content-Type": "application/json" },
      body: JSON.stringify({
        model: model || this.state.currentModel,
        prompt: text
      })
    })
    
    if (!response.ok) {
      throw new Error(`Ollama embedding error: ${response.status}`)
    }
    
    const data = await response.json()
    return data.embedding || []
  }
  
  @action async embedBatch(texts: string[], model?: string): Promise<number[][]> {
    const embeddings: number[][] = []
    
    for (const text of texts) {
      const embedding = await this.embed(text, model)
      embeddings.push(embedding)
    }
    
    return embeddings
  }
  
  // =========================================================================
  // HOLOSCRIPT-SPECIFIC
  // =========================================================================
  
  @method getSystemPrompt(): string {
    return `You are Brittney, an AI assistant specialized in HoloScript and HoloScript+ development.

HoloScript is a visual flow language for VR/AR worlds with:
- Objects: object "Name" { position: [x,y,z], traits: [...] }
- Templates: template "Type" { state {}, action() {} }
- Traits: trait Material { color: 0xff0000 }
- Events: on_click {}, on_hover_enter {}, every(ms) {}
- Logic: if/else, loops, async/await

When generating code:
1. Use proper HoloScript syntax
2. Include comments explaining the code
3. Wrap code in \`\`\`holoscript ... \`\`\` blocks
4. Follow best practices for VR/AR performance

Be concise and helpful.`
  }
  
  @action async generateHoloScript(
    description: string,
    context?: string
  ): Promise<string> {
    const prompt = context
      ? `Given this existing code:\n\`\`\`holoscript\n${context}\n\`\`\`\n\n${description}`
      : description
    
    let code = ""
    for await (const chunk of this.generate(prompt)) {
      code += chunk
    }
    
    // Extract code from markdown blocks
    const match = code.match(/```(?:holoscript|holo)?\n([\s\S]*?)```/)
    return match ? match[1].trim() : code.trim()
  }
  
  @action async explainCode(code: string): Promise<string> {
    const prompt = `Explain this HoloScript code in detail:\n\n\`\`\`holoscript\n${code}\n\`\`\``
    return await this.complete(prompt)
  }
  
  @action async fixCode(code: string, error: string): Promise<string> {
    const prompt = `Fix this HoloScript code that has an error:

Code:
\`\`\`holoscript
${code}
\`\`\`

Error: ${error}

Provide the corrected code.`
    
    return await this.generateHoloScript(prompt)
  }
  
  // =========================================================================
  // UTILITY
  // =========================================================================
  
  @action abort(): void {
    if (this.state.abortController) {
      this.state.abortController.abort()
      this.state.isGenerating = false
    }
  }
  
  @action clearContext(): void {
    this.state.contextWindow = []
  }
  
  @computed isReady(): boolean {
    return this.state.isConnected && !this.state.isGenerating
  }
  
  @method getStatus(): object {
    return {
      connected: this.state.isConnected,
      generating: this.state.isGenerating,
      model: this.state.currentModel,
      modelCount: this.state.availableModels.length,
      hasContext: this.state.contextWindow.length > 0
    }
  }
}

// =============================================================================
// EXPORTS
// =============================================================================

export {
  OllamaService,
  OllamaModel,
  OllamaGenerateOptions,
  OllamaEmbeddingRequest
}
