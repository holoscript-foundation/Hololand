/**
 * CodeTemplates.hsplus
 * 
 * Library of HoloScript code templates for common patterns,
 * objects, effects, and interactions.
 * 
 * @package @hololand/library
 * @version 2.0.0
 */

// =============================================================================
// TYPES
// =============================================================================

struct CodeTemplate {
  id: string
  name: string
  description: string
  category: string
  code: string
  tags: string[]
  difficulty: "beginner" | "intermediate" | "advanced"
}

// =============================================================================
// CODE TEMPLATES MODULE
// =============================================================================

module CodeTemplates {
  // =========================================================================
  // STATE
  // =========================================================================
  
  @state {
    templates: CodeTemplate[] = []
    customTemplates: CodeTemplate[] = []
    favorites: string[] = []
  }
  
  // =========================================================================
  // INITIALIZATION
  // =========================================================================
  
  @action initialize(): void {
    this.state.templates = [
      // Basic Objects
      ...this.getBasicObjectTemplates(),
      // Primitives
      ...this.getPrimitiveTemplates(),
      // Interactive Objects
      ...this.getInteractiveTemplates(),
      // Effects
      ...this.getEffectTemplates(),
      // NPCs
      ...this.getNPCTemplates(),
      // UI Elements
      ...this.getUITemplates(),
      // Scenes
      ...this.getSceneTemplates(),
      // Advanced
      ...this.getAdvancedTemplates()
    ]
  }
  
  // =========================================================================
  // BASIC OBJECT TEMPLATES
  // =========================================================================
  
  @method getBasicObjectTemplates(): CodeTemplate[] {
    return [
      {
        id: "basic_object",
        name: "Basic Object",
        description: "A simple 3D object with position, rotation, and scale",
        category: "basics",
        difficulty: "beginner",
        tags: ["object", "basic", "starter"],
        code: `object MyObject {
  position: [0, 0, 0]
  rotation: [0, 0, 0]
  scale: [1, 1, 1]
  
  trait Material {
    color: 0x3498db
    metalness: 0.5
    roughness: 0.5
  }
}`
      },
      {
        id: "grouped_objects",
        name: "Grouped Objects",
        description: "Multiple objects organized in a spatial group",
        category: "basics",
        difficulty: "beginner",
        tags: ["group", "organization", "hierarchy"],
        code: `spatial_group "ObjectGroup" {
  position: [0, 0, 0]
  
  object "ChildA" {
    position: [2, 0, 0]
    trait Material { color: 0xff0000 }
  }
  
  object "ChildB" {
    position: [-2, 0, 0]
    trait Material { color: 0x00ff00 }
  }
  
  object "ChildC" {
    position: [0, 2, 0]
    trait Material { color: 0x0000ff }
  }
}`
      },
      {
        id: "template_pattern",
        name: "Template Pattern",
        description: "Reusable template with instances",
        category: "basics",
        difficulty: "intermediate",
        tags: ["template", "reusable", "pattern"],
        code: `template "Tree" {
  state {
    height: 5
    leafColor: 0x228b22
  }
  
  trait Mesh { model: "tree.glb" }
  
  action grow(amount) {
    self.state.height += amount
    self.scale[1] = self.state.height / 5
  }
}

spatial_group "Forest" {
  object "Tree_1" using "Tree" { position: [0, 0, 0] }
  object "Tree_2" using "Tree" { position: [5, 0, 3] }
  object "Tree_3" using "Tree" { position: [-3, 0, 7] }
}`
      }
    ]
  }
  
