  // =========================================================================
  // INTERACTIVE TEMPLATES
  // =========================================================================
  
  @method getInteractiveTemplates(): CodeTemplate[] {
    return [
      {
        id: "clickable_button",
        name: "Clickable Button",
        description: "A button that responds to clicks",
        category: "interactive",
        difficulty: "beginner",
        tags: ["button", "click", "interactive"],
        code: `object Button {
  position: [0, 1, 0]
  interactive: true
  
  state {
    pressed: false
    pressCount: 0
  }
  
  trait BoxGeometry { width: 2, height: 0.5, depth: 2 }
  trait Material { color: 0xe74c3c }
  
  on_click {
    self.state.pressed = true
    self.state.pressCount += 1
    self.position[1] -= 0.1
    
    after(200) {
      self.position[1] += 0.1
      self.state.pressed = false
    }
  }
}`
      },
      {
        id: "hoverable_object",
        name: "Hover Effect",
        description: "Object that reacts to mouse hover",
        category: "interactive",
        difficulty: "beginner",
        tags: ["hover", "highlight", "interactive"],
        code: `object HoverCube {
  position: [0, 1, 0]
  interactive: true
  
  state {
    baseColor: 0x3498db
    hoverColor: 0xf39c12
    isHovered: false
  }
  
  trait BoxGeometry { width: 2, height: 2, depth: 2 }
  trait Material { color: self.state.baseColor }
  
  on_hover_enter {
    self.state.isHovered = true
    self.material.color = self.state.hoverColor
    self.scale = [1.1, 1.1, 1.1]
  }
  
  on_hover_exit {
    self.state.isHovered = false
    self.material.color = self.state.baseColor
    self.scale = [1, 1, 1]
  }
}`
      },
      {
        id: "draggable_object",
        name: "Draggable Object",
        description: "Object that can be dragged in 3D space",
        category: "interactive",
        difficulty: "intermediate",
        tags: ["drag", "move", "interactive"],
        code: `object DraggableCube {
  position: [0, 1, 0]
  interactive: true
  draggable: true
  
  state {
    isDragging: false
    startPos: [0, 0, 0]
  }
  
  trait BoxGeometry { width: 1, height: 1, depth: 1 }
  trait Material { color: 0x2ecc71 }
  
  on_drag_start(event) {
    self.state.isDragging = true
    self.state.startPos = [...self.position]
    self.material.color = 0xf39c12
  }
  
  on_drag(event) {
    self.position = event.worldPosition
  }
  
  on_drag_end(event) {
    self.state.isDragging = false
    self.material.color = 0x2ecc71
  }
}`
      },
      {
        id: "trigger_zone",
        name: "Trigger Zone",
        description: "Invisible zone that detects player entry",
        category: "interactive",
        difficulty: "intermediate",
        tags: ["trigger", "zone", "collision"],
        code: `object TriggerZone {
  position: [0, 0, 0]
  visible: false
  
  state {
    isPlayerInside: false
    enterCount: 0
  }
  
  trait BoxCollider {
    width: 5
    height: 3
    depth: 5
    isTrigger: true
  }
  
  on_trigger_enter(entity) {
    if (entity.type == "player") {
      self.state.isPlayerInside = true
      self.state.enterCount += 1
      emit("zone_entered", { zone: self.id })
    }
  }
  
  on_trigger_exit(entity) {
    if (entity.type == "player") {
      self.state.isPlayerInside = false
      emit("zone_exited", { zone: self.id })
    }
  }
}`
      }
    ]
  }
  
  // =========================================================================
  // EFFECT TEMPLATES
  // =========================================================================
  
  @method getEffectTemplates(): CodeTemplate[] {
