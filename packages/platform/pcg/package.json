{
  "name": "@hololand/pcg",
  "version": "1.0.0",
  "description": "Procedural Content Generation - noise, terrain, dungeons, L-systems, Wave Function Collapse for dynamic world building",
  "type": "module",
  "main": "./dist/index.js",
  "module": "./dist/index.mjs",
  "types": "./dist/index.d.ts",
  "sideEffects": false,
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.mjs",
      "require": "./dist/index.js"
    }
  },
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch",
    "test": "vitest run --passWithNoTests",
    "test:watch": "vitest run"
  },
  "keywords": ["hololand", "pcg", "procedural-generation", "perlin-noise", "terrain", "dungeon", "wfc", "wave-function-collapse", "metaverse"],
  "author": "Hololand Team",
  "license": "ELv2",
  "repository": {
    "type": "git",
    "url": "https://github.com/hololand/hololand.git",
    "directory": "packages/platform/pcg"
  },
  "devDependencies": {
    "tsup": "^8.0.1",
    "typescript": "^5.3.3",
    "vitest": "^1.0.0"
  }
}
