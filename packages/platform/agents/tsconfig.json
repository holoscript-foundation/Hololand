{
  "compilerOptions": {
    "target": "ES2022",
    "baseUrl": ".",
    "module": "NodeNext",
    "moduleResolution": "NodeNext",
    "declaration": true,
    "outDir": "./dist",
    "strict": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "paths": {
      "@hololand/*": ["../*"]
    }
  },
  "include": ["src/**/*"]
