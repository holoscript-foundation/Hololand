// =============================================================================
// ALL TEMPLATES
// =============================================================================

const ALL_TEMPLATES: PersonalityTemplate[] = [
  ...MERCHANT_TEMPLATES,
  ...GUARD_TEMPLATES,
  ...QUEST_GIVER_TEMPLATES,
  ...COMPANION_TEMPLATES,
  ...VILLAIN_TEMPLATES,
  ...AMBIENT_TEMPLATES,
  ...SERVICE_TEMPLATES,
  ...ENTERTAINMENT_TEMPLATES,
  ...MYSTERY_TEMPLATES
]

// =============================================================================
// TEMPLATE UTILITIES
// =============================================================================

module PersonalityTemplates {
  @method getAll(): PersonalityTemplate[] {
    return ALL_TEMPLATES
  }
  
  @method getById(id: string): PersonalityTemplate | null {
    return ALL_TEMPLATES.find(t => t.id === id) || null
  }
  
  @method getByCategory(category: PersonalityCategory): PersonalityTemplate[] {
    return ALL_TEMPLATES.filter(t => t.category === category)
  }
  
  @method getByTag(tag: string): PersonalityTemplate[] {
    return ALL_TEMPLATES.filter(t => t.tags.includes(tag))
  }
  
  @method search(query: string): PersonalityTemplate[] {
    const lowerQuery = query.toLowerCase()
    return ALL_TEMPLATES.filter(t => 
      t.name.toLowerCase().includes(lowerQuery) ||
      t.personality.toLowerCase().includes(lowerQuery) ||
      t.tags.some(tag => tag.includes(lowerQuery))
    )
  }
  
  @method getCategories(): PersonalityCategory[] {
    return Object.values(PersonalityCategory)
  }
  
  @method getAllTags(): string[] {
    const tagSet = new Set<string>()
    ALL_TEMPLATES.forEach(t => t.tags.forEach(tag => tagSet.add(tag)))
    return Array.from(tagSet).sort()
  }
  
  @method getMerchants(): PersonalityTemplate[] {
    return MERCHANT_TEMPLATES
  }
  
  @method getGuards(): PersonalityTemplate[] {
    return GUARD_TEMPLATES
  }
  
  @method getQuestGivers(): PersonalityTemplate[] {
    return QUEST_GIVER_TEMPLATES
  }
  
  @method getCompanions(): PersonalityTemplate[] {
    return COMPANION_TEMPLATES
  }
  
  @method getVillains(): PersonalityTemplate[] {
    return VILLAIN_TEMPLATES
  }
  
  @method getAmbient(): PersonalityTemplate[] {
    return AMBIENT_TEMPLATES
  }
  
  @method getService(): PersonalityTemplate[] {
    return SERVICE_TEMPLATES
  }
  
  @method getEntertainment(): PersonalityTemplate[] {
    return ENTERTAINMENT_TEMPLATES
  }
  
  @method getMystery(): PersonalityTemplate[] {
    return MYSTERY_TEMPLATES
  }
}

// =============================================================================
// EXPORTS
// =============================================================================

export {
  PersonalityTemplates,
  PersonalityTemplate,
  PersonalityCategory,
  MERCHANT_TEMPLATES,
  GUARD_TEMPLATES,
  QUEST_GIVER_TEMPLATES,
  COMPANION_TEMPLATES,
  VILLAIN_TEMPLATES,
  AMBIENT_TEMPLATES,
  SERVICE_TEMPLATES,
  ENTERTAINMENT_TEMPLATES,
  MYSTERY_TEMPLATES,
  ALL_TEMPLATES
}
