/**
 * PersonalityTemplates.hsplus
 * 
 * Pre-built personality archetypes for neural agents.
 * Use with AgentFactory or NeuralOllamaBridge.
 * 
 * @package @hololand/network
 * @version 2.0.0
 */

import { AgentCapability } from "./NeuralOllamaBridge.hsplus"

// =============================================================================
// TYPES
// =============================================================================

enum PersonalityCategory {
  MERCHANT = "merchant"
  GUARD = "guard"
  QUEST_GIVER = "quest-giver"
  COMPANION = "companion"
  VILLAIN = "villain"
  AMBIENT = "ambient"
  SERVICE = "service"
  ENTERTAINMENT = "entertainment"
  MYSTERY = "mystery"
}

struct PersonalityTemplate {
  id: string
  name: string
  category: PersonalityCategory
  personality: string
  capabilities: AgentCapability[]
  systemPrompt: string = null
  voice: string = null
  model: string = null
  tags: string[]
}

