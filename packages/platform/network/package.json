{
  "name": "@hololand/network",
  "version": "1.0.0",
  "description": "Compatibility network facade for HoloLand examples and adapters",
  "type": "module",
  "main": "./src/index.ts",
  "module": "./src/index.ts",
  "types": "./src/index.ts",
  "exports": {
    ".": {
      "types": "./src/index.ts",
      "import": "./src/index.ts",
      "require": "./src/index.ts"
    },
    "./voice/WebRTCVoiceTransport": {
      "types": "./src/voice/WebRTCVoiceTransport.ts",
      "import": "./src/voice/WebRTCVoiceTransport.ts",
      "require": "./src/voice/WebRTCVoiceTransport.ts"
    },
    "./voice/VoiceChannelManager": {
      "types": "./src/voice/VoiceChannelManager.ts",
      "import": "./src/voice/VoiceChannelManager.ts",
      "require": "./src/voice/VoiceChannelManager.ts"
    },
    "./voice/types": {
      "types": "./src/voice/types.ts",
      "import": "./src/voice/types.ts",
      "require": "./src/voice/types.ts"
    }
  },
  "scripts": {
    "build": "echo \"source-only compatibility facade\"",
    "dev": "echo \"source-only compatibility facade\"",
    "test": "echo \"No tests yet\" && exit 0"
  },
  "keywords": [
    "hololand",
    "network",
    "compatibility"
  ],
  "license": "MIT",
  "devDependencies": {
    "tsup": "^8.0.1",
    "typescript": "^5.3.3"
  }
}
