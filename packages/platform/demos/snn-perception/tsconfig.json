{
  "compilerOptions": {
    "target": "ES2020",
    "useDefineForClassFields": true,
    "lib": ["ES2020", "DOM", "DOM.Iterable", "WebWorker"],
    "module": "ESNext",
    "skipLibCheck": true,

    /* Bundler mode */
    "moduleResolution": "bundler",
    "allowImportingTsExtensions": true,
    "resolveJsonModule": true,
    "isolatedModules": true,
    "noEmit": true,
    "jsx": "react-jsx",

    /* Linting */
    "strict": true,
    "noUnusedLocals": true,
    "noUnusedParameters": true,
    "noFallthroughCasesInSwitch": true,

    /* Path aliases */
    "baseUrl": ".",
    "paths": {
      "@hololand/platform-renderer": ["../../renderer/src/index.ts"],
      "@hololand/platform": ["../../core/src/index.ts"],
      "@hololand/holoscript-runtime": ["../../../holoscript/runtime/src/index.ts"]
    }
  },
  "include": ["src"],
  "references": [
    { "path": "../../renderer" },
    { "path": "../../core" }
  ]
}
