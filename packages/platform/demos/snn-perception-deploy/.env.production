# Production Environment Configuration for SNN Perception Demo
# Copy to .env and customize for your deployment

# ============================================================================
# Application Settings
# ============================================================================
NODE_ENV=production
APP_NAME=snn-perception-demo
APP_VERSION=1.0.0

# ============================================================================
# SNN Model Configuration
# ============================================================================
# Path to SNN model file (relative to public directory)
SNN_MODEL_PATH=/models/warehouse-snn-v1.json

# Model serving endpoint (if using external model server)
# MODEL_SERVER_URL=https://models.hololand.io/warehouse-snn-v1.json

# ============================================================================
# Inference Configuration
# ============================================================================
# Default inference frequency (Hz)
VITE_DEFAULT_INFERENCE_HZ=10

# Adaptive frequency range
VITE_MIN_INFERENCE_HZ=2
VITE_MAX_INFERENCE_HZ=30

# Enable adaptive frequency control
VITE_ADAPTIVE_FREQUENCY=true

# Maximum objects to track simultaneously
VITE_MAX_TRACKED_OBJECTS=32

# Confidence threshold for object detection
VITE_CONFIDENCE_THRESHOLD=0.6

# ============================================================================
# Energy Optimization
# ============================================================================
# Target battery life (hours)
VITE_TARGET_BATTERY_HOURS=6

# Power budget (watts)
VITE_POWER_BUDGET_W=0.9

# Enable energy monitoring dashboard
VITE_SHOW_ENERGY_DASHBOARD=true

# ============================================================================
# WebGPU Configuration
# ============================================================================
# Fallback to CPU if WebGPU unavailable
VITE_WEBGPU_FALLBACK=true

# WebGPU device preference (high-performance | low-power)
VITE_WEBGPU_POWER_PREFERENCE=high-performance

# ============================================================================
# WebXR Configuration
# ============================================================================
# Enable WebXR mode
VITE_ENABLE_WEBXR=true

# XR session mode (immersive-vr | immersive-ar | inline)
VITE_XR_SESSION_MODE=immersive-vr

# Required features (space-separated)
VITE_XR_REQUIRED_FEATURES=local-floor bounded-floor

# Optional features
VITE_XR_OPTIONAL_FEATURES=hand-tracking eye-tracking

# ============================================================================
# API Endpoints (if backend integration is added)
# ============================================================================
# Backend API base URL
# VITE_API_BASE_URL=https://api.hololand.io

# WebSocket URL for real-time updates
# VITE_WS_URL=wss://api.hololand.io/ws

# API timeout (ms)
# VITE_API_TIMEOUT=10000

# ============================================================================
# Monitoring & Analytics
# ============================================================================
# Enable Prometheus metrics export
ENABLE_METRICS=true

# Metrics export port
METRICS_PORT=9090

# Enable error tracking (Sentry)
# VITE_SENTRY_DSN=https://your-sentry-dsn@sentry.io/project-id

# Sentry environment
# VITE_SENTRY_ENVIRONMENT=production

# Enable analytics
# VITE_ANALYTICS_ID=UA-XXXXX-Y

# ============================================================================
# Logging
# ============================================================================
# Log level (error | warn | info | debug)
LOG_LEVEL=info

# Log format (json | text)
LOG_FORMAT=json

# Enable access logs
ENABLE_ACCESS_LOGS=true

# ============================================================================
# Security
# ============================================================================
# CORS allowed origins (comma-separated)
CORS_ORIGINS=https://hololand.io,https://www.hololand.io

# Rate limiting (requests per second)
RATE_LIMIT_RPS=10

# Max connections per IP
MAX_CONNECTIONS_PER_IP=10

# ============================================================================
# SSL/TLS
# ============================================================================
# SSL certificate path
SSL_CERT_PATH=/etc/nginx/ssl/server.crt

# SSL key path
SSL_KEY_PATH=/etc/nginx/ssl/server.key

# Force HTTPS redirect
FORCE_HTTPS=true

# ============================================================================
# Performance
# ============================================================================
# Enable gzip compression
ENABLE_GZIP=true

# Gzip compression level (1-9)
GZIP_LEVEL=6

# Enable brotli compression
ENABLE_BROTLI=false

# Static asset cache duration (seconds)
STATIC_CACHE_DURATION=31536000

# Model cache duration (seconds)
MODEL_CACHE_DURATION=604800

# ============================================================================
# Feature Flags
# ============================================================================
# Show debug UI
VITE_SHOW_DEBUG_UI=false

# Enable experimental features
VITE_ENABLE_EXPERIMENTAL=false

# Show FPS counter
VITE_SHOW_FPS=false

# Enable performance profiling
VITE_ENABLE_PROFILING=false

# ============================================================================
# Deployment Info (auto-populated by CI/CD)
# ============================================================================
# Build date (ISO 8601)
# BUILD_DATE=2026-03-08T00:00:00Z

# Git commit SHA
# VCS_REF=abc123def456

# Deployment environment
# DEPLOY_ENV=production

# Container registry
# CONTAINER_REGISTRY=ghcr.io/hololand/snn-perception-demo
