{
  "name": "@hololand/gestures",
  "version": "1.0.0",
  "description": "Gesture recognition system - hand gestures, body poses, gesture sequences, and emotion detection for VR/AR",
  "type": "module",
  "main": "./dist/index.js",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "sideEffects": false,
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.cjs"
    }
  },
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch",
    "test": "vitest run --passWithNoTests",
    "test:watch": "vitest run"
  },
  "keywords": [
    "hololand",
    "gestures",
    "hand-tracking",
    "body-pose",
    "recognition",
    "vr",
    "ar",
    "webxr",
    "metaverse"
  ],
  "author": "Hololand Team",
  "license": "ELv2",
  "repository": {
    "type": "git",
    "url": "https://github.com/hololand/hololand.git",
    "directory": "packages/platform/gestures"
  },
  "peerDependencies": {
    "@holoscript/core": "^2.0.0"
  },
  "peerDependenciesMeta": {
    "@holoscript/core": {
      "optional": true
    }
  },
  "devDependencies": {
    "tsup": "^8.0.1",
    "typescript": "^5.3.3",
    "vitest": "^1.0.0"
  }
}
