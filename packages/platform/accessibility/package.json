{
  "name": "@hololand/accessibility",
  "version": "1.0.0",
  "description": "W3C XR Accessibility - haptic feedback, screen readers, motor accommodations, colorblind modes for inclusive VR",
  "type": "module",
  "main": "./dist/index.js",
  "module": "./dist/index.mjs",
  "types": "./dist/index.d.ts",
  "sideEffects": false,
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.mjs",
      "require": "./dist/index.js"
    }
  },
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch",
    "test": "vitest run --passWithNoTests",
    "test:watch": "vitest run"
  },
  "keywords": ["hololand", "accessibility", "a11y", "w3c", "screen-reader", "colorblind", "motor", "vr", "ar", "metaverse"],
  "author": "Hololand Team",
  "license": "ELv2",
  "repository": {
    "type": "git",
    "url": "https://github.com/hololand/hololand.git",
    "directory": "packages/platform/accessibility"
  },
  "peerDependencies": {
    "@holoscript/core": "^2.0.0",
    "three": "^0.170.0"
  },
  "peerDependenciesMeta": {
    "@holoscript/core": {
      "optional": true
    },
    "three": {
      "optional": true
    }
  },
  "devDependencies": {
    "tsup": "^8.0.1",
    "typescript": "^5.3.3",
    "vitest": "^1.0.0"
  }
}
