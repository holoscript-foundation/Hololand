// ============================================================================
// Main Library Module
// ============================================================================

module HololandLibrary {
  @state {
    version: string = "2.0.0"
    initialized: boolean = false
  }
  
  @action async initialize(config?: object): Promise<void> {
    if (this.state.initialized) return
    
    // Initialize all subsystems
    HoloScriptService.initialize()
    CodeTemplates.initialize()
    PlaygroundStore.loadFromLocalStorage()
    SystemsManager.initializeAll()
    
    if (config?.aiConfig) {
      AIService.initialize(config.aiConfig)
      await OllamaService.initialize(config.aiConfig?.ollamaUrl)
    }
    
    this.state.initialized = true
    console.log(`Hololand Library v${this.state.version} initialized`)
  }
  
  @action dispose(): void {
    SystemsManager.shutdown()
    PreviewService.dispose()
    EventBus.reset()
    this.state.initialized = false
  }
  
  @method getVersion(): string {
    return this.state.version
  }
}

export { HololandLibrary }
export default HololandLibrary
