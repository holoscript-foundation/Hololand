// HOSL: @hololand/library Master Index
// Standard Library for HoloScript - Reusable Components & Traits

/* 
 * @hololand/library
 * =================
 * 
 * This package provides pre-built, production-ready components for
 * HoloScript applications. All components are written in HoloScript+ (.hsplus).
 * 
 * ## Categories
 * 
 * - **Core**: Basic building blocks (shapes, primitives)
 * - **Interactive**: IoT and connected device components
 * - **UI**: Brittney AI integration and UI elements
 * 
 * ## Usage
 * 
 * ```hsplus
 * import { BrittneyToolbar } from "@hololand/library/UI"
 * import { SmartLight } from "@hololand/library/Interactive"
 * import { BasicShapes } from "@hololand/library/Core"
 * ```
 */

