// =============================================================================
// TOOL HANDLER
// =============================================================================

module BrittneyToolHandler {
  @method async handle(toolName: string, args: Record<string, any>): Promise<any> {
    switch (toolName) {
      case "brittney_get_browser_state":
        return this.getBrowserState()
        
      case "brittney_list_scenes":
        return this.listScenes()
        
      case "brittney_get_profiler_stats":
        return this.getProfilerStats(args.duration)
        
      case "brittney_get_console_logs":
        return this.getConsoleLogs(args.limit || 20, args.level || "all")
        
      case "brittney_get_runtime_errors":
        return this.getRuntimeErrors(args.limit || 10)
        
      case "brittney_analyze_performance":
        return this.analyzePerformance(args.focus || "all")
        
      case "brittney_ask":
        return this.ask(args.question, args.includeContext !== false)
        
      case "brittney_explain_error":
        return this.explainError(args.errorIndex || 0)
        
      case "brittney_generate_holoscript":
        return this.generateHoloScript(args.description, args.category)
        
      case "brittney_inject_holoscript":
        return this.injectHoloScript(args.code, args.worldId, args.validate !== false)
        
      case "brittney_navigate_to_world":
        return this.navigateToWorld(args.worldId)
        
      case "brittney_reload_scene":
        return this.reloadScene(args.preserveState || false)
        
      case "brittney_take_screenshot":
        return this.takeScreenshot(args.format || "png", args.quality || 90)
        
      default:
        throw new Error(`Unknown Brittney tool: ${toolName}`)
    }
  }
  
  // =========================================================================
  // INSPECTION HANDLERS
  // =========================================================================
  
  @method getBrowserState(): BrowserStateData | null {
    return sharedDataBridge.getBrowserState()
  }
  
  @method listScenes(): SceneInfoData[] {
    return sharedDataBridge.getScenes()
  }
  
  @method getProfilerStats(duration?: number): ProfilerStatsData | null {
    return sharedDataBridge.getProfilerStats()
  }
  
  @method getConsoleLogs(limit: number, level: string): ConsoleLogData[] {
    let logs = sharedDataBridge.getConsoleLogs()
    
    if (level !== "all") {
      logs = logs.filter(l => l.level === level)
    }
    
    return logs.slice(-limit)
  }
  
  @method getRuntimeErrors(limit: number): RuntimeErrorData[] {
    return sharedDataBridge.getRuntimeErrors().slice(-limit)
  }
  
  // =========================================================================
  // AI ANALYSIS HANDLERS
  // =========================================================================
  
  @method async analyzePerformance(focus: string): Promise<any> {
    const stats = sharedDataBridge.getProfilerStats()
    const context = await BrittneyService.collectBrowserContext()
    
    const prompt = `Analyze the current performance metrics and suggest optimizations.
Focus: ${focus}
Current stats: ${JSON.stringify(stats, null, 2)}`
    
    const response = await BrittneyService.call(prompt, { browserContext: context })
    
    return {
      stats,
      analysis: response.success ? response.response : response.error
    }
  }
  
  @method async ask(question: string, includeContext: boolean): Promise<any> {
    let context: BrittneyBrowserContext = null
    
    if (includeContext) {
      context = await BrittneyService.collectBrowserContext()
    }
    
    const response = await BrittneyService.call(question, { browserContext: context })
    
    return {
      question,
      answer: response.success ? response.response : response.error,
      success: response.success
    }
  }
  
  @method async explainError(errorIndex: number): Promise<any> {
    const errors = sharedDataBridge.getRuntimeErrors()
    const error = errors[errorIndex]
    
    if (!error) {
      return { error: "No error found at index " + errorIndex }
    }
    
    const context = await BrittneyService.collectBrowserContext()
    
    const prompt = `Explain this runtime error in plain language and suggest fixes:
Error: ${error.message}
Stack: ${error.stack || "No stack trace"}
Source: ${error.source || "Unknown"}`
    
    const response = await BrittneyService.call(prompt, { browserContext: context })
    
    return {
      error,
      explanation: response.success ? response.response : response.error,
      success: response.success
    }
  }
  
  // =========================================================================
  // CODE GENERATION HANDLERS
  // =========================================================================
  
  @method async generateHoloScript(description: string, category?: string): Promise<any> {
    const context = await BrittneyService.collectBrowserContext()
    
    const prompt = `Generate HoloScript code for: ${description}
${category ? `Category: ${category}` : ""}
Return only the HoloScript code, no explanation.`
    
    const response = await BrittneyService.call(prompt, {
      browserContext: context,
      systemPrompt: "You are a HoloScript expert. Generate clean, efficient HoloScript code."
    })
    
    return {
      description,
      code: response.success ? response.response : null,
      error: response.success ? null : response.error
    }
  }
  
  @method async injectHoloScript(
    code: string, 
    worldId?: string, 
    validate: boolean = true
  ): Promise<any> {
    // TODO: Implement actual injection via native messaging
    return {
      injected: false,
      message: "Injection requires native messaging host connection"
    }
  }
  
  // =========================================================================
  // NAVIGATION HANDLERS
  // =========================================================================
  
  @method async navigateToWorld(worldId: string): Promise<any> {
    // TODO: Implement via native messaging
    return {
      navigated: false,
      worldId,
      message: "Navigation requires native messaging host connection"
    }
  }
  
  @method async reloadScene(preserveState: boolean): Promise<any> {
    // TODO: Implement via native messaging
    return {
      reloaded: false,
      preserveState,
      message: "Reload requires native messaging host connection"
    }
  }
  
  @method async takeScreenshot(format: string, quality: number): Promise<any> {
    // TODO: Implement via native messaging
    return {
      captured: false,
      format,
      message: "Screenshot requires native messaging host connection"
    }
  }
}

// =============================================================================
// EXPORTS
// =============================================================================

const brittneyTools = BRITTNEY_TOOLS

async function handleBrittneyTool(toolName: string, args: Record<string, any>): Promise<any> {
  return BrittneyToolHandler.handle(toolName, args)
}

export {
  brittneyTools,
  handleBrittneyTool,
  BrittneyService,
  BrittneyToolHandler,
  BRITTNEY_SERVICE_URL
}
