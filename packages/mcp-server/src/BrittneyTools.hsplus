/**
 * BrittneyTools.hsplus
 * 
 * Brittney IDE Agent Integration Tools.
 * Enables IDE agents (Claude Code, Cursor, Copilot) to get visibility 
 * into the running Hololand application through Brittney.
 * 
 * Architecture:
 * IDE Agent ←→ MCP Protocol ←→ Brittney Tools ←→ SharedDataBridge ←→ Native Messaging Host ←→ Browser Extension ←→ Hololand App
 *                                    ↓
 *                          Brittney Service (localhost:11435)
 *                                    ↓
 *                          LM Studio + RAG Knowledge
 * 
 * @package @hololand/mcp-server
 * @version 2.0.0
 */

import { sharedDataBridge } from "./SharedDataBridge.hsplus"
import {
  Tool,
  BrittneyServiceResponse,
  BrittneyBrowserContext,
  BrowserStateData,
  SceneInfoData,
  ProfilerStatsData,
  ConsoleLogData,
  RuntimeErrorData
} from "./Types.hsplus"

// =============================================================================
// CONFIGURATION
// =============================================================================

const BRITTNEY_SERVICE_URL = process.env.BRITTNEY_SERVICE_URL || "http://localhost:11435"

// =============================================================================
// BRITTNEY SERVICE CLIENT
// =============================================================================

module BrittneyService {
  @method async call(
    message: string,
    options: {
      systemPrompt?: string
      browserContext?: BrittneyBrowserContext
      conversationId?: string
    } = {}
  ): Promise<BrittneyServiceResponse> {
    try {
      // Build ChatRequest format
      const chatRequest = {
        messages: [
          ...(options.systemPrompt ? [{ role: "system", content: options.systemPrompt }] : []),
          { role: "user", content: message }
        ],
        context: options.browserContext ? {
          browserState: {
            url: options.browserContext.url || "unknown",
            scenes: options.browserContext.scenes || [],
            profilerStats: options.browserContext.profilerStats,
            consoleLogs: options.browserContext.consoleLogs,
            errors: options.browserContext.errors
          }
        } : undefined
      }
      
      const response = await fetch(`${BRITTNEY_SERVICE_URL}/chat`, {
        method: "POST",
        headers: { "Content-Type": "application/json" },
        body: JSON.stringify(chatRequest)
      })
      
      if (!response.ok) {
        const errorText = await response.text()
        return {
          success: false,
          error: `Brittney service error (${response.status}): ${errorText}`
        }
      }
      
      const chatResponse = await response.json()
      return {
        success: true,
        response: chatResponse.content,
        conversationId: chatResponse.id,
        usage: chatResponse.usage
      }
    } catch (error: any) {
      if (error.code === "ECONNREFUSED") {
        return {
          success: false,
          error: "Brittney service not running. Start it with: npx @hololand/brittney-service start"
        }
      }
      return {
        success: false,
        error: `Failed to call Brittney service: ${error.message}`
      }
    }
  }
  
  @method async checkHealth(): Promise<{
    healthy: boolean
    status?: any
    error?: string
  }> {
    try {
      const response = await fetch(`${BRITTNEY_SERVICE_URL}/health`)
      if (response.ok) {
        const status = await response.json()
        return { healthy: true, status }
      }
      return { healthy: false, error: `Health check failed: ${response.status}` }
    } catch (error: any) {
      return { healthy: false, error: `Service unreachable: ${error.message}` }
    }
  }
  
  @method async collectBrowserContext(): Promise<BrittneyBrowserContext> {
    try {
      const browserState = sharedDataBridge.getBrowserState()
      const scenes = sharedDataBridge.getScenes()
      const profilerStats = sharedDataBridge.getProfilerStats()
      const consoleLogs = sharedDataBridge.getConsoleLogs()
      const errors = sharedDataBridge.getRuntimeErrors()
      
      return {
        url: browserState?.url,
        scenes: scenes?.map(s => ({
          id: s.id,
          name: s.name,
          objectCount: s.objectCount
        })),
        profilerStats: profilerStats ? {
          fps: profilerStats.fps,
          drawCalls: profilerStats.drawCalls,
          triangles: profilerStats.triangles
        } : null,
        consoleLogs: consoleLogs?.slice(0, 10).map(l => ({
          level: l.level,
          message: l.message
        })),
        errors: errors?.slice(0, 5).map(e => ({
          message: e.message,
          stack: e.stack
        }))
      }
    } catch {
      return {}
    }
  }
}

