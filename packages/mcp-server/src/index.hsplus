// =============================================================================
// ALL TOOLS
// =============================================================================

const ALL_TOOLS: Tool[] = [
  ...CORE_TOOLS,
  ...brittneyTools,
  ...advancedBrittneyTools,
  ...holoGraphTools
]

// =============================================================================
// TOOL HANDLER
// =============================================================================

module MCPToolHandler {
  @method async handle(toolName: string, args: Record<string, any>): Promise<any> {
    // Core tools
    switch (toolName) {
      case "create_world":
        return HololandClient.createWorld(args)
        
      case "execute_holoscript":
        return HololandClient.executeHoloScript(args)
        
      case "visualize_data":
        return HololandClient.visualizeData(args)
        
      case "invite_agent":
        return HololandClient.inviteAgent(args)
        
      case "get_world":
        return HololandClient.getWorld(args.worldId)
        
      case "list_worlds":
        return HololandClient.listWorlds(args)
        
      case "add_object":
        return HololandClient.addObject(args)
        
      case "remove_object":
        return HololandClient.removeObject(args.worldId, args.objectId)
        
      case "list_objects":
        return HololandClient.listObjects(args.worldId)
        
      case "get_holoscript_version":
        return { version: "2.0.0", platforms: ["browser", "node", "bun"] }
        
      case "validate_holoscript":
        return { valid: true, message: "Validation requires HoloScript parser" }
        
      case "parse_holoscript":
        return { parsed: true, message: "Parsing requires HoloScript parser" }
    }
    
    // Brittney tools
    if (toolName.startsWith("brittney_")) {
      // Check for advanced tools first
      const advancedTool = advancedBrittneyTools.find(t => t.name === toolName)
      if (advancedTool) {
        return handleAdvancedBrittneyTool(toolName, args)
      }
      return handleBrittneyTool(toolName, args)
    }
    
    // HoloGraph tools
    if (toolName.startsWith("holo_")) {
      return handleHoloGraphTool(toolName, args)
    }
    
    throw new Error(`Unknown tool: ${toolName}`)
  }
}

// =============================================================================
// MCP SERVER
// =============================================================================

module MCPServer {
  @state {
    server: Server = null
  }
  
  @action async start(): Promise<void> {
    this.state.server = new Server(
      { name: "hololand", version: "2.0.0" },
      { capabilities: { tools: {} } }
    )
    
    // List tools handler
    this.state.server.setRequestHandler(ListToolsRequestSchema, async () => {
      return { tools: ALL_TOOLS }
    })
    
    // Call tool handler
    this.state.server.setRequestHandler(CallToolRequestSchema, async (request) => {
      const { name, arguments: args } = request.params
      
      try {
        const result = await MCPToolHandler.handle(name, args || {})
        return {
          content: [{ type: "text", text: JSON.stringify(result, null, 2) }]
        }
      } catch (error) {
        const message = error instanceof Error ? error.message : String(error)
        return {
          content: [{ type: "text", text: `Error: ${message}` }],
          isError: true
        }
      }
    })
    
    // Start with stdio transport
    const transport = new StdioServerTransport()
    await this.state.server.connect(transport)
    
    console.error("[MCPServer] Hololand MCP Server v2.0.0 started")
  }
}

// =============================================================================
// CLI ENTRY POINT
// =============================================================================

if (require.main === module) {
  MCPServer.start().catch(err => {
    console.error("[MCPServer] Fatal error:", err)
    process.exit(1)
  })
}

// =============================================================================
// EXPORTS
// =============================================================================

export {
  // Server
  MCPServer,
  MCPToolHandler,
  
  // Client
  HololandClient,
  
  // Tools
  CORE_TOOLS,
  ALL_TOOLS,
  
  // Re-exports
  brittneyTools,
  handleBrittneyTool,
  advancedBrittneyTools,
  handleAdvancedBrittneyTool,
  holoGraphTools,
  handleHoloGraphTool,
  sharedDataBridge,
  BrittneyService
}
