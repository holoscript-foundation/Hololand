/**
 * @hololand/mcp-server
 * 
 * Hololand MCP Server - Model Context Protocol server for AI agent integration.
 * Enables AI agents to create and manage VR/AR worlds, execute HoloScript,
 * and collaborate in spatial environments.
 * 
 * Features:
 * - Local HoloScript parsing and validation (no API required)
 * - Brittney IDE Agent Integration (browser context visibility for coding agents)
 * - HoloScript Graph Understanding Tools (helps agents understand .holo as visual graphs)
 * 
 * @package @hololand/mcp-server
 * @version 2.0.0
 * @author Hololand Team
 * @license MIT
 */

// =============================================================================
// IMPORTS
// =============================================================================

import { Server } from "@modelcontextprotocol/sdk/server/index.js"
import { StdioServerTransport } from "@modelcontextprotocol/sdk/server/stdio.js"
import { CallToolRequestSchema, ListToolsRequestSchema, Tool } from "@modelcontextprotocol/sdk/types.js"
import axios from "axios"

// Internal modules
import { brittneyTools, handleBrittneyTool, BrittneyService } from "./BrittneyTools.hsplus"
import { advancedBrittneyTools, handleAdvancedBrittneyTool } from "./AdvancedBrittneyTools.hsplus"
import { holoGraphTools, handleHoloGraphTool } from "./HoloGraphTools.hsplus"
import { sharedDataBridge } from "./SharedDataBridge.hsplus"

// Export types
export * from "./Types.hsplus"

// =============================================================================
// CONFIGURATION
// =============================================================================

const HOLOLAND_API_URL = process.env.HOLOLAND_API_URL || "http://localhost:3001"
const HOLOLAND_API_KEY = process.env.HOLOLAND_API_KEY

// =============================================================================
// HOLOLAND API CLIENT
// =============================================================================

module HololandClient {
  @state {
    baseUrl: string = HOLOLAND_API_URL
    apiKey: string = HOLOLAND_API_KEY
  }
  
  @method getHeaders(): Record<string, string> {
    const headers: Record<string, string> = {
      "Content-Type": "application/json"
    }
    if (this.state.apiKey) {
      headers["X-API-Key"] = this.state.apiKey
    }
    return headers
  }
  
  @method async createWorld(params: {
    name: string
    template?: string
    privacy?: string
    ownerId?: string
  }): Promise<any> {
    const response = await axios.post(
      `${this.state.baseUrl}/api/v1/worlds`,
      params,
      { headers: this.getHeaders() }
    )
    return response.data
  }
  
  @method async executeHoloScript(params: {
    worldId: string
    code: string
    context?: any
  }): Promise<any> {
    const response = await axios.post(
      `${this.state.baseUrl}/api/v1/holoscript/execute`,
      params,
      { headers: this.getHeaders() }
    )
    return response.data
  }
  
  @method async visualizeData(params: {
    worldId: string
    data: any
    vizType: string
  }): Promise<any> {
    const response = await axios.post(
      `${this.state.baseUrl}/api/v1/holoscript/visualize`,
      params,
      { headers: this.getHeaders() }
    )
    return response.data
  }
  
  @method async inviteAgent(params: {
    worldId: string
    agentId: string
    permissions?: string[]
  }): Promise<any> {
    const response = await axios.post(
      `${this.state.baseUrl}/api/v1/worlds/${params.worldId}/invite`,
      { agentId: params.agentId, permissions: params.permissions || ["view", "edit"] },
      { headers: this.getHeaders() }
    )
    return response.data
  }
  
  @method async getWorld(worldId: string): Promise<any> {
    const response = await axios.get(
      `${this.state.baseUrl}/api/v1/worlds/${worldId}`,
      { headers: this.getHeaders() }
    )
    return response.data
  }
  
  @method async listWorlds(filters?: { ownerId?: string, type?: string }): Promise<any> {
    const response = await axios.get(
      `${this.state.baseUrl}/api/v1/worlds`,
      { headers: this.getHeaders(), params: filters }
    )
    return response.data
  }
  
  @method async updateWorld(worldId: string, updates: any): Promise<any> {
    const response = await axios.put(
      `${this.state.baseUrl}/api/v1/worlds/${worldId}`,
      updates,
      { headers: this.getHeaders() }
    )
    return response.data
  }
  
  @method async deleteWorld(worldId: string): Promise<any> {
    const response = await axios.delete(
      `${this.state.baseUrl}/api/v1/worlds/${worldId}`,
      { headers: this.getHeaders() }
    )
    return response.data
  }
  
  @method async addObject(params: {
    worldId: string
    type: string
    position: { x: number, y: number, z: number }
    metadata?: Record<string, any>
    physics?: { enabled: boolean, mass?: number, restitution?: number }
  }): Promise<any> {
    const response = await axios.post(
      `${this.state.baseUrl}/api/v1/worlds/${params.worldId}/objects`,
      params,
      { headers: this.getHeaders() }
    )
    return response.data
  }
  
  @method async removeObject(worldId: string, objectId: string): Promise<any> {
    const response = await axios.delete(
      `${this.state.baseUrl}/api/v1/worlds/${worldId}/objects/${objectId}`,
      { headers: this.getHeaders() }
    )
    return response.data
  }
  
  @method async listObjects(worldId: string): Promise<any> {
    const response = await axios.get(
      `${this.state.baseUrl}/api/v1/worlds/${worldId}/objects`,
      { headers: this.getHeaders() }
    )
    return response.data
  }
}

