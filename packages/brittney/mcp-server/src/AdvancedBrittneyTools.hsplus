// =============================================================================
// TOOL HANDLER
// =============================================================================

module AdvancedBrittneyToolHandler {
  @method async handle(toolName: string, args: Record<string, any>): Promise<any> {
    switch (toolName) {
      case "brittney_create_and_inject":
        return this.createAndInject(args.description, args.category, args.worldId, args.validate)
        
      case "brittney_error_monitor":
        return this.errorMonitor(args.analyze, args.threshold || 5)
        
      case "brittney_auto_fix":
        return this.autoFix(args.errorIndex || 0, args.apply || false)
        
      case "brittney_performance_monitor":
        return this.performanceMonitor(args.fpsThreshold || 30, args.memoryThresholdMB || 500, args.getSuggestions)
        
      case "brittney_holoscript_playground":
        return this.playground(args.code, args.action, args.convertFrom)
        
      case "brittney_holoscript_diff":
        return this.holoScriptDiff(args.newCode, args.showDetails || false)
        
      case "brittney_holoscript_templates":
        return this.getTemplate(args.category, args.customize)
        
      case "brittney_scene_snapshot":
        return this.sceneSnapshot(args.name, args.includeScreenshot !== false, args.includePerformance !== false)
        
      case "brittney_compare_snapshots":
        return this.compareSnapshots(args.snapshot1, args.snapshot2)
        
      case "brittney_record_session":
        return this.recordSession(args.action, args.sessionName, args.format)
        
      case "brittney_accessibility_check":
        return this.accessibilityCheck(args.checks || ["all"])
        
      case "brittney_test_scene":
        return this.testScene(args.testType, args.baseline, args.threshold)
        
      case "brittney_explain_scene":
        return this.explainScene(args.depth || "overview", args.focus || "all")
        
      default:
        throw new Error(`Unknown advanced Brittney tool: ${toolName}`)
    }
  }
  
  // =========================================================================
  // ONE-SHOT CREATION
  // =========================================================================
  
  @method async createAndInject(
    description: string,
    category?: string,
    worldId?: string,
    validate: boolean = true
  ): Promise<any> {
    const context = await BrittneyService.collectBrowserContext()
    
    // Generate code
    const prompt = `Generate HoloScript for: ${description}
${category ? `Category: ${category}` : ""}
Return only valid HoloScript code.`
    
    const response = await BrittneyService.call(prompt, {
      browserContext: context,
      systemPrompt: "You are a HoloScript expert. Generate clean, efficient code."
    })
    
    if (!response.success) {
      return {
        success: false,
        error: response.error
      }
    }
    
    const code = response.response
    
    // TODO: Inject via native messaging
    return {
      success: true,
      generated: true,
      injected: false,
      code,
      message: "Code generated. Injection requires native messaging connection."
    }
  }
  
  // =========================================================================
  // MONITORING
  // =========================================================================
  
  @method async errorMonitor(analyze: boolean, threshold: number): Promise<any> {
    const errors = sharedDataBridge.getRuntimeErrors()
    const count = errors.length
    const exceeds = count > threshold
    
    let analysis = null
    if (analyze && errors.length > 0) {
      const context = await BrittneyService.collectBrowserContext()
      const response = await BrittneyService.call(
        `Analyze this error: ${errors[0].message}`,
        { browserContext: context }
      )
      analysis = response.success ? response.response : null
    }
    
    return {
      count,
      exceeds,
      threshold,
      latestError: errors[0] || null,
      analysis
    }
  }
  
  @method async autoFix(errorIndex: number, apply: boolean): Promise<any> {
    const errors = sharedDataBridge.getRuntimeErrors()
    const error = errors[errorIndex]
    
    if (!error) {
      return { success: false, error: "No error at index " + errorIndex }
    }
    
    const context = await BrittneyService.collectBrowserContext()
    
    const prompt = `Generate a fix for this error:
Error: ${error.message}
Stack: ${error.stack || "N/A"}

Provide HoloScript code that fixes this issue.`
    
    const response = await BrittneyService.call(prompt, { browserContext: context })
    
    return {
      error,
      fix: response.success ? response.response : null,
      applied: false,
      message: apply ? "Auto-apply requires native messaging connection" : "Preview only"
    }
  }
  
  @method async performanceMonitor(
    fpsThreshold: number,
    memoryThresholdMB: number,
    getSuggestions?: boolean
  ): Promise<any> {
    const stats = sharedDataBridge.getProfilerStats()
    
    if (!stats) {
      return { connected: false, message: "No performance data available" }
    }
    
    const fpsBelowThreshold = stats.fps < fpsThreshold
    const memoryAboveThreshold = stats.memoryUsed > memoryThresholdMB * 1024 * 1024
    const alert = fpsBelowThreshold || memoryAboveThreshold
    
    let suggestions = null
    if ((getSuggestions === true || (getSuggestions === undefined && alert))) {
      const context = await BrittneyService.collectBrowserContext()
      const response = await BrittneyService.call(
        `Performance is ${fpsBelowThreshold ? "low FPS" : ""} ${memoryAboveThreshold ? "high memory" : ""}. Suggest optimizations.`,
        { browserContext: context }
      )
      suggestions = response.success ? response.response : null
    }
    
    return {
      stats,
      alert,
      fpsBelowThreshold,
      memoryAboveThreshold,
      thresholds: { fps: fpsThreshold, memoryMB: memoryThresholdMB },
      suggestions
    }
  }
  
  // =========================================================================
  // PLAYGROUND
  // =========================================================================
  
  @method async playground(code: string, action: string, convertFrom?: string): Promise<any> {
    switch (action) {
      case "validate":
        // TODO: Use HoloScript parser
        return { valid: true, message: "Syntax validation requires parser" }
        
      case "explain":
        const explainResponse = await BrittneyService.call(
          `Explain this HoloScript code:\n${code}`,
          { systemPrompt: "You are a HoloScript expert. Explain code clearly." }
        )
        return { explanation: explainResponse.response }
        
      case "optimize":
        const optimizeResponse = await BrittneyService.call(
          `Optimize this HoloScript code for performance:\n${code}`,
          { systemPrompt: "You are a HoloScript performance expert." }
        )
        return { optimized: optimizeResponse.response }
        
      case "inject":
        return { injected: false, message: "Injection requires native messaging" }
        
      case "convert":
        const convertResponse = await BrittneyService.call(
          `Convert this ${convertFrom} to HoloScript:\n${code}`,
          { systemPrompt: "Convert to valid HoloScript syntax." }
        )
        return { converted: convertResponse.response }
        
      default:
        return { error: "Unknown action: " + action }
    }
  }
  
  // =========================================================================
  // TEMPLATES
  // =========================================================================
  
  @method getTemplate(category: string, customize?: Record<string, any>): any {
    const template = HOLOSCRIPT_TEMPLATES[category]
    
    if (!template) {
      return {
        error: "Unknown template category",
        available: Object.keys(HOLOSCRIPT_TEMPLATES)
      }
    }
    
    return {
      category,
      template,
      customize: customize || null
    }
  }
  
  // =========================================================================
  // SNAPSHOTS
  // =========================================================================
  
  @method async sceneSnapshot(
    name: string,
    includeScreenshot: boolean,
    includePerformance: boolean
  ): Promise<any> {
    const snapshot: SceneSnapshot = {
      id: `snapshot_${Date.now()}`,
      name,
      timestamp: Date.now(),
      objects: [],
      performance: includePerformance ? sharedDataBridge.getProfilerStats() : null,
      screenshot: null
    }
    
    AdvancedBrittneyState.snapshots.set(name, snapshot)
    
    return {
      success: true,
      snapshot: {
        id: snapshot.id,
        name: snapshot.name,
        timestamp: snapshot.timestamp
      }
    }
  }
  
  @method compareSnapshots(snapshot1: string, snapshot2?: string): any {
    const s1 = AdvancedBrittneyState.snapshots.get(snapshot1)
    
    if (!s1) {
      return { error: "Snapshot not found: " + snapshot1 }
    }
    
    const s2 = snapshot2 
      ? AdvancedBrittneyState.snapshots.get(snapshot2)
      : null
    
    return {
      snapshot1: { name: s1.name, timestamp: s1.timestamp },
      snapshot2: s2 ? { name: s2.name, timestamp: s2.timestamp } : "current",
      diff: "Comparison requires scene data"
    }
  }
  
  // =========================================================================
  // SESSION RECORDING
  // =========================================================================
  
  @method recordSession(action: string, sessionName?: string, format?: string): any {
    switch (action) {
      case "start":
        if (!sessionName) {
          return { error: "Session name required" }
        }
        const session: SessionRecording = {
          id: `session_${Date.now()}`,
          name: sessionName,
          startTime: Date.now(),
          events: [],
          snapshots: []
        }
        AdvancedBrittneyState.activeSession = session
        return { success: true, session: { id: session.id, name: session.name } }
        
      case "stop":
        if (!AdvancedBrittneyState.activeSession) {
          return { error: "No active session" }
        }
        const stopped = AdvancedBrittneyState.activeSession
        stopped.endTime = Date.now()
        AdvancedBrittneyState.sessionRecordings.set(stopped.name, stopped)
        AdvancedBrittneyState.activeSession = null
        return { 
          success: true, 
          session: stopped,
          duration: stopped.endTime - stopped.startTime
        }
        
      case "status":
        return {
          active: AdvancedBrittneyState.activeSession !== null,
          session: AdvancedBrittneyState.activeSession
        }
        
      case "export":
        return { error: "Export not yet implemented", format }
        
      default:
        return { error: "Unknown action: " + action }
    }
  }
  
  // =========================================================================
  // TESTING
  // =========================================================================
  
  @method async accessibilityCheck(checks: string[]): Promise<any> {
    const context = await BrittneyService.collectBrowserContext()
    
    const response = await BrittneyService.call(
      `Check the scene for accessibility issues. Focus on: ${checks.join(", ")}`,
      { 
        browserContext: context,
        systemPrompt: "You are a VR/AR accessibility expert."
      }
    )
    
    return {
      checks,
      results: response.success ? response.response : null,
      error: response.success ? null : response.error
    }
  }
  
  @method async testScene(testType: string, baseline?: string, threshold?: number): Promise<any> {
    const stats = sharedDataBridge.getProfilerStats()
    
    switch (testType) {
      case "performance":
        return {
          passed: stats ? stats.fps >= (threshold || 30) : false,
          fps: stats?.fps,
          threshold: threshold || 30
        }
        
      case "holoscript-syntax":
        return { passed: true, message: "Syntax check requires parser" }
        
      case "accessibility":
        return this.accessibilityCheck(["all"])
        
      case "visual-regression":
        return { passed: true, message: "Visual regression requires baseline" }
        
      case "interaction":
        return { passed: true, message: "Interaction test requires browser context" }
        
      default:
        return { error: "Unknown test type" }
    }
  }
  
  @method async explainScene(depth: string, focus: string): Promise<any> {
    const context = await BrittneyService.collectBrowserContext()
    
    const response = await BrittneyService.call(
      `Explain the current scene. Depth: ${depth}. Focus: ${focus}.`,
      {
        browserContext: context,
        systemPrompt: "You are a Hololand scene expert. Explain scenes clearly."
      }
    )
    
    return {
      depth,
      focus,
      explanation: response.success ? response.response : null,
      context
    }
  }
  
  @method holoScriptDiff(newCode: string, showDetails: boolean): any {
    // TODO: Implement actual diff
    return {
      newCode,
      showDetails,
      diff: "Diff requires current scene HoloScript"
    }
  }
}

// =============================================================================
// EXPORTS
// =============================================================================

const advancedBrittneyTools = ADVANCED_BRITTNEY_TOOLS

async function handleAdvancedBrittneyTool(toolName: string, args: Record<string, any>): Promise<any> {
  return AdvancedBrittneyToolHandler.handle(toolName, args)
}

export {
  advancedBrittneyTools,
  handleAdvancedBrittneyTool,
  AdvancedBrittneyToolHandler,
  AdvancedBrittneyState,
  HOLOSCRIPT_TEMPLATES
}
