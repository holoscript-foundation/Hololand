  }
  
  destination: "world:plaza"
}`,

  "vehicle": `
template "Vehicle" {
  state {
    speed: 0
    max_speed: 20
    driver: null
  }
  
  action enter(player) {
    driver = player
    player.mount(this)
  }
  
  action accelerate() {
    speed = min(speed + 2, max_speed)
