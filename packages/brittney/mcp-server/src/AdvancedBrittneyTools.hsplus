/**
 * AdvancedBrittneyTools.hsplus
 * 
 * Power tools that extend Brittney's capabilities:
 * - One-shot generate & inject pipeline
 * - Real-time error monitoring with auto-fix
 * - Performance guard with AI optimization
 * - HoloScript playground for live testing
 * - Session recording & replay
 * - Visual comparison tools
 * - Scene versioning
 * 
 * @package @hololand/mcp-server
 * @version 2.0.0
 */

import { sharedDataBridge } from "./SharedDataBridge.hsplus"
import { BrittneyService } from "./BrittneyTools.hsplus"
import {
  Tool,
  SceneSnapshot,
  SessionRecording,
  SessionEvent,
  BrittneyBrowserContext
} from "./Types.hsplus"

// =============================================================================
// STATE
// =============================================================================

module AdvancedBrittneyState {
  @state {
    activeSession: SessionRecording = null
    snapshots: Map<string, SceneSnapshot> = new Map()
    sessionRecordings: Map<string, SessionRecording> = new Map()
  }
}

