{
  "name": "@hololand/brittney-models",
  "version": "1.0.0",
  "description": "Brittney AI model registry and download utilities",
  "license": "MIT",
  "type": "module",
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "types": "./dist/index.d.ts"
    },
    "./download": {
      "import": "./dist/download.js",
      "types": "./dist/download.d.ts"
    }
  },
  "bin": {
    "brittney-download": "./bin/download.mjs"
  },
  "files": [
    "dist",
    "bin",
    "README.md"
  ],
  "scripts": {
    "build": "tsc",
    "download": "node bin/download.mjs",
    "download:v1": "node bin/download.mjs --model v1-free",
    "verify": "node bin/verify.mjs"
  },
  "dependencies": {
    "node-fetch": "^3.3.0",
    "progress": "^2.0.3"
  },
  "devDependencies": {
    "@types/node": "^20.0.0",
    "@types/progress": "^2.0.0",
    "typescript": "^5.3.0"
  },
  "engines": {
    "node": ">=18.0.0"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/hololand/hololand.git",
    "directory": "packages/brittney/models"
  },
  "keywords": [
    "brittney",
    "ai",
    "model",
    "gguf",
    "holoscript",
    "hololand"
  ]
}
