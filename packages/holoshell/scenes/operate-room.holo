// HoloShell — chat surface
//
// Perceivable assistant/management surface. You TALK to Brittney (and the Daimon,
// D.053, which manifests THROUGH her via the rehydration channel — not as a panel).
// Founder ruling 2026-06-16: "I don't want data, I just want to chat with the LLM;
// the data gets processed by the agents." So this surface is ONE full-height chat.
//
// The machine-local data (worktree health, stale processes, consents, substrate
// pressure) is still collected by serve.mjs's /api/* endpoints for AGENTS to
// process in the background — it is no longer rendered here as dashboard panels.
//
// Compiled via Native2DCompiler to standalone HTML + the injected chat runtime.
// Build: node packages/holoshell/compile.mjs
// Serve: node packages/holoshell/serve.mjs  → http://localhost:8747

composition "OperateRoom" {
  metadata {
    title: "HoloShell"
    product: "HoloShell"
    sourceLayer: "HoloScript"
    phase: "C"
    schema: "hololand.holoshell.operate-room.v0.1.0"
    compile_target: "Native2DCompiler"
    serve_port: 8747
    surface: "chat"
  }

  environment {
    theme: "dark"
    backgroundColor: "#0d1117"
    render_mode: "desktop_2d"
  }

  // No data state — the surface holds a conversation, not dashboards. Brittney's
  // turn (+ proposals) is rendered by the injected chat runtime into the mount.
  state {}

  object "root" {
    type: "container"
    layout: "column"
    gap: 14
    // full viewport height; centered, readable column
    style: "height:100vh;max-width:900px;margin:0 auto;padding:20px;box-sizing:border-box"

    object "header" {
      type: "header"
      layout: "row"
      align: "baseline"
      gap: 12
      border_bottom: "1px solid #30363d"

      object "title"    { type: "text"; variant: "h1"; content: "HoloShell" }
      object "subtitle" { type: "text"; variant: "caption"; content: "chat with Brittney & Daimon — agents handle the data" }
    }

    // The chat IS the surface. Brittney routes through POST /api/brittney/chat →
    // the HoloShell operator loop, fleet-routed across both owned GPUs ($0). Her
    // reply + any permission-enveloped action proposals come back INLINE — she
    // proposes, you read them in the conversation; there is no dashboard. The
    // Daimon's remembered context (once emerged) rides along via rehydration.
    // The interactive DOM (messages / input / send) is built by the runtime helper.
    object "chat" {
      type: "main"
      id: "brittney-chat-mount"
      style: "flex:1 1 auto;display:flex;flex-direction:column;min-height:0"
    }
  }

  logic {
    on_enter {
      emit "holoshell_chat_loaded"
    }
  }
}
