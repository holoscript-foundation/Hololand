// HoloShell — chat + compact cockpit surface
//
// Perceivable assistant/management surface. You TALK to Brittney (and the Daimon,
// D.053, which manifests THROUGH her via the rehydration channel — not as a panel).
// Founder ruling 2026-06-16: "I don't want data, I just want to chat with the LLM;
// the data gets processed by the agents." The surface remains chat-first, with
// a compact operator capsule for runtime truth, context carry, guarded desktop
// routes, and receipts across agent turns.
//
// The machine-local data (worktree health, stale processes, consents, substrate
// pressure) is still collected by serve.mjs's /api/* endpoints for AGENTS to
// process in the background — only the compact cockpit capsule is rendered here.
//
// Compiled via Native2DCompiler to standalone HTML + the injected chat runtime.
// Build: node packages/holoshell/compile.mjs
// Serve: node packages/holoshell/serve.mjs  → http://localhost:8747

composition "OperateRoom" {
  metadata {
    title: "HoloShell"
    product: "HoloShell"
    sourceLayer: "HoloScript"
    phase: "C"
    schema: "hololand.holoshell.operate-room.v0.1.0"
    compile_target: "Native2DCompiler"
    serve_port: 8747
    surface: "chat_plus_compact_cockpit"
    operator_chat_source: "apps/holoshell/source/holoshell-brittney-operator-chat.hsplus"
    improvement_run_source: "apps/holoshell/source/holoshell-improvement-run-loop.hsplus"
    improvement_run_endpoint: "POST /api/improvement-runs"
    improvement_run_execute_endpoint: "POST /api/improvement-runs/:runId/execute"
    brittney_cockpit_source: "apps/holoshell/source/holoshell-brittney-desktop-cockpit.hsplus"
    brittney_cockpit_endpoint: "GET /api/cockpit/capsule"
    laptop_reasoning_source: "apps/holoshell/source/holoshell-laptop-reasoning-worker.hsplus"
    laptop_reasoning_lane: "laptop-hardware"
    laptop_reasoning_report_endpoint: "POST /api/laptop-reasoning/report"
    browser_terminal_coupling_source: "apps/holoshell/source/holoshell-browser-terminal-coupling.hsplus"
    operator_terminal_session_endpoint: "GET /api/operator-terminal/session"
    operator_terminal_report_endpoint: "POST /api/operator-terminal/report"
    desktop_bridge_endpoint: "GET /api/desktop-control/bridge"
    desktop_bridge_report_endpoint: "POST /api/desktop-control/bridge/report"
    window_awareness_report_endpoint: "POST /api/window-awareness/report"
    laptop_desktop_bridge_endpoint: "GET http://127.0.0.1:8751/api/desktop-control/bridge"
    laptop_desktop_bridge_fallback_endpoint: "GET http://127.0.0.1:8752/api/desktop-control/bridge"
    laptop_desktop_bridge_tertiary_endpoint: "GET http://127.0.0.1:8753/api/desktop-control/bridge"
    laptop_desktop_bridge_consent_endpoint: "POST http://127.0.0.1:{8751|8752|8753}/api/desktop-control/consent-token"
    laptop_desktop_bridge_execute_endpoint: "POST http://127.0.0.1:{8751|8752|8753}/api/desktop-control/execute"
  }

  environment {
    theme: "dark"
    backgroundColor: "#0d1117"
    render_mode: "desktop_2d"
  }

  // No data state — the surface holds a conversation, not dashboards. Brittney's
  // turn (+ proposals) is rendered by the injected chat runtime into the mount.
  // Public open_url desktop actions are surfaced as explicit approval buttons
  // that use the laptop bridge preflight -> consent-token -> execute chain.
  state {
    last_improvement_run_id: ""
    last_improvement_run_count: 0
    last_cockpit_capsule_status: ""
    last_laptop_reasoning_status: ""
    last_operator_terminal_status: ""
    last_operator_chat_receipt_type: ""
    stale_evidence_prompt_count: 0
    visible_action_proposal_count: 0
  }

  object "root" {
    type: "container"
    layout: "column"
    gap: 14
    // full viewport height; centered, readable column
    style: "height:100vh;max-width:900px;margin:0 auto;padding:20px;box-sizing:border-box"

    object "header" {
      type: "header"
      layout: "row"
      align: "baseline"
      gap: 12
      border_bottom: "1px solid #30363d"

      object "title"    { type: "text"; variant: "h1"; content: "HoloShell" }
      object "subtitle" { type: "text"; variant: "caption"; content: "chat with Brittney & Daimon — agents handle the data" }
    }

    // The chat IS the surface. Brittney routes through POST /api/brittney/chat →
    // the HoloShell operator loop, with owned GPU routes available ($0) and
    // receipts proving whether laptop GPU inference actually ran. Her
    // reply + any permission-enveloped action proposals come back INLINE — she
    // proposes, you read them in the conversation; there is no dashboard. The
    // Daimon's remembered context (once emerged) rides along via rehydration.
    // The compact cockpit strip consumes GET /api/cockpit/capsule, whose source
    // contract is apps/holoshell/source/holoshell-brittney-desktop-cockpit.hsplus.
    // Its Terminal card consumes GET /api/operator-terminal/session, whose source
    // contract binds browser chat and terminal evidence to one HoloShell session.
    // When SSH receipt mirroring is unavailable, the laptop can POST terminal,
    // reasoning, and window-awareness receipts back through /api/operator-terminal/report,
    // /api/laptop-reasoning/report, and /api/window-awareness/report, matching the
    // desktop bridge report lane.
    // Its Reasoning card uses the laptop-hardware lane so Brittney can distinguish
    // receipt-only completion from actual GPU-backed model invocation.
    // Improvement batches use POST /api/improvement-runs, then capped codebase-fix
    // shakedowns through POST /api/improvement-runs/:runId/execute. Counted runs
    // require patch + validation evidence; HoloTune waits until fixes pass review.
    // Vision models read screens/images; Fara is reserved for guarded desktop automation planning.
    // The browser probes the laptop bridge at 127.0.0.1:8751, 8752, then 8753
    // when needed, and reports status back to the Jetson surface; desktop mutation
    // remains consent-token gated.
    // The interactive DOM (messages / input / send) is built by the runtime helper.
    // Operator Chat v1 keeps the Brittney transcript/input as the focal workbench.
    // Lane truth, stale-evidence prompts, context capsule carry, proposal cards,
    // agent handoffs, and receipt narration stay compact in side rails or inline
    // turn cards instead of stacking above the conversation. The source contract is
    // apps/holoshell/source/holoshell-brittney-operator-chat.hsplus.
    object "chat" {
      type: "main"
      id: "brittney-chat-mount"
      style: "flex:1 1 auto;display:flex;flex-direction:column;min-height:0"
    }
  }

  logic {
    on_enter {
      emit "holoshell_chat_loaded"
    }
  }
}
