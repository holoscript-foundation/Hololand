{
  "name": "@hololand/react-three",
  "version": "1.0.0-alpha.1",
  "description": "React components for Hololand VR worlds with Three.js integration",
  "main": "./dist/index.js",
  "module": "./dist/index.mjs",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.mjs",
      "require": "./dist/index.js"
    }
  },
  "files": [
    "dist",
    "README.md"
  ],
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch",
    "test": "echo \"Tests coming soon\" && exit 0",
    "lint": "tsc --noEmit",
    "clean": "rm -rf dist"
  },
  "keywords": [
    "hololand",
    "react",
    "threejs",
    "vr",
    "webxr",
    "3d",
    "metaverse",
    "hooks",
    "components"
  ],
  "author": "Hololand Contributors",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/brianonbased-dev/Hololand.git",
    "directory": "packages/react-three"
  },
  "devDependencies": {
    "@types/react": "^18.2.0",
    "@types/three": "^0.159.0",
    "react": "^18.2.0",
    "tsup": "^8.0.1",
    "typescript": "^5.3.3"
  },
  "peerDependencies": {
    "@hololand/renderer": "^1.0.0-alpha.1",
    "@hololand/world": "^1.0.0-alpha.1",
    "react": "^18.0.0",
    "three": "^0.159.0"
  },
  "engines": {
    "node": ">=18.0.0"
  }
}
