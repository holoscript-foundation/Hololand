# HoloScript Playground - Production Environment
# This file should be used in production deployments
# Secrets should be injected via environment variables or secrets management

# ============================================
# AI SERVICE PROVIDERS
# ============================================

# Use environment variables for sensitive keys in production
VITE_BRITTNEY_ENABLED=true
VITE_BRITTNEY_API_URL=${BRITTNEY_API_URL}

VITE_OPENAI_ENABLED=true
VITE_OPENAI_API_KEY=${OPENAI_API_KEY}
VITE_OPENAI_MODEL=gpt-4-turbo

VITE_CLAUDE_ENABLED=true
VITE_CLAUDE_API_KEY=${CLAUDE_API_KEY}
VITE_CLAUDE_MODEL=claude-3-opus-20240229

VITE_OLLAMA_ENABLED=false
VITE_OLLAMA_BASE_URL=${OLLAMA_URL}
VITE_OLLAMA_MODEL=neural-chat

# ============================================
# APPLICATION SETTINGS
# ============================================

VITE_ENV=production
VITE_DEBUG=false

# Performance optimization for production
VITE_MAX_FRAME_TIME=16
VITE_TARGET_FPS=60

# Storage with production quota
VITE_LOCAL_STORAGE_ENABLED=true
VITE_STORAGE_QUOTA_MB=50

# ============================================
# DEPLOYMENT SETTINGS
# ============================================

VITE_API_BASE_URL=${API_BASE_URL}
VITE_WS_URL=${WS_URL}

# Enable analytics in production
VITE_ANALYTICS_ENABLED=true
VITE_ANALYTICS_KEY=${ANALYTICS_KEY}

# All features enabled in production
VITE_FEATURE_STREAMING=true
VITE_FEATURE_TEMPLATES=true
VITE_FEATURE_PROFILER=true
VITE_FEATURE_INSPECTOR=true

# Production security
VITE_CSP_ENABLED=true
VITE_CORS_ENABLED=true
