# HoloScript Playground - Environment Configuration
# Copy this file to .env and fill in your API keys

# ============================================
# AI SERVICE PROVIDERS
# ============================================

# Brittney AI (Workspace/Local)
# No API key needed - uses workspace model
VITE_BRITTNEY_ENABLED=true
VITE_BRITTNEY_API_URL=http://localhost:8000

# OpenAI GPT-4 Turbo
VITE_OPENAI_ENABLED=true
VITE_OPENAI_API_KEY=sk-your-api-key-here
VITE_OPENAI_MODEL=gpt-4-turbo

# Anthropic Claude 3 Opus
VITE_CLAUDE_ENABLED=true
VITE_CLAUDE_API_KEY=your-claude-api-key-here
VITE_CLAUDE_MODEL=claude-3-opus-20240229

# Ollama (Local Neural Chat)
VITE_OLLAMA_ENABLED=true
VITE_OLLAMA_BASE_URL=http://localhost:11434
VITE_OLLAMA_MODEL=neural-chat

# ============================================
# APPLICATION SETTINGS
# ============================================

# Environment
VITE_ENV=development
VITE_DEBUG=false

# Performance
VITE_MAX_FRAME_TIME=16
VITE_TARGET_FPS=60

# Storage
VITE_LOCAL_STORAGE_ENABLED=true
VITE_STORAGE_QUOTA_MB=100

# ============================================
# DEPLOYMENT SETTINGS
# ============================================

# API Endpoints
VITE_API_BASE_URL=http://localhost:3000
VITE_WS_URL=ws://localhost:3000

# Analytics (optional)
VITE_ANALYTICS_ENABLED=false
VITE_ANALYTICS_KEY=

# Feature Flags
VITE_FEATURE_STREAMING=true
VITE_FEATURE_TEMPLATES=true
VITE_FEATURE_PROFILER=true
VITE_FEATURE_INSPECTOR=true
