# Brittney Cloud API - Environment Configuration

# Server
NODE_ENV=development
PORT=8080
API_VERSION=v1

# Database (PostgreSQL)
DATABASE_URL=postgresql://brittney:password@localhost:5432/brittney_prod
DATABASE_POOL_MIN=2
DATABASE_POOL_MAX=10

# Redis
REDIS_URL=redis://localhost:6379
REDIS_KEY_PREFIX=brittney:

# Stripe Billing
STRIPE_SECRET_KEY=sk_test_...
STRIPE_WEBHOOK_SECRET=whsec_...
STRIPE_PUBLISHABLE_KEY=pk_test_...

# Brittney Inference Service
INFERENCE_SERVICE_URL=http://brittney-inference.brittney-prod.svc.cluster.local:11434
INFERENCE_TIMEOUT_MS=30000
INFERENCE_MAX_RETRIES=2

# Rate Limiting
RATE_LIMIT_FREE_RPM=3
RATE_LIMIT_FREE_RPD=100
RATE_LIMIT_PAYG_RPM=60
RATE_LIMIT_PAYG_RPD=10000
RATE_LIMIT_PRO_RPM=300
RATE_LIMIT_PRO_RPD=999999
RATE_LIMIT_ENTERPRISE_RPM=10000
RATE_LIMIT_ENTERPRISE_RPD=999999

# Pricing (USD per 1M tokens)
PRICE_FREE_TIER=0
PRICE_PAYG=0.30
PRICE_PRO_BASE=49
PRICE_PRO_INCLUDED_TOKENS=10000000
PRICE_PRO_OVERAGE_1=0.25
PRICE_PRO_OVERAGE_2=0.20
PRICE_ENTERPRISE_BASE=500
PRICE_ENTERPRISE_OVERAGE=0.15

# Quotas
QUOTA_FREE_MONTHLY_TOKENS=100000
QUOTA_PRO_MONTHLY_TOKENS=10000000

# Monitoring
LOG_LEVEL=info
METRICS_ENABLED=true
PROMETHEUS_PORT=9090

# Security
API_KEY_LENGTH=32
API_KEY_PREFIX_LIVE=britt_sk_live_
API_KEY_PREFIX_TEST=britt_sk_test_
JWT_SECRET=your-secret-key-change-in-production
CORS_ORIGINS=http://localhost:3000,https://hololand.ai

# Feature Flags
ENABLE_WEBSOCKET=true
ENABLE_STREAMING=true
ENABLE_USAGE_ALERTS=true
ENABLE_AUTO_BILLING=true
