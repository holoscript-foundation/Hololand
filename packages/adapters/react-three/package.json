{
  "name": "@hololand/react-three",
  "version": "1.0.0",
  "description": "React components for Hololand VR worlds with Three.js integration",
  "main": "./dist/index.js",
  "module": "./dist/index.mjs",
  "types": "./src/index.ts",
  "exports": {
    ".": {
      "types": "./src/index.ts",
      "import": "./dist/index.mjs",
      "require": "./dist/index.js"
    }
  },
  "files": [
    "dist",
    "README.md"
  ],
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch",
    "test": "echo \"Tests coming soon\" && exit 0",
    "lint": "node ../../../node_modules/eslint/bin/eslint.js src",
    "typecheck": "tsc --noEmit",
    "clean": "rm -rf dist"
  },
  "keywords": [
    "hololand",
    "react",
    "threejs",
    "vr",
    "webxr",
    "3d",
    "metaverse",
    "hooks",
    "components"
  ],
  "author": "Hololand Contributors",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/brianonbased-dev/Hololand.git",
    "directory": "packages/react-three"
  },
  "devDependencies": {
    "@types/react": "^18.2.0",
    "@types/three": "^0.159.0",
    "react": "^18.2.0",
    "tsup": "^8.0.1",
    "typescript": "^5.3.3"
  },
  "peerDependencies": {
    "@hololand/renderer": "^1.0.0",
    "@hololand/world": "^1.0.0",
    "react": "^18.0.0",
    "three": "^0.159.0"
  },
  "engines": {
    "node": ">=18.0.0"
  },
  "dependencies": {
    "@dimforge/rapier3d-compat": "^0.19.3",
    "@hololand/audio": "workspace:*",
    "@hololand/network": "workspace:*",
    "@holoscript/core": "^3.43.0",
    "@holoscript/r3f-renderer": "file:../../../../HoloScript/packages/r3f-renderer",
    "@react-three/drei": "^10.7.7",
    "@react-three/fiber": "^9.5.0",
    "@react-three/postprocessing": "^3.0.4",
    "@react-three/rapier": "^2.2.0",
    "@react-three/xr": "^6.6.29"
  }
}
