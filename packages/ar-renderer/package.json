{
  "name": "@hololand/ar-renderer",
  "version": "0.1.0",
  "description": "WebXR and Three.js AR rendering with VRM avatar support",
  "type": "module",
  "main": "./dist/index.js",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "files": [
    "dist",
    "README.md"
  ],
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@hololand/logger": "workspace:*"
  },
  "peerDependencies": {
    "three": "^0.160.0",
    "@pixiv/three-vrm": "^2.0.0"
  },
  "peerDependenciesMeta": {
    "@pixiv/three-vrm": {
      "optional": true
    }
  },
  "devDependencies": {
    "@types/node": "^20.10.0",
    "@types/three": "^0.160.0",
    "tsup": "^8.0.1",
    "typescript": "^5.3.2"
  },
  "keywords": [
    "ar",
    "webxr",
    "three.js",
    "vrm",
    "avatar",
    "rendering",
    "hololand"
  ],
  "license": "MIT"
}
