{
  "name": "@hololand/trait-marketplace",
  "version": "1.0.0",
  "description": "Trait marketplace where users can buy and sell custom HoloScript traits",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "scripts": {
    "dev": "vite",
    "build": "tsc && vite build",
    "typecheck": "tsc --noEmit",
    "db:generate": "prisma generate",
    "db:push": "prisma db push",
    "db:studio": "prisma studio"
  },
  "dependencies": {
    "@hololand/traits": "workspace:*",
    "@prisma/client": "^6.3.0",
    "@tanstack/react-query": "^5.0.0",
    "@trpc/client": "^11.0.0",
    "@trpc/react-query": "^11.0.0",
    "@trpc/server": "^11.0.0",
    "ethers": "^6.16.0",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "stripe": "^14.0.0",
    "zod": "^3.24.0"
  },
  "devDependencies": {
    "@types/react": "^18.3.12",
    "@types/react-dom": "^18.3.1",
    "@vitejs/plugin-react": "^4.3.4",
    "prisma": "^6.3.0",
    "typescript": "^5.7.2",
    "vite": "^6.0.3"
  },
  "keywords": [
    "holoscript",
    "traits",
    "marketplace",
    "blockchain",
    "nft"
  ],
  "author": "Hololand Team",
  "license": "MIT"
}
