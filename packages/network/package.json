{
  "name": "@hololand/network",
  "version": "1.0.0-alpha.1",
  "description": "Real-time networking and multiplayer for the Hololand metaverse",
  "main": "./dist/index.js",
  "module": "./dist/index.mjs",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.mjs",
      "require": "./dist/index.js"
    }
  },
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch",
    "test": "echo \"Tests coming soon\" && exit 0"
  },
  "keywords": [
    "hololand",
    "metaverse",
    "networking",
    "multiplayer",
    "websocket",
    "webrtc",
    "voice-chat",
    "real-time"
  ],
  "author": "Hololand Team",
  "license": "MIT",
  "dependencies": {
    "@hololand/logger": "workspace:*"
  },
  "devDependencies": {
    "tsup": "^8.0.1",
    "typescript": "^5.3.3"
  },
  "peerDependencies": {
    "@hololand/world": "workspace:*",
    "@hololand/social": "workspace:*"
  },
  "peerDependenciesMeta": {
    "@hololand/world": {
      "optional": true
    },
    "@hololand/social": {
      "optional": true
    }
  }
}
