// HoloScript+ Component: Quest Tracker System
// A complete quest system with objectives, progress, and rewards
//
// This example demonstrates:
// - Quest definitions with multiple objectives
// - Progress tracking and persistence
// - Quest chains and prerequisites
// - Reward distribution
// - Quest log UI
// - World markers and waypoints
// - NPC quest givers

import { Vec3, time } from "@holoscript/std"
import { ui, audio, particles } from "@holoscript/runtime"

// ============================================
// TYPES & INTERFACES
// ============================================

type QuestStatus = "locked" | "available" | "active" | "completed" | "failed"
type ObjectiveType = "kill" | "collect" | "talk" | "explore" | "escort" | "defend" | "craft" | "deliver"

interface QuestDefinition {
  id: string
  title: string
  description: string
  category: "main" | "side" | "daily" | "event"
  level: int
  prerequisites: List<string>
  objectives: List<ObjectiveDefinition>
  rewards: QuestRewards
  timeLimit: int?              // milliseconds, null = no limit
  repeatable: bool
  autoComplete: bool           // Complete when all objectives done
  chain: { previous: string?, next: string? }?
}

interface ObjectiveDefinition {
  id: string
  type: ObjectiveType
  description: string
  target: string              // Entity ID, item ID, location ID
  required: int               // Number needed
  optional: bool
  hidden: bool                // Reveal only when previous complete
  hints: List<string>?
  location: Vec3?             // For waypoint
}

interface ObjectiveProgress {
  objectiveId: string
  current: int
  completed: bool
}

interface QuestProgress {
  questId: string
  status: QuestStatus
  objectives: Map<string, ObjectiveProgress>
  startedAt: int
  completedAt: int?
  failedAt: int?
}

interface QuestRewards {
  experience: int
  gold: int
  items: List<{ itemId: string, quantity: int }>
  reputation: Map<string, int>?
  unlocks: List<string>?      // Quest IDs, abilities, areas
}

