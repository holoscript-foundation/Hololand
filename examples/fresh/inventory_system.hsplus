// HoloScript+ Component: Inventory System
// A complete inventory with items, slots, stacking, and equipment
//
// This example demonstrates:
// - Item definitions with properties
// - Grid-based inventory slots
// - Drag and drop mechanics
// - Item stacking and splitting
// - Equipment slots and stat bonuses
// - Loot and pickup systems
// - Crafting basics

import { Vec3, math, time } from "@holoscript/std"
import { ui, audio, particles } from "@holoscript/runtime"

// ============================================
// TYPES & INTERFACES
// ============================================

type ItemRarity = "common" | "uncommon" | "rare" | "epic" | "legendary"
type ItemType = "weapon" | "armor" | "consumable" | "material" | "quest" | "key"
type EquipSlot = "head" | "chest" | "legs" | "feet" | "mainhand" | "offhand" | "ring" | "amulet"

interface ItemDefinition {
  id: string
  name: string
  description: string
  type: ItemType
  rarity: ItemRarity
  icon: string
  stackable: bool
  maxStack: int
  value: int
  weight: float
  equipSlot: EquipSlot?
  stats: Map<string, int>?
  effects: List<ItemEffect>?
  craftingRecipe: CraftingRecipe?
}

interface ItemInstance {
  definitionId: string
  quantity: int
  durability: int?
  enchantments: List<string>?
  customData: Map<string, any>?
}

interface InventorySlot {
  index: int
  item: ItemInstance?
  locked: bool
}

interface EquipmentSlots {
  head: ItemInstance?
  chest: ItemInstance?
  legs: ItemInstance?
  feet: ItemInstance?
  mainhand: ItemInstance?
  offhand: ItemInstance?
  ring: ItemInstance?
  amulet: ItemInstance?
}

interface ItemEffect {
  type: "heal" | "buff" | "damage" | "teleport" | "unlock"
  value: int
  duration: int?
}

interface CraftingRecipe {
  materials: List<{ itemId: string, quantity: int }>
  craftTime: int
  requiredStation: string?
}

// ============================================
// ITEM DATABASE
// ============================================

items {
