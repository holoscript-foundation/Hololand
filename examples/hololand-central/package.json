{
  "name": "hololand-central",
  "version": "1.0.0",
  "description": "Hololand Central Hub - The public VR gateway to the Hololand metaverse",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "vite build",
    "typecheck": "tsc -b",
    "preview": "vite preview",
    "deploy": "pnpm build && vercel --prod",
    "db:generate": "prisma generate",
    "db:push": "prisma db push",
    "db:seed": "tsx prisma/seed.ts",
    "db:studio": "prisma studio",
    "db:migrate": "prisma migrate dev",
    "db:reset": "prisma migrate reset",
    "db:seed-templates": "tsx prisma/seedTemplates.ts",
    "test": "vitest run --passWithNoTests",
    "test:watch": "vitest",
    "test:ui": "vitest --ui",
    "test:coverage": "vitest run --coverage"
  },
  "prisma": {
    "seed": "tsx prisma/seed.ts"
  },
  "dependencies": {
    "@hololand/brittney-toolkit": "workspace:*",
    "@hololand/traits": "workspace:*",
    "@hololand/world": "workspace:*",
    "@holoscript/core": "^3.41.0",
    "@holoscript/runtime": "^3.1.1",
    "@lumaai/luma-web": "^0.2.2",
    "@react-three/drei": "^9.114.3",
    "@react-three/fiber": "^8.17.10",
    "@react-three/xr": "^6.2.5",
    "cannon-es": "^0.20.0",
    "openai": "^4.77.0",
    "postprocessing": "^6.35.6",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "react-router-dom": "^6.22.0",
    "three": "^0.170.0",
    "zustand": "^4.5.0",
    "@prisma/client": "^6.3.0",
    "bcrypt": "^5.1.1",
    "ethers": "^6.13.0",
    "next-auth": "^4.24.0",
    "@trpc/client": "^11.0.0",
    "@trpc/server": "^11.0.0",
    "@trpc/react-query": "^11.0.0",
    "@tanstack/react-query": "^5.0.0",
    "zod": "^3.24.0",
    "superjson": "^2.2.0"
  },
  "devDependencies": {
    "@types/react": "^18.3.12",
    "@types/react-dom": "^18.3.1",
    "@types/three": "^0.170.0",
    "@types/bcrypt": "^5.0.2",
    "@vitejs/plugin-react": "^4.3.4",
    "@vitest/ui": "^2.0.0",
    "prisma": "^6.3.0",
    "tsx": "^4.19.0",
    "typescript": "^5.7.2",
    "vite": "^6.0.3",
    "vitest": "^2.0.0"
  },
  "keywords": [
    "hololand",
    "vr",
    "webxr",
    "metaverse",
    "three.js",
    "react"
  ],
  "author": "Hololand Community",
  "license": "MIT"
}
