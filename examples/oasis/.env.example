# Hololand Oasis Environment Variables
# Copy to .env.local for local development

# API Configuration
VITE_API_URL=http://localhost:3001
VITE_WS_URL=ws://localhost:3001

# Supabase (via @hololand/auth)
VITE_SUPABASE_URL=your-supabase-url
VITE_SUPABASE_ANON_KEY=your-supabase-anon-key

# Brittney AI
VITE_BRITTNEY_API_URL=http://localhost:11434
VITE_BRITTNEY_MODEL=brittney-v14

# Feature Flags
VITE_ENABLE_VR=true
VITE_ENABLE_AR=true
VITE_ENABLE_VOICE_CHAT=true
VITE_ENABLE_AI_CREATION=true

# Analytics (optional)
VITE_POSTHOG_KEY=
VITE_SENTRY_DSN=

# Railway-specific (auto-populated)
# PORT - automatically set by Railway
# RAILWAY_PUBLIC_DOMAIN - automatically set by Railway
