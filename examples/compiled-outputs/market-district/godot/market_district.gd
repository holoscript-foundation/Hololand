func create_audio_stream(audio_name: String, file_path: String, loop: bool, volume: float, spatial: bool, pos: Vector3 = Vector3.ZERO):
	var audio_player

	if spatial:
		audio_player = AudioStreamPlayer3D.new()
		audio_player.position = pos
		audio_player.max_distance = 20.0
	else:
		audio_player = AudioStreamPlayer.new()

	audio_player.name = audio_name
	audio_player.stream = load("res://audio/" + file_path)
	audio_player.autoplay = true
	audio_player.volume_db = linear_to_db(volume)

	if audio_player.stream:
		audio_player.stream.loop = loop

	add_child(audio_player)

