# Helper Methods

func create_mesh(mesh_name: String, type: String, pos: Vector3, scale: Vector3) -> MeshInstance3D:
	var mesh_instance = MeshInstance3D.new()
	mesh_instance.name = mesh_name

	match type:
		"box":
			mesh_instance.mesh = BoxMesh.new()
			mesh_instance.mesh.size = scale
		"sphere":
			mesh_instance.mesh = SphereMesh.new()
			mesh_instance.mesh.radius = scale.x / 2.0
			mesh_instance.mesh.height = scale.y
		"cylinder":
			mesh_instance.mesh = CylinderMesh.new()
			mesh_instance.mesh.top_radius = scale.x / 2.0
			mesh_instance.mesh.bottom_radius = scale.x / 2.0
			mesh_instance.mesh.height = scale.y
		"plane":
			mesh_instance.mesh = PlaneMesh.new()
			mesh_instance.mesh.size = Vector2(scale.x, scale.z)

	mesh_instance.position = pos
	add_child(mesh_instance)
	scene_objects[mesh_name] = mesh_instance

	return mesh_instance

func create_standard_material(base_color: String, roughness: float, metallic: float) -> StandardMaterial3D:
	var mat = StandardMaterial3D.new()
	mat.albedo_color = Color(base_color)
	mat.roughness = roughness
	mat.metallic = metallic
	return mat

func create_emissive_material(base_color: String, emissive_color: String, emissive_intensity: float, opacity: float = 1.0) -> StandardMaterial3D:
	var mat = StandardMaterial3D.new()
	mat.albedo_color = Color(base_color)
	mat.emission_enabled = true
	mat.emission = Color(emissive_color)
	mat.emission_energy_multiplier = emissive_intensity

	if opacity < 1.0:
		mat.transparency = BaseMaterial3D.TRANSPARENCY_ALPHA
		mat.albedo_color.a = opacity

	return mat

func apply_material(mesh: MeshInstance3D, material: StandardMaterial3D):
	mesh.material_override = material

func apply_traits(node: Node3D, traits: Array):
	for trait in traits:
		match trait:
			"spatial":
				node.set_meta("trait_spatial", true)
			"networked":
				node.set_meta("trait_networked", true)
				# Add NetworkSync component
			"collision":
				# Collision shape is added separately
				pass
			"emissive":
				node.set_meta("trait_emissive", true)
			"grabbable":
				node.set_meta("trait_grabbable", true)
				# Add GrabbableController
			"interactive":
				node.set_meta("trait_interactive", true)
				# Add InteractionArea
			"sittable":
				node.set_meta("trait_sittable", true)
				# Add SittableController

func create_collision_shape(type: String, scale: Vector3) -> CollisionShape3D:
	var collision = CollisionShape3D.new()

	match type:
		"box":
			var shape = BoxShape3D.new()
			shape.size = scale
			collision.shape = shape
		"sphere":
			var shape = SphereShape3D.new()
			shape.radius = scale.x / 2.0
			collision.shape = shape
		"cylinder":
			var shape = CylinderShape3D.new()
			shape.radius = scale.x / 2.0
			shape.height = scale.y
			collision.shape = shape

	return collision

