# Hololand Environment Configuration
# ====================================
=your_value_here
# Brittney AI Service
BRITTNEY_PORT=your_value_here
BRITTNEY_HOST=your_value_here
=your_value_here
# Admin API Key for MCP and trusted clients
# This allows the MCP server to access cloud APIs through Brittney
BRITTNEY_ADMIN_KEY=your_value_here
=your_value_here
# Prefer local GGUF model over cloud APIs
BRITTNEY_PREFER_LOCAL=your_value_here
=your_value_here
# Local model path (auto-detected if not set)
# BRITTNEY_MODEL_PATH=./models/brittney-v4-expert.gguf
=your_value_here
# Cloud API Keys (optional - for fallback/advanced features)
# These are only used when admin key is provided
# GROK_API_KEY=your-grok-key
# OPENAI_API_KEY=your-openai-key
# ANTHROPIC_API_KEY=your-anthropic-key
=your_value_here
# Hololand App
NEXT_PUBLIC_APP_URL=your_value_here
=your_value_here
# Bitquery API (for Clanker token metadata)
# Get key at: https://account.bitquery.io/user/api_v2/api_keys
BITQUERY_API_KEY=your_value_here
=your_value_here
# OpenTelemetry (optional)
# OTEL_EXPORTER_OTLP_ENDPOINT=http://localhost:4318
