1.1 HoloScript Source Code
Universal Format:


world "ShowroomDemo" {
  @vr_mode      // Target VR layer
  @vrr_mode     // OR VRR layer (mutually exclusive with vr_mode)
  @ar_mode      // OR AR layer
  
  @target_platforms(["web", "quest", "ios", "android"])
  
  metadata: {
    title: "Tesla Showroom"
    description: "Explore vehicles in immersive detail"
    creator: "Tesla Motors"
    category: "automotive"
    tags: ["cars", "showroom", "commercial"]
  }
  
  environment: {
    sky: "hdri_warehouse.hdr"  // VR/VRR use HDRI, AR ignores
    lighting: "realistic"       // VR=stylized, VRR=photorealistic, AR=match real-world
    physics: "accurate"         // VR can be exaggerated, VRR must be real
    scale: "1:1"               // REQUIRED for VRR/AR, optional for VR
  }
  
  object "TeslaModelS" {
    model: "tesla_model_s_2024.glb"  // High-poly for VRR, auto-LOD for VR, mobile-optimized for AR
    position: [0, 0, 0]
    rotation: [0, 0, 0]
    scale: [1, 1, 1]           // Real-world scale
    
    // Layer-specific traits
    @vr: {
      @interactive(click_to_open_doors: true)
      @teleportable(enter_vehicle: true)
    }
    
    @vrr: {
      @photorealistic(materials: "automotive_pbr")
      @accurate_physics(mass: 2150kg)
      @configurator(colors: ["white", "black", "blue", "red"])
    }
    
    @ar: {
      @mobile_optimized(max_triangles: 50k)
      @real_world_scale(length: 196in)
      @anchoring(ground_plane: true)
      @occlusion(detect_real_objects: true)
    }
    
    materials: {
      paint: {
        type: "car_paint"
        color: "#FFFFFF"
        metallic: 0.9
        roughness: 0.1
        clearcoat: 1.0
      }
    }
    
    on_interact: {
      if (vr_mode) {
        open_door("driver")
        allow_enter_vehicle()
      }
      
      if (vrr_mode) {
        show_configurator_panel()
        enable_color_change()
      }
      
      if (ar_mode) {
        show_info_card(price, specs, reviews)
        enable_rotate_gesture()
      }
    }
  }
}
