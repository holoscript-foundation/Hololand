    @objc func handleRotation(_ recognizer: UIRotationGestureRecognizer) {
        guard let car = carEntity else { return }
        
        // AR-specific: Rotate car around Y-axis
        car.orientation *= simd_quatf(
            angle: Float(recognizer.rotation),
