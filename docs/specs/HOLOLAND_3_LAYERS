class ShowroomDemo_AR: UIViewController, ARSessionDelegate {
    var arView: ARView!
    var carEntity: ModelEntity?
    
    override func viewDidLoad() {
        super.viewDidLoad()
        
        // Setup ARView
        arView = ARView(frame: view.bounds)
        view.addSubview(arView)
        
        // AR-specific: World tracking configuration
        let configuration = ARWorldTrackingConfiguration()
        configuration.planeDetection = [.horizontal]  // Detect ground
        configuration.environmentTexturing = .automatic  // Real-world lighting
        
        // AR-specific: People occlusion (iOS 13+)
        if ARWorldTrackingConfiguration.supportsFrameSemantics(.personSegmentationWithDepth) {
            configuration.frameSemantics.insert(.personSegmentationWithDepth)
        }
        
        arView.session.run(configuration)
        arView.session.delegate = self
        
        // Load mobile-optimized model
        loadCarModel()
    }
    
    func loadCarModel() {
        // AR-specific: Mobile-optimized mesh (50K tris max)
        guard let modelURL = Bundle.main.url(
            forResource: "tesla_model_s_mobile",
            withExtension: "usdz"  // Apple's AR format
        ) else { return }
        
        // Load asynchronously
        ModelEntity.loadModelAsync(contentsOf: modelURL).sink(
            receiveCompletion: { completion in
                if case let .failure(error) = completion {
                    print("AR model load failed: \(error)")
                }
            },
            receiveValue: { [weak self] modelEntity in
                self?.setupCarEntity(modelEntity)
            }
        )
    }
    
    func setupCarEntity(_ model: ModelEntity) {
        self.carEntity = model
        
        // AR-specific: Set real-world scale
        // Tesla Model S length: 196 inches = 4.98 meters
        let scaleFactor: Float = 4.98 / model.visualBounds(relativeTo: nil).extents.x
        model.scale = SIMD3<Float>(repeating: scaleFactor)
        
        // AR-specific: Enable occlusion (real objects hide virtual car)
        model.components.set(ModelComponent(
            mesh: model.model!.mesh,
            materials: model.model!.materials.map { material in
                var mat = material
                mat.blending = .transparent(opacity: 1.0)
                return mat
            }
        ))
        
        // AR-specific: Ground plane anchoring
        let anchor = AnchorEntity(plane: .horizontal)
        anchor.addChild(model)
        
        arView.scene.addAnchor(anchor)
        
        // AR-specific: Add tap gesture for interaction
        setupARInteraction()
    }
    
    func setupARInteraction() {
        let tapGesture = UITapGestureRecognizer(
            target: self,
            action: #selector(handleTap)
        )
        arView.addGestureRecognizer(tapGesture)
        
        // AR-specific: Rotation gesture (pinch to rotate)
        let rotationGesture = UIRotationGestureRecognizer(
            target: self,
            action: #selector(handleRotation)
        )
        arView.addGestureRecognizer(rotationGesture)
    }
    
    @objc func handleTap(_ recognizer: UITapGestureRecognizer) {
        let location = recognizer.location(in: arView)
        
        // AR-specific: Raycast to find tapped entity
